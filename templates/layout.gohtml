{{define "head"}}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{.Title}} · CIMS</title>
  <script>
    (function () {
      try {
        var theme = localStorage.getItem("cims.theme");
        var prefersDark = window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches;
        if (theme === "dark" || (!theme && prefersDark)) {
          document.documentElement.classList.add("theme-dark");
        }
      } catch (error) {}
    })();
  </script>
  <link rel="stylesheet" href="/static/app.css?v=202607150001">
  <script src="/static/htmx.min.js?v=1.9.12"></script>
</head>
<body>
{{end}}

{{define "topbar"}}
{{if .User.ID}}
<nav class="navrail" aria-label="Primary">
  <button class="navitem navitem-modern navtoggle active" type="button" aria-label="Main Menu" aria-controls="primary-sidebar" aria-expanded="true"><img class="toolbar-icon-image" src="/static/toolbar-icons/main-menu-icon-v2.png" alt=""><span class="navlabel">Main Menu</span></button>
  <div class="navitem navitem-modern has-menu has-caret" tabindex="0" aria-label="Utility Files"><img class="toolbar-icon-image" src="/static/toolbar-icons/utility-files-icon-v2.png" alt=""><span class="navlabel">Utility Files</span>
    <div class="dropdown-menu wide-menu">
      <h3>Utility Files</h3>
      <a href="/masters/stocks/"><img class="dropdown-icon" src="/static/icons/dropdown-stocks.svg" alt="">Stocks</a>
      <a href="/masters/branches/"><img class="dropdown-icon" src="/static/icons/dropdown-branches.svg" alt="">Branches</a>
      <a href="/masters/suppliers/"><img class="dropdown-icon" src="/static/icons/dropdown-suppliers.svg" alt="">Suppliers</a>
      <a href="/masters/customers/"><img class="dropdown-icon" src="/static/icons/dropdown-customers.svg" alt="">Customers</a>
      <a href="/masters/expense-chart/"><img class="dropdown-icon" src="/static/icons/dropdown-expense-chart.svg" alt="">Expenses Chart</a>
      <a href="/masters/stock-categories/"><img class="dropdown-icon" src="/static/icons/dropdown-stock-categories.svg" alt="">Stock Categories</a>
    </div>
  </div>
  <div class="navitem navitem-modern has-menu has-caret" tabindex="0" aria-label="Other Files"><img class="toolbar-icon-image" src="/static/toolbar-icons/other-files-icon-v3.png" alt=""><span class="navlabel">Other Files</span>
    <div class="dropdown-menu">
      <h3>Other Files</h3>
      <a href="/transactions/stock-in/"><img class="dropdown-icon" src="/static/icons/dropdown-stock-in.svg" alt="">Stock In</a>
      <a href="/transactions/dr/"><img class="dropdown-icon" src="/static/icons/dropdown-stock-out.svg" alt="">Stock Out</a>
      <a href="/transactions/checks-in/"><img class="dropdown-icon" src="/static/icons/dropdown-checks-in.svg" alt="">Checks In</a>
      <a href="/transactions/other-income/"><img class="dropdown-icon" src="/static/icons/dropdown-other-income-file.svg" alt="">Other Income File</a>
      <a href="/masters/other-income-chart/"><img class="dropdown-icon" src="/static/icons/dropdown-other-income.svg" alt="">Other Income</a>
    </div>
  </div>
  <div class="navitem navitem-compact has-menu has-caret" tabindex="0" aria-label="Stock Summary"><img class="toolbar-icon-image" src="/static/toolbar-icons/stock-summary.png" alt=""><span class="navlabel">Stock Summary</span>
    <div class="dropdown-menu">
      <h3>Stock Summary</h3>
      <a href="/reports/stock-aging"><img class="dropdown-icon" src="/static/icons/dropdown-stock-aging.svg" alt="">Stock Aging</a>
      <a href="/reports/stock-ledger"><img class="dropdown-icon" src="/static/icons/dropdown-stock-ledger.svg" alt="">Stock Ledger</a>
      <a href="/reports/stock-reorder-point"><img class="dropdown-icon" src="/static/icons/dropdown-stock-reorder-point.svg" alt="">Stock Reorder Point</a>
      <a href="/reports/stock-summary"><img class="dropdown-icon" src="/static/icons/dropdown-stock-summary.svg" alt="">Stock Summary</a>
    </div>
  </div>
  <div class="navitem navitem-compact has-menu has-caret" tabindex="0" aria-label="Stock Purchases"><img class="toolbar-icon-image" src="/static/toolbar-icons/stock-purchases.png" alt=""><span class="navlabel">Stock Purchases</span>
    <div class="dropdown-menu">
      <h3>Stock Purchases</h3>
      <a href="/reports/purchases-by-dr-number"><img class="dropdown-icon" src="/static/icons/dropdown-purchases-by-dr-number.svg" alt="">By DR Number</a>
      <a href="/reports/purchases-by-stock-code"><img class="dropdown-icon" src="/static/icons/dropdown-purchases-by-stock-code.svg" alt="">By Stock Code</a>
      <a href="/reports/purchases-by-supplier"><img class="dropdown-icon" src="/static/icons/dropdown-purchases-by-supplier.svg" alt="">By Supplier</a>
    </div>
  </div>
  <div class="navitem navitem-compact has-menu has-caret" tabindex="0" aria-label="Stock Sales"><img class="toolbar-icon-image" src="/static/toolbar-icons/stock-sales.png" alt=""><span class="navlabel">Stock Sales</span>
    <div class="dropdown-menu">
      <h3>Stock Sales</h3>
      <a href="/reports/sales-by-customer"><img class="dropdown-icon" src="/static/icons/dropdown-sales-by-customer.svg" alt="">By Customer</a>
      <a href="/reports/sales-by-stock-name"><img class="dropdown-icon" src="/static/icons/dropdown-sales-by-stock-name.svg" alt="">By Stock Name</a>
      <a href="/reports/sales-by-or-ci-dr-number"><img class="dropdown-icon" src="/static/icons/dropdown-sales-by-or-ci-dr-number.svg" alt="">By OR/CI/DR Number</a>
      <a href="/reports/sales-summary-by-item"><img class="dropdown-icon" src="/static/icons/dropdown-sales-summary-by-item.svg" alt="">Summary By Item</a>
      <a href="/reports/sales-markup-by-transaction"><img class="dropdown-icon" src="/static/icons/dropdown-sales-markup-by-transaction.svg" alt="">Sales Markup by Transaction</a>
      <a href="/reports/sales-by-customer-summary-by-item"><img class="dropdown-icon" src="/static/icons/dropdown-sales-by-customer-summary.svg" alt="">By Customer (Summary By Item)</a>
    </div>
  </div>
  <div class="navitem navitem-compact has-menu has-caret" tabindex="0" aria-label="Stock Transfers"><img class="toolbar-icon-image" src="/static/toolbar-icons/stock-transfers.png" alt=""><span class="navlabel">Stock Transfers</span>
    <div class="dropdown-menu">
      <h3>Stock Transfers</h3>
      <a href="/reports/transfers-summary"><img class="dropdown-icon" src="/static/icons/dropdown-transfers-summary.svg" alt="">Summary</a>
      <a href="/reports/transfers-by-stock-name"><img class="dropdown-icon" src="/static/icons/dropdown-transfers-by-stock-name.svg" alt="">By Stock Name</a>
      <a href="/reports/transfers-by-entry-id"><img class="dropdown-icon" src="/static/icons/dropdown-transfers-by-entry-id.svg" alt="">By Entry ID</a>
      <a href="/reports/transfers-summary-by-entry-id"><img class="dropdown-icon" src="/static/icons/dropdown-transfers-summary-by-entry-id.svg" alt="">Summary By Entry ID</a>
      <a href="/reports/transfers-summary-by-item"><img class="dropdown-icon" src="/static/icons/dropdown-transfers-summary-by-item.svg" alt="">Summary By Item</a>
      <a href="/reports/transfers-markup-by-transaction"><img class="dropdown-icon" src="/static/icons/dropdown-transfers-markup-by-transaction.svg" alt="">Transfer Markup By Transaction</a>
      <a href="/reports/transfers-by-branch"><img class="dropdown-icon" src="/static/icons/dropdown-transfers-by-branch.svg" alt="">By Branch</a>
    </div>
  </div>
  <div class="navrail-spacer" aria-hidden="true"></div>
  <button class="nav-theme-toggle" type="button" data-theme-toggle title="Toggle dark mode" aria-label="Toggle dark mode">
    <span class="nav-theme-icon" data-theme-icon>☾</span>
    <span class="nav-theme-label" data-theme-label>Dark Mode</span>
  </button>
  <form method="post" action="/logout" class="nav-logout-form">
    <button class="nav-logout-button" type="submit" title="Logout" aria-label="Logout">
      <span class="nav-logout-icon" aria-hidden="true"></span>
      <span class="nav-logout-label">Logout</span>
    </button>
  </form>
</nav>
<aside class="sidebar" id="primary-sidebar" aria-label="Files">
  <section class="side-section expanded" data-section-key="files">
    <button class="side-section-toggle" type="button" aria-expanded="true">
      <span class="section-heading-label"><img class="section-heading-icon" src="/static/icons/sidebar-files.svg" alt="">Files</span>
      <span class="section-chevron" aria-hidden="true"></span>
    </button>
    <div class="side-section-body">
    <a class="side-link side-link-tile" href="/transactions/purchases/"><img class="side-icon" src="/static/icons/purchases.svg" alt=""><span class="side-text">Purchases File</span></a>
    <a class="side-link side-link-tile" href="/transactions/dr/"><img class="side-icon" src="/static/icons/dr.svg" alt=""><span class="side-text">Stock Out File</span></a>
    <a class="side-link side-link-tile" href="/transactions/sales/"><img class="side-icon" src="/static/icons/sales.svg" alt=""><span class="side-text">Sales File</span></a>
    <a class="side-link side-link-tile" href="/transactions/stock-transactions/"><img class="side-icon" src="/static/icons/transfer.svg" alt=""><span class="side-text">Stock Transaction File</span></a>
    <a class="side-link side-link-tile" href="/transactions/ap-credit/"><img class="side-icon" src="/static/icons/ap-credit.svg" alt=""><span class="side-text">AP Credit File</span></a>
    <a class="side-link side-link-tile" href="/transactions/ap-debit/"><img class="side-icon" src="/static/icons/ap-debit.svg" alt=""><span class="side-text">AP Debit File</span></a>
    <a class="side-link side-link-tile" href="/transactions/ar-credit/"><img class="side-icon" src="/static/icons/ar-credit.svg" alt=""><span class="side-text">AR Credit File</span></a>
    <a class="side-link side-link-tile" href="/transactions/ar-debit/"><img class="side-icon" src="/static/icons/ar-debit.svg" alt=""><span class="side-text">AR Debit File</span></a>
    <a class="side-link side-link-tile" href="/transactions/rebates/"><img class="side-icon" src="/static/icons/rebates.svg" alt=""><span class="side-text">Rebates Entry File</span></a>
    <a class="side-link side-link-tile" href="/transactions/expenses/"><img class="side-icon" src="/static/icons/expenses.svg" alt=""><span class="side-text">Expenses File</span></a>
    </div>
  </section>
  <section class="side-section expanded" data-section-key="reports">
    <button class="side-section-toggle" type="button" aria-expanded="true">
      <span class="section-heading-label"><img class="section-heading-icon" src="/static/icons/sidebar-reports.svg" alt="">Reports</span>
      <span class="section-chevron" aria-hidden="true"></span>
    </button>
    <div class="side-section-body">
    <a class="side-link side-link-report" href="/reports/purchases-summary"><img class="side-icon" src="/static/icons/report-purchases-summary.svg" alt=""><span class="side-text">Purchases Summary</span></a>
    <a class="side-link side-link-report" href="/reports/sales-summary"><img class="side-icon" src="/static/icons/report-sales-summary.svg" alt=""><span class="side-text">Sales Summary</span></a>
    <a class="side-link side-link-report" href="/reports/ap-ledger"><img class="side-icon" src="/static/icons/report-ap-ledger.svg" alt=""><span class="side-text">AP Ledger</span></a>
    <a class="side-link side-link-report" href="/reports/ar-ledger"><img class="side-icon" src="/static/icons/report-ar-ledger.svg" alt=""><span class="side-text">AR Ledger</span></a>
    <a class="side-link side-link-report" href="/reports/incoming-check-list"><img class="side-icon" src="/static/icons/report-incoming-check.svg" alt=""><span class="side-text">Incoming Check List</span></a>
    <a class="side-link side-link-report" href="/reports/expenses-summary"><img class="side-icon" src="/static/icons/report-expenses-summary.svg" alt=""><span class="side-text">Expenses Summary</span></a>
    <a class="side-link side-link-report" href="/reports/outgoing-check-list"><img class="side-icon" src="/static/icons/report-outgoing-check.svg" alt=""><span class="side-text">Outgoing Check List</span></a>
    <a class="side-link side-link-report" href="/reports/income-statement"><img class="side-icon" src="/static/icons/report-income-statement.svg" alt=""><span class="side-text">Income Statement</span></a>
    <a class="side-link side-link-report" href="/reports/incentive"><img class="side-icon" src="/static/icons/report-incentive.svg" alt=""><span class="side-text">Incentive Report</span></a>
    </div>
  </section>
  <section class="side-section expanded" data-section-key="special-reports">
    <button class="side-section-toggle" type="button" aria-expanded="true">
      <span class="section-heading-label"><img class="section-heading-icon" src="/static/icons/report-document.svg" alt="">Special Reports</span>
      <span class="section-chevron" aria-hidden="true"></span>
    </button>
    <div class="side-section-body">
    <a class="side-link side-link-report side-link-special-report" href="/reports/daily-sales-collection"><img class="side-icon" src="/static/icons/special-daily-sales-collection.svg" alt=""><span class="side-text">Daily Sales &amp; Collection</span></a>
    <a class="side-link side-link-report side-link-special-report" href="/reports/incoming-check-calendar"><img class="side-icon" src="/static/icons/special-incoming-check-calendar.svg" alt=""><span class="side-text">Incoming Check Calendar</span></a>
    <a class="side-link side-link-report side-link-special-report" href="/reports/daily-due-check"><img class="side-icon" src="/static/icons/special-daily-due-check.svg" alt=""><span class="side-text">Daily Due Check</span></a>
    <a class="side-link side-link-report side-link-special-report" href="/reports/stock-sales-transfer"><img class="side-icon" src="/static/icons/special-stock-sales-transfer.svg" alt=""><span class="side-text">Stock Sales &amp; Transfer</span></a>
    <a class="side-link side-link-report side-link-special-report" href="/reports/stock-sales-transfer-amount"><img class="side-icon" src="/static/icons/special-stock-sales-transfer-amount.svg" alt=""><span class="side-text">Stk. Sales &amp; Transfer Amount</span></a>
    </div>
  </section>
  <section class="side-section expanded" data-section-key="settings">
