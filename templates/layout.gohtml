      <span class="section-heading-label">Settings</span>
      <span class="section-chevron" aria-hidden="true"></span>
    </button>
    <div class="side-section-body">
    <a class="side-link" href="/dashboard"><span>♙</span><span class="side-text">User Settings</span></a>
    </div>
  </section>
</aside>
{{end}}
{{end}}

{{define "foot"}}
<script>
  (function () {
    var storageKey = "cims.sidebarCollapsed";
    var sectionKeyPrefix = "cims.sidebarSection.";
    var themeKey = "cims.theme";
    var body = document.body;
    var toggle = document.querySelector(".navtoggle");
    if (!body || !toggle) return;

    var themeToggles = Array.prototype.slice.call(document.querySelectorAll("[data-theme-toggle]"));
    var root = document.documentElement;

    var setThemeState = function (dark, persist) {
      root.classList.toggle("theme-dark", dark);
      themeToggles.forEach(function (themeToggle) {
        var themeLabel = themeToggle.querySelector("[data-theme-label]");
        var themeIcon = themeToggle.querySelector("[data-theme-icon]");
        if (themeLabel) themeLabel.textContent = dark ? "Light Mode" : "Dark Mode";
        if (themeIcon) themeIcon.textContent = dark ? "☀" : "☾";
        themeToggle.setAttribute("aria-pressed", dark ? "true" : "false");
      });
      if (persist) {
        localStorage.setItem(themeKey, dark ? "dark" : "light");
        window.dispatchEvent(new CustomEvent("cims:themechange", { detail: { dark: dark } }));
      }
    };

    setThemeState(root.classList.contains("theme-dark"), false);

    themeToggles.forEach(function (themeToggle) {
      themeToggle.addEventListener("click", function () {
        setThemeState(!root.classList.contains("theme-dark"), true);
      });
    });

    var navMenus = Array.prototype.slice.call(document.querySelectorAll(".navrail .has-menu"));
    var dismissMenu = function (menu) {
      if (!menu) return;
      menu.classList.add("menu-dismissed");
      menu.addEventListener("pointerleave", function clearDismissed() {
        menu.classList.remove("menu-dismissed");
      }, { once: true });
    };
    var activateMenu = function (activeMenu) {
      navMenus.forEach(function (menu) {
        if (menu === activeMenu) {
          menu.classList.remove("menu-dismissed");
        } else {
          dismissMenu(menu);
        }
      });
    };
    navMenus.forEach(function (menu) {
      menu.addEventListener("pointerenter", function () { activateMenu(menu); });
      menu.addEventListener("focusin", function () { activateMenu(menu); });
      menu.addEventListener("mousedown", function () { activateMenu(menu); });
    });

    document.querySelectorAll(".dropdown-menu a[href]").forEach(function (link) {
      link.addEventListener("click", function () {
        var menu = link.closest(".has-menu");
        if (!menu) return;
        dismissMenu(menu);
        menu.blur();
        link.blur();
      });
    });

    var setSidebarState = function (collapsed) {
      body.classList.toggle("sidebar-collapsed", collapsed);
      toggle.setAttribute("aria-expanded", collapsed ? "false" : "true");
    };

    setSidebarState(localStorage.getItem(storageKey) === "1");

    toggle.addEventListener("click", function () {
      var collapsed = !body.classList.contains("sidebar-collapsed");
      setSidebarState(collapsed);
      localStorage.setItem(storageKey, collapsed ? "1" : "0");
    });

    var sideSections = Array.prototype.slice.call(document.querySelectorAll(".side-section[data-section-key]"));
    var setSidebarSectionState = function (section, collapsed) {
      var button = section.querySelector(".side-section-toggle");
      if (!button) return;
      var sectionKey = sectionKeyPrefix + section.getAttribute("data-section-key");
      section.classList.toggle("collapsed", collapsed);
      section.classList.toggle("expanded", !collapsed);
      button.setAttribute("aria-expanded", collapsed ? "false" : "true");
      localStorage.setItem(sectionKey, collapsed ? "1" : "0");
    };

    sideSections.forEach(function (section) {
      var button = section.querySelector(".side-section-toggle");
      var sectionKey = sectionKeyPrefix + section.getAttribute("data-section-key");
      if (!button) return;
      setSidebarSectionState(section, localStorage.getItem(sectionKey) === "1");

      button.addEventListener("click", function () {
        var collapsed = !section.classList.contains("collapsed");
        setSidebarSectionState(section, collapsed);
        if (!collapsed) {
          sideSections.forEach(function (otherSection) {
            if (otherSection !== section) {
              setSidebarSectionState(otherSection, true);
            }
          });
        }

        if (section.getAttribute("data-section-key") === "files" && window.location.pathname !== "/dashboard") {
          window.location.href = "/dashboard";
        }
      });
    });

    var normalizePath = function (path) {
      if (!path) return "/";
      return path.length > 1 ? path.replace(/\/+$/, "") : path;
    };

    var currentPath = normalizePath(window.location.pathname);
    var bestMatch = null;

    document.querySelectorAll(".side-link[href]").forEach(function (link) {
      var href = normalizePath(link.getAttribute("href"));
      if (currentPath === href || (href !== "/" && currentPath.indexOf(href + "/") === 0)) {
        if (!bestMatch || href.length > bestMatch.href.length) {
          bestMatch = { link: link, href: href };
        }
      }
    });

    if (bestMatch) {
      bestMatch.link.classList.add("active");
    }
  })();

  (function () {
    var tree = document.querySelector(".report-preview-tree");
    if (!tree) return;

    var parseReportNumber = function (text) {
      var normalized = String(text || "").replace(/,/g, "").replace(/[()]/g, "-").replace(/[^0-9.\-]/g, "");
      var value = Number(normalized);
      return Number.isFinite(value) ? value : 0;
    };
    var elementHasReportValue = function (element) {
      if (!element) return false;
      var text = (element.innerText || element.textContent || "").replace(/\s+/g, " ").trim();
      if (!text || element.querySelector(".report-empty")) return false;
      var numericCells = Array.prototype.slice.call(element.querySelectorAll(".num"));
      if (numericCells.length) {
        return numericCells.some(function (cell) { return Math.abs(parseReportNumber(cell.textContent)) > 0.00001; });
      }
      return !!element.querySelector("tbody tr, [data-report-filter-item]") || !!text;
    };
    var elementMatchesFilterGroup = function (element, targetID) {
      return (element.getAttribute("data-report-filter-groups") || "").split(/\s+/).indexOf(targetID) !== -1;
    };
    var filterGroupHasReportValue = function (targetID) {
      return Array.prototype.slice.call(document.querySelectorAll("[data-report-filter-groups]")).some(function (element) {
        return elementMatchesFilterGroup(element, targetID) && elementHasReportValue(element);
      });
    };
    var pageHasReportValue = function (page) {
      var section = document.querySelector(".report-detail-group[data-report-page='" + String(page) + "']");
      if (!section) return false;
      var items = Array.prototype.slice.call(section.querySelectorAll("[data-report-filter-item]"));
      if (items.length) {
        return items.some(elementHasReportValue);
      }
      return elementHasReportValue(section);
    };
    var treeNodeHasReportValue = function (node) {
      var summaryRow = node.getAttribute("data-report-summary-row");
      if (summaryRow) {
        return elementHasReportValue(document.querySelector("tbody tr[data-report-summary-row='" + summaryRow + "']"));
      }
      var targetID = node.getAttribute("data-report-filter-target") || node.getAttribute("data-report-scroll-target");
      if (targetID) {
        return elementHasReportValue(document.getElementById(targetID)) || filterGroupHasReportValue(targetID);
      }
      if (node.hasAttribute("data-report-tree-page")) {
        return pageHasReportValue(Number(node.getAttribute("data-report-tree-page")));
      }
      return true;
    };
    var pruneEmptyReportTreeNodes = function () {
      if (tree.hasAttribute("data-report-always-full-tree")) return;
      treeNodes().forEach(function (node) {
        var item = node.closest("li");
        if (!item) return;
        var empty = !treeNodeHasReportValue(node);
        item.hidden = empty;
        item.toggleAttribute("data-report-pruned", empty);
      });
      Array.prototype.slice.call(tree.querySelectorAll(".report-tree-branch")).reverse().forEach(function (branch) {
        var parentNode = branch.querySelector(":scope > .report-tree-parent");
        var hasVisibleChild = Array.prototype.some.call(branch.querySelectorAll(":scope > ul > li"), function (child) {
          return !child.hasAttribute("data-report-pruned");
        });
        var empty = !hasVisibleChild && (!parentNode || !treeNodeHasReportValue(parentNode));
        branch.hidden = empty;
        branch.toggleAttribute("data-report-pruned", empty);
      });
    };
    var treeNodes = function () {
      return Array.prototype.slice.call(tree.querySelectorAll(".report-tree-node"));
    };
    pruneEmptyReportTreeNodes();
    var visibleTreeNodes = function () {
      return treeNodes().filter(function (node) {
        return node.offsetParent !== null && !node.closest("[data-report-pruned]") && !node.closest(".report-tree-branch.collapsed > ul");
      });
    };
    var scrollReportPaperToTop = function () {
      var paperScroll = document.querySelector(".report-paper-scroll");
      if (paperScroll) paperScroll.scrollTop = 0;
    };
    var resetReportPaperToTop = function () {
      scrollReportPaperToTop();
      window.setTimeout(scrollReportPaperToTop, 0);
      window.setTimeout(scrollReportPaperToTop, 50);
      window.requestAnimationFrame(scrollReportPaperToTop);
    };
    var focusTreeNode = function (node, activate) {
      if (!node) return;
      node.focus();
      node.scrollIntoView({block: "nearest", inline: "nearest"});
      if (activate) {
        node.setAttribute("data-report-keyboard-activate", "1");
        node.click();
        node.removeAttribute("data-report-keyboard-activate");
        if (!node.hasAttribute("data-report-scroll-target")) resetReportPaperToTop();
      }
    };

    tree.addEventListener("click", function (event) {
      var node = event.target.closest(".report-tree-node");
      if (!node || !tree.contains(node)) return;
      if (node.hasAttribute("data-report-scroll-target")) return;
      resetReportPaperToTop();
    });

    tree.addEventListener("keydown", function (event) {
      var node = event.target.closest(".report-tree-node");
      if (!node || !tree.contains(node)) return;

      var nodes = visibleTreeNodes();
      var currentIndex = nodes.indexOf(node);
      if (currentIndex < 0) return;

      if (event.key === "ArrowDown") {
        event.preventDefault();
        focusTreeNode(nodes[Math.min(nodes.length - 1, currentIndex + 1)], true);
      } else if (event.key === "ArrowUp") {
        event.preventDefault();
        focusTreeNode(nodes[Math.max(0, currentIndex - 1)], true);
      } else if (event.key === "ArrowRight" && node.hasAttribute("data-report-tree-toggle")) {
        var branch = node.closest(".report-tree-branch");
        if (branch && branch.classList.contains("collapsed")) {
          event.preventDefault();
          node.click();
        }
      } else if (event.key === "ArrowLeft" && node.hasAttribute("data-report-tree-toggle")) {
        var parentBranch = node.closest(".report-tree-branch");
        if (parentBranch && parentBranch.classList.contains("expanded")) {
          event.preventDefault();
          node.click();
        }
      } else if (event.key === "Home") {
        event.preventDefault();
        focusTreeNode(nodes[0], true);
      } else if (event.key === "End") {
        event.preventDefault();
        focusTreeNode(nodes[nodes.length - 1], true);
      }
    });
  })();

  (function () {
    var papers = Array.prototype.slice.call(document.querySelectorAll(".report-paper"));
    var zoom = document.querySelector("[data-report-zoom]");
    if (papers.length === 0 || !zoom) return;

    var reportZoomBase = 1.25;
    var applyReportZoom = function () {
      var displayZoom = Number(zoom.value) || 1;
      var actualZoom = displayZoom * reportZoomBase;
      papers.forEach(function (paper) {
        paper.style.transform = "scale(" + actualZoom + ")";
        paper.style.transformOrigin = "top center";
        var paperHeight = paper.offsetHeight || paper.scrollHeight || 0;
        paper.style.marginBottom = (60 + (paperHeight * (actualZoom - 1))) + "px";
      });
    };

    window.applyReportZoom = applyReportZoom;
    zoom.addEventListener("change", applyReportZoom);
    window.addEventListener("load", applyReportZoom);
    window.setTimeout(applyReportZoom, 0);
  })();

  (function () {
    var fillListTables = function () {
      document.querySelectorAll("table[data-fill-empty-rows]").forEach(function (table) {
        var wrap = table.closest(".list-table-wrap");
        var tbody = table.tBodies && table.tBodies[0];
        if (!wrap || !tbody) return;
        tbody.querySelectorAll(".empty-fill-row").forEach(function (row) { row.remove(); });
        if (tbody.querySelector(".lazy-load-row")) return;

        var sampleRow = tbody.querySelector("tr:not(.empty-fill-row)");
        var headerRow = table.tHead && table.tHead.rows[0];
        var columnCount = headerRow ? headerRow.cells.length : 1;
        var rowHeight = sampleRow ? sampleRow.getBoundingClientRect().height : 34;
        if (!rowHeight || rowHeight < 1) rowHeight = 34;

        var remaining = wrap.clientHeight - table.getBoundingClientRect().height;
        var rowsToAdd = Math.floor(remaining / rowHeight);
        for (var rowIndex = 0; rowIndex < rowsToAdd; rowIndex++) {
          var row = document.createElement("tr");
          row.className = "empty-fill-row";
          row.setAttribute("aria-hidden", "true");
          for (var cellIndex = 0; cellIndex < columnCount; cellIndex++) {
            row.appendChild(document.createElement("td"));
          }
          tbody.appendChild(row);
        }
      });
    };

    window.CIMSFillListTables = fillListTables;
    window.addEventListener("load", fillListTables);
    window.addEventListener("resize", fillListTables);
    document.addEventListener("htmx:afterSettle", fillListTables);
    window.setTimeout(fillListTables, 0);
    window.setTimeout(fillListTables, 100);
  })();
</script>
<script src="/static/table-sort.js?v=202606230001"></script>
{{if .User.ID}}<script src="/static/content-window.js?v=202606230002"></script>{{end}}
</body>
</html>
{{end}}
