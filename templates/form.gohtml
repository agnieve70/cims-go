        if (!row) return;
        var index = parseInt(row.getAttribute("data-sales-dr-index"), 10);
        applySalesDRSelection(salesDRPickerState.matches[index]);
      });
      salesDRPickerState.results.addEventListener("keydown", function (event) {
        var row = event.target.closest && event.target.closest("[data-sales-dr-option]");
        if (!row) return;
        event.stopPropagation();
        var index = parseInt(row.getAttribute("data-sales-dr-index"), 10);
        if (event.key === "Escape") {
          event.preventDefault();
          closeSalesDRPicker();
          return;
        }
        if (event.key === "ArrowDown") {
          event.preventDefault();
          focusSalesDRPickerRow(Math.min(index + 1, salesDRPickerState.matches.length - 1));
          return;
        }
        if (event.key === "ArrowUp") {
          event.preventDefault();
          focusSalesDRPickerRow(Math.max(index - 1, 0));
          return;
        }
        if (event.key === "Enter") {
          event.preventDefault();
          applySalesDRSelection(salesDRPickerState.matches[index]);
        }
      });
      salesDRPickerState.results.addEventListener("focusin", function (event) {
