          <input name="firstname" value="{{fieldValue $.Record "firstname"}}">
        </label>
        <label class="legacy-record-field">
          <span>Middle Name:</span>
          <input name="middlename" value="{{fieldValue $.Record "middlename"}}">
        </label>
        <label class="legacy-record-field">
