      var query = input.value.trim().toLowerCase();
      var supplier = purchaseSuppliers.find(function (item) {
        return item.label.toLowerCase() === query;
      }) || purchaseSuppliers.find(function (item) {
        return item.label.toLowerCase().indexOf(query) === 0;
      });
      hidden.value = supplier ? supplier.id : "";
      if (supplier && input.value !== supplier.label) input.value = supplier.label;
    }

