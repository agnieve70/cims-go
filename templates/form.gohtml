    var purchaseStockPickerState = {
      root: document.querySelector("[data-purchase-stock-picker]"),
      search: document.querySelector("[data-purchase-stock-picker-search]"),
      tableWrap: document.querySelector(".purchase-stock-picker-table-wrap"),
      results: document.querySelector("[data-purchase-stock-picker-results]"),
      empty: document.querySelector("[data-purchase-stock-picker-empty]"),
      matches: [],
      selectedIndex: -1,
      activeInput: null,
      activeRow: null
    };

    if (purchaseStockPickerState.root) {
      purchaseStockPickerState.root.classList.add("is-hidden");
      purchaseStockPickerState.root.setAttribute("aria-hidden", "true");
    }

    if (purchaseStockPickerState.tableWrap) {
      purchaseStockPickerState.tableWrap.tabIndex = -1;
      purchaseStockPickerState.tableWrap.setAttribute("role", "listbox");
    }

    function caretToEnd(target) {
      if (!target || !target.isContentEditable) return;
      var selection = window.getSelection && window.getSelection();
      if (!selection) return;
      var range = document.createRange();
      range.selectNodeContents(target);
      range.collapse(false);
      selection.removeAllRanges();
      selection.addRange(range);
    }

    function filterPurchaseStocks(query) {
      query = String(query || "").trim().toLowerCase();
      if (!query) return purchaseStocks.slice();
      return purchaseStocks.filter(function (stock) {
        return [stock.code, stock.name, stock.label].some(function (value) {
          return String(value || "").toLowerCase().indexOf(query) !== -1;
        });
      });
    }

    function highlightPurchaseStockPickerRow(index) {
      purchaseStockPickerState.selectedIndex = index;
      if (!purchaseStockPickerState.results) return;
      Array.prototype.forEach.call(purchaseStockPickerState.results.querySelectorAll("tr"), function (row, rowIndex) {
        row.classList.toggle("is-active", rowIndex === index);
        row.tabIndex = rowIndex === index ? 0 : -1;
        row.setAttribute("aria-selected", rowIndex === index ? "true" : "false");
      });
    }

    function focusPurchaseStockPickerRow(index) {
      if (!purchaseStockPickerState.results || index < 0) return;
      highlightPurchaseStockPickerRow(index);
      var row = purchaseStockPickerState.results.querySelector("[data-stock-index='" + String(index) + "']");
      if (!row) return;
      row.focus();
      if (typeof row.scrollIntoView === "function") {
        row.scrollIntoView({ block: "nearest" });
      }
    }

    function renderPurchaseStockPicker(query) {
      if (!purchaseStockPickerState.results) return;
      purchaseStockPickerState.matches = filterPurchaseStocks(query);
      purchaseStockPickerState.results.innerHTML = "";
      purchaseStockPickerState.matches.forEach(function (stock, index) {
        var row = document.createElement("tr");
        row.setAttribute("data-purchase-stock-option", "");
        row.setAttribute("data-stock-index", String(index));
        row.setAttribute("role", "option");
        row.tabIndex = -1;

        var code = document.createElement("td");
        code.textContent = stock.code;
        row.appendChild(code);

        var name = document.createElement("td");
        name.textContent = stock.name;
        row.appendChild(name);

        purchaseStockPickerState.results.appendChild(row);
      });
      if (purchaseStockPickerState.empty) {
        purchaseStockPickerState.empty.classList.toggle("is-hidden", purchaseStockPickerState.matches.length !== 0);
      }
      highlightPurchaseStockPickerRow(purchaseStockPickerState.matches.length ? 0 : -1);
    }

    function closePurchaseStockPicker() {
      if (!purchaseStockPickerState.root) return;
      purchaseStockPickerState.root.classList.add("is-hidden");
      purchaseStockPickerState.root.setAttribute("aria-hidden", "true");
      var input = purchaseStockPickerState.activeInput;
      purchaseStockPickerState.activeInput = null;
      purchaseStockPickerState.activeRow = null;
      purchaseStockPickerState.matches = [];
      purchaseStockPickerState.selectedIndex = -1;
      if (input) input.focus();
    }

    function applyPurchaseStockSelection(stock) {
      if (!stock || !purchaseStockPickerState.activeRow) return;
      var row = purchaseStockPickerState.activeRow;
      var codeCell = row.querySelector("[data-field='stock_code']");
      var nameCell = row.querySelector("[data-field='stock_name']");
      if (codeCell) codeCell.value = stock.code;
      if (nameCell) nameCell.textContent = stock.name;
      setHidden(row, "stock_id", stock.id);
      syncStockPickerRow(row, codeCell);
      closePurchaseStockPicker();
      var qtyCell = row.querySelector("[data-field='qty']");
      if (qtyCell) {
        qtyCell.focus();
        caretToEnd(qtyCell);
      }
    }

    function openPurchaseStockPicker(input) {
      if (!purchaseStockPickerState.root || !input) return;
      purchaseStockPickerState.activeInput = input;
      purchaseStockPickerState.activeRow = input.closest("[data-stock-picker-row]");
      purchaseStockPickerState.root.classList.remove("is-hidden");
      purchaseStockPickerState.root.setAttribute("aria-hidden", "false");
      if (purchaseStockPickerState.search) {
        purchaseStockPickerState.search.value = cellText(input);
        renderPurchaseStockPicker(purchaseStockPickerState.search.value);
        purchaseStockPickerState.search.focus();
        purchaseStockPickerState.search.select();
      } else {
        renderPurchaseStockPicker(cellText(input));
      }
    }

    function syncDRDetailRow(row, sourceCell) {
      var stockID = row.querySelector("[data-field-input='stock_id']");
      var codeCell = row.querySelector("[data-field='stock_code']");
      var nameCell = row.querySelector("[data-field='stock_name']");
      var qtyCell = row.querySelector("[data-field='qty']");
      var stock = null;
      if (sourceCell && sourceCell.dataset.field === "stock_name") {
        stock = findStock(cellText(nameCell), "name");
      } else {
        stock = findStock(cellText(codeCell), "code");
      }
      if (stock) {
        codeCell.value = stock.code;
        nameCell.textContent = stock.name;
        if (stockID) stockID.value = stock.id;
      } else if (stockID && !cellText(codeCell) && !cellText(nameCell)) {
        stockID.value = "";
      }
      setHidden(row, "qty", cellText(qtyCell));
    }

    function renumberDRDetails() {
      document.querySelectorAll(".dr-detail-row").forEach(function (row, index) {
        var no = row.querySelector(".row-no");
        if (no) no.textContent = String(index + 1) + ".";
      });
    }

    function hydrateDRDetails() {
      document.querySelectorAll(".dr-detail-row").forEach(function (row) {
        var stockID = (row.querySelector("[data-field-input='stock_id']") || {}).value || "";
        var stock = purchaseStocks.find(function (item) { return item.id === stockID; });
        if (stock) {
          row.querySelector("[data-field='stock_code']").value = stock.code;
          row.querySelector("[data-field='stock_name']").textContent = stock.name;
        }
        syncDRDetailRow(row);
      });
      renumberDRDetails();
      ensureStockPickerBlankRow("dr");
    }

    function syncDRCustomer() {
      var select = document.querySelector("[data-dr-party-select]");
      if (!select) return null;
      return drCustomers.find(function (item) {
        return item.id === String(select.value || "");
      }) || null;
    }

    function hydrateDRCustomer() {
      var select = document.querySelector("[data-dr-party-select]");
      if (!select) return;
      if (select.value && !syncDRCustomer()) {
        select.value = "";
      }
      select.addEventListener("change", syncDRCustomer);
    }

    function syncARCreditCompany() {
      var input = document.querySelector("input[name='ar_credit_company_name']");
      var hidden = document.querySelector("[data-ar-credit-party-id]");
      if (!input || !hidden) return;
      var query = input.value.trim().toLowerCase();
      var customer = drCustomers.find(function (item) {
        return item.label.toLowerCase() === query;
      }) || drCustomers.find(function (item) {
        return item.label.toLowerCase().indexOf(query) === 0;
      });
      hidden.value = customer ? customer.id : "";
      if (customer && input.value !== customer.label) input.value = customer.label;
    }

    function hydrateARCreditCompany() {
      var input = document.querySelector("input[name='ar_credit_company_name']");
      var hidden = document.querySelector("[data-ar-credit-party-id]");
      if (!input || !hidden) return;
      var customer = drCustomers.find(function (item) {
        return item.id === hidden.value;
      });
      if (customer) input.value = customer.label;
      input.addEventListener("input", syncARCreditCompany);
      input.addEventListener("change", syncARCreditCompany);
      input.addEventListener("blur", syncARCreditCompany);
      var form = input.closest("form");
      if (form) form.addEventListener("submit", syncARCreditCompany);
    }

