    function syncSalesDetailRow(row) {
      var qty = parseMoney(cellText(row.querySelector("[data-field='qty']")));
      var unitCost = parseMoney(cellText(row.querySelector("[data-field='unit_cost']")));
      var amountCell = row.querySelector("[data-field='amount']");
      var discount = parseMoney(cellText(row.querySelector("[data-field='discount']")));
      var otherDiscount = parseMoney(cellText(row.querySelector("[data-field='other_discount']")));
      var capital = parseMoney(cellText(row.querySelector("[data-field='capital']")));
      var amount = parseMoney(cellText(amountCell));
      if (qty && unitCost && !amount) {
        amount = qty * unitCost;
        amountCell.textContent = formatMoney(amount);
      }
      var net = amount - discount - otherDiscount;
      var markup = net - capital;
      var markupPct = capital ? (markup / capital) * 100 : 0;
      var netCell = row.querySelector("[data-field='net_amount']");
      var markupCell = row.querySelector("[data-field='markup']");
      var markupPctCell = row.querySelector("[data-field='markup_pct']");
      if (netCell) netCell.textContent = formatMoney(net);
      if (markupCell && !cellText(markupCell)) markupCell.textContent = formatMoney(markup);
      if (markupPctCell && !cellText(markupPctCell)) markupPctCell.textContent = formatMoney(markupPct);
      ["stock_label", "qty", "unit_cost", "amount", "capital", "discount", "other_discount", "markup", "markup_pct"].forEach(function (field) {
        if (field === "stock_label") {
          var code = cellText(row.querySelector("[data-field='stock_code']"));
          var name = cellText(row.querySelector("[data-field='stock_name']"));
          setHidden(row, field, name ? code + " - " + name : code);
        } else {
          setHidden(row, field, cellText(row.querySelector("[data-field='" + field + "']")));
        }
      });
      var groupInput = row.querySelector("[data-field-input='stock_group']");
      var stockID = (row.querySelector("[data-field-input='stock_id']") || {}).value || "";
      if (groupInput && !groupInput.value) groupInput.value = salesStockGroups[stockID] || "Ungrouped";
    }

    function hydrateSalesDetails() {
      document.querySelectorAll(".sales-detail-row").forEach(function (row, index) {
        var no = row.querySelector(".row-no");
        var label = (row.querySelector("[data-field-input='stock_label']") || {}).value || cellText(row.querySelector("[data-field='stock_code']"));
        var groupInput = row.querySelector("[data-field-input='stock_group']");
        var stockID = (row.querySelector("[data-field-input='stock_id']") || {}).value || "";
        var parts = label.split(" - ");
        var code = (parts.shift() || label).trim();
        var name = parts.join(" - ").trim();
        if (no) no.textContent = String(index + 1) + ".";
        row.querySelector("[data-field='stock_code']").textContent = code;
        row.querySelector("[data-field='stock_name']").textContent = name;
        if (groupInput && !groupInput.value) groupInput.value = salesStockGroups[stockID] || "Ungrouped";
        syncSalesDetailRow(row);
      });
      updateSalesTotals();
    }

    function renderSalesMarkupSummary(groups) {
      var tbody = document.querySelector("#sales-markup-summary-rows");
      if (!tbody) return;
      tbody.innerHTML = "";
      Object.keys(groups).sort().forEach(function (groupName, index) {
        var group = groups[groupName];
        var avgMarkup = group.capital ? (group.markup / group.capital) * 100 : 0;
        var tr = document.createElement("tr");
        [String(index + 1) + ".", groupName, formatMoney(group.net), formatMoney(group.capital), formatMoney(group.markup), formatMoney(avgMarkup)].forEach(function (value) {
          var td = document.createElement("td");
          td.textContent = value;
          tr.appendChild(td);
        });
        tbody.appendChild(tr);
      });
    }

    function updateSalesTotals() {
      var rows = Array.prototype.slice.call(document.querySelectorAll(".sales-detail-row"));
      var totalQty = 0;
      var gross = 0;
      var capital = 0;
      var lineDiscount = 0;
      var markup = 0;
      var groups = {};
      rows.forEach(function (row) {
        syncSalesDetailRow(row);
        var groupName = ((row.querySelector("[data-field-input='stock_group']") || {}).value || "Ungrouped").trim() || "Ungrouped";
        if (!groups[groupName]) groups[groupName] = { net: 0, capital: 0, markup: 0 };
        var rowNet = parseMoney(cellText(row.querySelector("[data-field='net_amount']")));
        var rowCapital = parseMoney(cellText(row.querySelector("[data-field='capital']")));
        var rowMarkup = parseMoney(cellText(row.querySelector("[data-field='markup']")));
        totalQty += parseMoney(cellText(row.querySelector("[data-field='qty']")));
        gross += parseMoney(cellText(row.querySelector("[data-field='amount']")));
        capital += rowCapital;
        lineDiscount += parseMoney(cellText(row.querySelector("[data-field='discount']"))) + parseMoney(cellText(row.querySelector("[data-field='other_discount']")));
        markup += rowMarkup;
        groups[groupName].net += rowNet;
        groups[groupName].capital += rowCapital;
        groups[groupName].markup += rowMarkup;
      });
      renderSalesMarkupSummary(groups);
      var deductions = sumInputs("input[name='line_deductions_amount']") || sumInputs("input[name='line_discounts_amount']");
      var additionals = sumInputs("input[name='line_additionals_amount']");
      var net = gross - lineDiscount - deductions + additionals;
      [
        ["[data-sales-total-qty]", totalQty],
        ["[data-sales-total-net]", net],
        ["[data-sales-total]", gross],
        ["[data-sales-less-a]", deductions],
        ["[data-sales-less-m]", lineDiscount],
        ["[data-sales-add]", additionals],
        ["[data-sales-net]", net]
      ].forEach(function (item) {
        var el = document.querySelector(item[0]);
        if (!el) return;
        if ("value" in el) el.value = formatMoney(item[1]);
        else el.textContent = formatMoney(item[1]);
      });
    }

    function setSalesTab(tab) {
      document.querySelectorAll("[data-sales-tab]").forEach(function (button) {
        button.classList.toggle("is-active", button.dataset.salesTab === tab);
      });
      document.querySelectorAll("[data-sales-panel]").forEach(function (panel) {
        panel.classList.toggle("is-hidden", panel.dataset.salesPanel !== tab);
      });
    }

    function findExpenseCode(query) {
      query = String(query || "").trim().toLowerCase();
      if (!query) return null;
      return expenseCodes.find(function (item) {
        return item.label.toLowerCase() === query;
      }) || expenseCodes.find(function (item) {
        return item.label.toLowerCase().indexOf(query) === 0;
      }) || null;
    }

    function syncExpenseRow(row, sourceCell) {
      var codeInput = row.querySelector("[data-field='code_label']");
      var code = findExpenseCode(cellText(codeInput));
      if (code) {
        codeInput.value = code.label;
        setHidden(row, "code_id", code.id);
      } else if (!cellText(codeInput)) {
        setHidden(row, "code_id", "");
      }
      var cash = parseMoney(cellText(row.querySelector("[data-field='cash']")));
      var check = parseMoney(cellText(row.querySelector("[data-field='check']")));
      var totalCell = row.querySelector("[data-field='total']");
      if ((cash || check) && (!cellText(totalCell) || sourceCell && (sourceCell.dataset.field === "cash" || sourceCell.dataset.field === "check"))) {
        totalCell.textContent = formatMoney(cash + check);
      }
      ["reference", "cash", "check", "total"].forEach(function (field) {
        setHidden(row, field, cellText(row.querySelector("[data-field='" + field + "']")));
      });
    }

    function updateExpenseTotals() {
      var cash = 0;
      var check = 0;
      var total = 0;
      document.querySelectorAll(".expense-detail-row").forEach(function (row) {
        syncExpenseRow(row);
        cash += parseMoney(cellText(row.querySelector("[data-field='cash']")));
        check += parseMoney(cellText(row.querySelector("[data-field='check']")));
        total += parseMoney(cellText(row.querySelector("[data-field='total']")));
      });
      [["[data-expense-cash-total]", cash], ["[data-expense-check-total]", check], ["[data-expense-grand-total]", total]].forEach(function (item) {
        var input = document.querySelector(item[0]);
        if (input) input.value = formatMoney(item[1]);
      });
    }

    function hydrateExpenseRows() {
      document.querySelectorAll(".expense-detail-row").forEach(function (row, index) {
        var no = row.querySelector(".row-no");
        var codeID = (row.querySelector("[data-field-input='code_id']") || {}).value || "";
        var code = expenseCodes.find(function (item) { return item.id === codeID; });
        if (no) no.textContent = String(index + 1) + ".";
        if (code) row.querySelector("[data-field='code_label']").value = code.label;
        syncExpenseRow(row);
      });
      updateExpenseTotals();
    }

    window.addExpenseRow = function () {
      var tbody = document.querySelector("#rows-details");
      var template = document.querySelector(".expense-detail-row");
      if (!tbody || !template) return;
      var row = template.cloneNode(true);
      row.querySelectorAll(".editable-cell").forEach(function (cell) { cell.textContent = ""; });
      row.querySelectorAll(".cell-combobox").forEach(function (input) { input.value = ""; });
      row.querySelectorAll("input[type='hidden']").forEach(function (input) { input.value = ""; });
      tbody.appendChild(row);
      hydrateExpenseRows();
      var first = row.querySelector(".cell-combobox, .editable-cell");
      if (first) first.focus();
    };

    function findOtherIncomeCode(query) {
      query = String(query || "").trim().toLowerCase();
      if (!query) return null;
      return otherIncomeCodes.find(function (item) {
        return item.label.toLowerCase() === query;
      }) || otherIncomeCodes.find(function (item) {
        return item.label.toLowerCase().indexOf(query) === 0;
      }) || null;
    }

