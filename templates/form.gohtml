        </label>
        <label class="legacy-record-field">
          <span>APS:</span>
          <input name="aps" value="{{fieldValue $.Record "aps"}}">
        </label>
        <label class="legacy-record-field legacy-monitor-field">
          <span></span>
          <span class="legacy-checkbox-copy">
            <input type="checkbox" name="farm_customer" {{if truthy (fieldValue $.Record "farm_customer")}}checked{{end}}>
            <span>Farm Customer</span>
          </span>
        </label>
        <label class="legacy-record-field">
          <span>Encoder:</span>
          <input value="{{fieldValue $.Record "encoder"}}" readonly tabindex="-1" aria-readonly="true">
        </label>
        <label class="legacy-record-field legacy-record-date">
          <span>Last Update:</span>
          <input value="{{fieldValue $.Record "last_update"}}" readonly tabindex="-1" aria-readonly="true">
        </label>
        <label class="legacy-record-field">
          <span>Last Update By:</span>
          <input value="{{fieldValue $.Record "updated_by"}}" readonly tabindex="-1" aria-readonly="true">
        </label>
      </section>
      {{else if eq .Form.Kind "expense-chart"}}
      <section class="stock-category-legacy-form stock-legacy-form">
        <label class="legacy-record-field legacy-record-id">
          <span>ID:</span>
          <input value="{{fieldValue $.Record "id"}}" readonly>
        </label>
        <label class="legacy-record-field">
          <span>Code:</span>
          <input name="code" value="{{fieldValue $.Record "code"}}" required>
        </label>
        <label class="legacy-record-field">
          <span>Name:</span>
          <input name="name" value="{{fieldValue $.Record "name"}}" required>
        </label>
        <label class="legacy-record-field">
          <span>Description:</span>
          <textarea name="description" rows="3">{{fieldValue $.Record "description"}}</textarea>
        </label>
        <label class="legacy-record-field legacy-monitor-field">
          <span></span>
          <span class="legacy-checkbox-copy">
            <input type="checkbox" name="exclude_daily_sales" {{if truthy (fieldValue $.Record "exclude_daily_sales")}}checked{{end}}>
            <span>Not Included in Daily Sales and Collection Report</span>
          </span>
        </label>
        <label class="legacy-record-field legacy-monitor-field">
          <span></span>
          <span class="legacy-checkbox-copy">
            <input type="checkbox" name="daily_sales_only" {{if truthy (fieldValue $.Record "daily_sales_only")}}checked{{end}}>
            <span>For Daily Sales and Collection Report Only</span>
          </span>
        </label>
        <label class="legacy-record-field">
          <span>Encoder:</span>
          <input value="{{fieldValue $.Record "encoder"}}" readonly tabindex="-1" aria-readonly="true">
        </label>
        <label class="legacy-record-field legacy-record-date">
          <span>Last Update:</span>
          <input value="{{fieldValue $.Record "last_update"}}" readonly tabindex="-1" aria-readonly="true">
        </label>
        <label class="legacy-record-field">
          <span>Last Update By:</span>
          <input value="{{fieldValue $.Record "updated_by"}}" readonly tabindex="-1" aria-readonly="true">
        </label>
      </section>
      {{else}}
      <section class="form-grid modal-fields{{if eq .Form.Kind "other-income-chart"}} other-income-chart-fields{{end}}">
        {{range .Form.Fields}}
          <label class="field {{if eq .Type "textarea"}}wide{{end}} {{if eq .Type "bool"}}check-field{{end}}">
            <span>{{.Label}}{{if .Required}} *{{end}}</span>
            {{if eq .Type "textarea"}}
              <textarea name="{{.Key}}" rows="2">{{fieldValue $.Record .Key}}</textarea>
            {{else if eq .Type "bool"}}
              <input type="checkbox" name="{{.Key}}" {{if truthy (fieldValue $.Record .Key)}}checked{{end}}>
            {{else if eq .Type "readonly"}}
              <input name="{{.Key}}" value="{{fieldValue $.Record .Key}}" readonly>
            {{else if eq .Type "select"}}
              <select name="{{.Key}}" {{if .Required}}required{{end}} {{if and (eq .Key "dr_document_id") (or (eq $.Form.Kind "sales") (eq $.Form.Kind "stock-transactions"))}}onchange="window.location=window.location.pathname + (this.value ? '?dr_document_id=' + this.value : '')"{{end}}>
                <option value="">Select</option>
                {{$current := fieldValue $.Record .Key}}
                {{range index $.Options .Source}}
                  <option value="{{.Value}}" {{if eq .Value $current}}selected{{end}}>{{.Label}}</option>
                {{end}}
              </select>
            {{else if eq .Type "combo"}}
              <input name="{{.Key}}" list="list-{{.Key}}" value="{{fieldValue $.Record .Key}}" {{if .Required}}required{{end}}>
              <datalist id="list-{{.Key}}">
                {{range index $.Options .Source}}
                  <option value="{{.Value}}">{{.Label}}</option>
                {{end}}
              </datalist>
            {{else}}
              <input name="{{.Key}}" type="{{if eq .Type "date"}}date{{else if eq .Type "money"}}number{{else if eq .Type "number"}}number{{else}}text{{end}}" step="{{if eq .Type "money"}}0.01{{else}}1{{end}}" value="{{fieldValue $.Record .Key}}" {{if .Required}}required{{end}}>
            {{end}}
          </label>
        {{end}}
      </section>
      {{end}}

      {{if and (ne .Form.Kind "purchases") (ne .Form.Kind "dr") (ne .Form.Kind "sales") (ne .Form.Kind "stock-transactions") (ne .Form.Kind "ap-credit") (ne .Form.Kind "ar-credit") (ne .Form.Kind "rebates") (ne .Form.Kind "ap-debit") (ne .Form.Kind "ar-debit") (ne .Form.Kind "expenses") (ne .Form.Kind "other-income") (ne .Form.Kind "stock-in") (ne .Form.Kind "stock-out") (ne .Form.Kind "checks-in")}}
        {{range .Form.LineGroups}}
        {{$group := .}}
        <section class="line-section modal-line-section">
          <div class="section-head">
            <h2>{{.Label}}</h2>
            {{if and (eq $.Form.Kind "sales") (eq .Key "details")}}
              {{if not (fieldValue $.Record "dr_document_id")}}<span class="muted">Select a DR file first.</span>{{end}}
            {{else if and (eq $.Form.Kind "stock-transactions") (eq .Key "details")}}
              {{if not (fieldValue $.Record "dr_document_id")}}<span class="muted">Select a DR file first.</span>{{end}}
            {{else}}
              <button type="button" hx-get="/line-row/{{.Key}}" hx-target="#rows-{{.Key}}" hx-swap="beforeend">Add Row</button>
            {{end}}
          </div>
          <div class="table-wrap modal-table">
            <table>
              <thead>
                <tr>{{range .Columns}}{{if .Hidden}}<th class="hidden-col"></th>{{else}}<th>{{.Label}}</th>{{end}}{{end}}</tr>
              </thead>
              <tbody id="rows-{{.Key}}">
                {{$rows := index $.LineRows .Key}}
                {{if $rows}}
                  {{range $rows}}
                    {{template "line_row.gohtml" dictRow $group $.Options .}}
                  {{end}}
                {{else if and (or (eq $.Form.Kind "sales") (eq $.Form.Kind "stock-transactions")) (eq .Key "details")}}
                  <tr><td colspan="20" class="empty">Select a DR file to load detail quantities.</td></tr>
                {{else}}
                  {{template "line_row.gohtml" dictLine $group $.Options}}
                  {{template "line_row.gohtml" dictLine $group $.Options}}
                  {{template "line_row.gohtml" dictLine $group $.Options}}
                {{end}}
              </tbody>
            </table>
          </div>
        </section>
        {{end}}
      {{end}}
    </div>

    <div class="modal-footer actions">
      {{if eq .Form.Kind "purchases"}}
      <div class="legacy-form-toolbar" aria-label="Record actions">
        <button type="button" title="New" aria-label="New record" data-form-action="new"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 3h8l4 4v14H6z"/><path d="M14 3v5h5"/><path d="M9 14h6M12 11v6"/></svg></button>
        <button type="submit" title="Save" aria-label="Save"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 4h12l2 2v14H5z"/><path d="M8 4v6h8V4"/><path d="M8 15h8v5H8z"/></svg></button>
        <span class="legacy-toolbar-separator"></span>
        <button type="button" title="First" aria-label="First record" onclick="goPurchaseRecord('first')"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 5v14"/><path d="M18 6l-8 6 8 6z"/></svg></button>
        <button type="button" title="Previous" aria-label="Previous record" onclick="goPurchaseRecord('previous')"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16 6l-8 6 8 6z"/></svg></button>
