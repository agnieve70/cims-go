      </div>
      {{else if or (eq .Form.Kind "expenses") (eq .Form.Kind "stock-in") (eq .Form.Kind "stock-out") (eq .Form.Kind "checks-in")}}
      <div class="legacy-form-toolbar" aria-label="Record actions">
        <button type="submit" title="Save" aria-label="Save"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 4h12l2 2v14H5z"/><path d="M8 4v6h8V4"/><path d="M8 15h8v5H8z"/></svg></button>
        <span class="legacy-toolbar-separator"></span>
        <button type="button" title="First" aria-label="First record" onclick="goPurchaseRecord('first')"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 5v14"/><path d="M18 6l-8 6 8 6z"/></svg></button>
        <button type="button" title="Previous" aria-label="Previous record" onclick="goPurchaseRecord('previous')"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16 6l-8 6 8 6z"/></svg></button>
        <button type="button" title="Next" aria-label="Next record" onclick="goPurchaseRecord('next')"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 6l8 6-8 6z"/></svg></button>
        <button type="button" title="Last" aria-label="Last record" onclick="goPurchaseRecord('last')"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 5v14"/><path d="M6 6l8 6-8 6z"/></svg></button>
        <span class="legacy-toolbar-separator"></span>
        <button type="button" title="Search" aria-label="Search" data-form-action="search" onclick="searchStockCategoryRecord()"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="6"/><path d="M16 16l4 4"/></svg></button>
        <span class="legacy-toolbar-spacer"></span>
        <button type="button" title="Open" aria-label="Open list" data-form-action="open-list"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 7h7l2 2h9v10H3z"/><path d="M3 7v12"/></svg></button>
      </div>
      {{else if or (eq .Form.Kind "stock-categories") (eq .Form.Kind "stocks") (eq .Form.Kind "branches") (eq .Form.Kind "suppliers") (eq .Form.Kind "customers") (eq .Form.Kind "expense-chart") (eq .Form.Kind "other-income-chart")}}
      <div class="legacy-form-toolbar" aria-label="Record actions">
        <button type="submit" title="Save" aria-label="Save"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 4h12l2 2v14H5z"/><path d="M8 4v6h8V4"/><path d="M8 15h8v5H8z"/></svg></button>
        <span class="legacy-toolbar-separator"></span>
        <button type="button" title="First" aria-label="First record" onclick="goStockCategoryRecord('{{.FirstRecordID}}')" {{if or (not .CanDelete) .Embedded}}disabled{{end}}><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 5v14"/><path d="M18 6l-8 6 8 6z"/></svg></button>
        <button type="button" title="Previous" aria-label="Previous record" onclick="goStockCategoryRecord('{{.PreviousRecordID}}')" {{if or (not .CanDelete) .Embedded}}disabled{{end}}><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16 6l-8 6 8 6z"/></svg></button>
        <button type="button" title="Next" aria-label="Next record" onclick="goStockCategoryRecord('{{.NextRecordID}}')" {{if or (not .CanDelete) .Embedded}}disabled{{end}}><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 6l8 6-8 6z"/></svg></button>
        <button type="button" title="Last" aria-label="Last record" onclick="goStockCategoryRecord('{{.LastRecordID}}')" {{if or (not .CanDelete) .Embedded}}disabled{{end}}><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 5v14"/><path d="M6 6l8 6-8 6z"/></svg></button>
        <span class="legacy-toolbar-separator"></span>
        <button type="submit" class="legacy-toolbar-delete" title="Delete" aria-label="Delete current record" form="master-delete-form" {{if or (not .CanDelete) .Embedded}}disabled{{end}} onclick="return confirm('Delete this record?')"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18"/></svg></button>
        <button type="button" title="Search" aria-label="Search" data-form-action="search" onclick="searchStockCategoryRecord()" {{if or (not .CanDelete) .Embedded}}disabled{{end}}><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="6"/><path d="M16 16l4 4"/></svg></button>
        <span class="legacy-toolbar-spacer"></span>
        <button type="button" title="Open" aria-label="Open list" data-form-action="open-list" {{if or (not .CanDelete) .Embedded}}disabled{{end}}><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 7h7l2 2h9v10H3z"/><path d="M3 7v12"/></svg></button>
      </div>
      {{else}}
      <button type="submit">Save</button>
      <a class="button secondary" href="{{.Form.RouteBase}}/">Cancel</a>
      {{end}}
    </div>
  </form>

  {{if not .Embedded}}
  <div class="form-backdrop-table table-wrap">
    <form method="get" action="{{.Form.RouteBase}}/" class="legacy-strip" id="page-query-form">
      <div class="legacy-strip-note">After specifying keyword, press enter or click magnifying glass button, to search.</div>
      <div class="legacy-strip-controls">
        <label class="legacy-inline-field">
          <span>Year:</span>
          <select name="year">
            <option value="2025" {{if eq .Year 2025}}selected{{end}}>2025</option>
            <option value="2026" {{if eq .Year 2026}}selected{{end}}>2026</option>
            <option value="2027" {{if eq .Year 2027}}selected{{end}}>2027</option>
          </select>
        </label>
        <label class="legacy-inline-field legacy-strip-search">
          <span>Search:</span>
          <button type="submit" class="legacy-strip-icon-button" title="Search" aria-label="Search records"><img src="/static/icons/report-toolbar-find.svg" alt=""></button>
          <input type="text" name="q" value="{{.Search}}" placeholder="{{if eq .Form.Kind "stock-categories"}}Search group name, parent group, or encoder{{else}}Search records{{end}}">
        </label>
        <button type="submit" class="legacy-strip-refresh">Refresh</button>
      </div>
    </form>
    <table>
      {{if .Form.Table}}
      <thead>
        {{if eq .Form.Kind "stock-categories"}}
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>Group</th>
          <th>APS Monitor</th>
          <th>Encoder</th>
          <th>Last Update</th>
          <th>Last Update By</th>
        </tr>
        {{else}}
        <tr>
          <th>ID</th>
          {{range .Form.Fields}}<th>{{.Label}}</th>{{end}}
          <th>Encoder</th>
        </tr>
        {{end}}
      </thead>
      <tbody>
        {{if .User.CanWrite}}
        <tr class="add-new-row" tabindex="0" ondblclick="window.location='{{.Form.RouteBase}}/new'" onkeydown="if(event.key==='Enter'){window.location='{{.Form.RouteBase}}/new'}">
          {{if eq .Form.Kind "stock-categories"}}
          <td>+</td>
          <td colspan="6">Add new ...</td>
          {{else}}
          <td>Add new ...</td>
          <td colspan="20"></td>
          {{end}}
        </tr>
        {{end}}
        {{range .Records}}
        {{$record := .}}
        {{if eq $.Form.Kind "stock-categories"}}
        <tr class="data-row" data-record-id="{{index . "id"}}" data-record-search="{{range $.Form.Fields}} {{fieldValue $record .Key}}{{end}}" tabindex="0" ondblclick="window.location='{{$.Form.RouteBase}}/{{index . "id"}}/edit'" onkeydown="if(event.key==='Enter'){window.location='{{$.Form.RouteBase}}/{{index . "id"}}/edit'}">
          <td>{{index . "id"}}</td>
          <td>{{index . "name"}}</td>
          <td>{{index . "group_name"}}</td>
          <td>{{index . "aps_monitor"}}</td>
          <td>{{index . "encoder"}}</td>
          <td>{{index . "last_update"}}</td>
          <td>{{index . "updated_by"}}</td>
        </tr>
        {{else}}
        <tr class="data-row" data-record-id="{{index . "id"}}" data-record-search="{{range $.Form.Fields}} {{fieldValue $record .Key}}{{end}}" tabindex="0" ondblclick="window.location='{{$.Form.RouteBase}}/{{index . "id"}}/edit'" onkeydown="if(event.key==='Enter'){window.location='{{$.Form.RouteBase}}/{{index . "id"}}/edit'}">
          <td>{{index . "id"}}</td>
          {{range $.Form.Fields}}<td>{{fieldValue $record .Key}}</td>{{end}}
          <td>{{index . "encoder"}}</td>
        </tr>
        {{end}}
        {{else}}
        <tr><td colspan="20" class="empty">No records yet.</td></tr>
        {{end}}
      </tbody>
      {{else}}
      <thead>
        <tr><th>Entry ID</th><th>Date</th><th>Company</th><th>Reference</th><th>DR Ref</th><th>Status</th><th>Branch</th><th>Net</th><th>Encoder</th></tr>
      </thead>
      <tbody>
        {{if .User.CanWrite}}
        <tr class="add-new-row" tabindex="0" ondblclick="window.location='{{.Form.RouteBase}}/new'" onkeydown="if(event.key==='Enter'){window.location='{{.Form.RouteBase}}/new'}">
          <td>Add new ...</td>
          <td colspan="8"></td>
        </tr>
        {{end}}
        {{range .Documents}}
        <tr class="data-row" data-record-id="{{.ID}}" data-record-search="{{.EntryID}} {{.EntryDate.Format "2006-01-02"}} {{.Party}} {{.Reference}} {{.DRRef}} {{.Status}} {{.Branch}} {{.Net}} {{.Encoder}}" tabindex="0" ondblclick="window.location='{{$.Form.RouteBase}}/{{.ID}}/edit'" onkeydown="if(event.key==='Enter'){window.location='{{$.Form.RouteBase}}/{{.ID}}/edit'}">
          <td>{{.EntryID}}</td>
          <td>{{.EntryDate.Format "2006-01-02"}}</td>
          <td>{{.Party}}</td>
          <td>{{.Reference}}</td>
          <td>{{.DRRef}}</td>
          <td>{{.Status}}</td>
          <td>{{.Branch}}</td>
          <td>{{.Net}}</td>
          <td>{{.Encoder}}</td>
        </tr>
        {{else}}
        <tr><td colspan="9" class="empty">No entries yet.</td></tr>
        {{end}}
      </tbody>
      {{end}}
    </table>
  </div>
  {{end}}
</main>
{{if or (eq .Form.Kind "stock-categories") (eq .Form.Kind "stocks") (eq .Form.Kind "branches") (eq .Form.Kind "suppliers") (eq .Form.Kind "customers") (eq .Form.Kind "expense-chart") (eq .Form.Kind "purchases") (eq .Form.Kind "dr") (eq .Form.Kind "sales") (eq .Form.Kind "stock-transactions") (eq .Form.Kind "ap-credit") (eq .Form.Kind "ar-credit") (eq .Form.Kind "rebates") (eq .Form.Kind "ap-debit") (eq .Form.Kind "ar-debit") (eq .Form.Kind "expenses") (eq .Form.Kind "other-income") (eq .Form.Kind "stock-in") (eq .Form.Kind "stock-out") (eq .Form.Kind "checks-in")}}
{{if .CanDelete}}
<form id="master-delete-form" method="post" action="{{.Form.RouteBase}}/{{if fieldValue .Record "record_id"}}{{fieldValue .Record "record_id"}}{{else}}{{fieldValue .Record "id"}}{{end}}/delete"></form>
{{end}}
  <script>
  (function () {
    var routeBase = "{{.Form.RouteBase}}";
    var page = document.querySelector(".form-page");
    var formShell = document.querySelector(".form-shell.modal-form");
    var formBody = formShell && formShell.querySelector(".modal-body");
    var embeddedMode = !!(formShell && formShell.dataset.embedded === "true");
    var embeddedSaved = !!(formShell && formShell.dataset.embeddedSaved === "true");
    var existingRecord = !!(formShell && !embeddedMode && (formShell.dataset.existingRecord === "true" || /\/\d+\/edit$/.test(window.location.pathname)));
    var purchaseStocks = [
      {{range index .Options "stocks"}}
      { id: "{{.Value}}", label: "{{.Label}}" },
      {{end}}
    ].map(function (stock) {
      var parts = stock.label.split(" - ");
      stock.code = (parts.shift() || stock.label).trim();
      stock.name = parts.join(" - ").trim();
      return stock;
    });
    var purchaseSuppliers = [
      {{range index .Options "suppliers"}}
      { id: "{{.Value}}", label: "{{.Label}}" },
      {{end}}
    ];
    var drCustomers = [
      {{range index .Options "customers"}}
      { id: "{{.Value}}", label: "{{.Label}}" },
      {{end}}
    ];
    var drDocuments = [
      {{range index .Options "dr_documents"}}
      { id: "{{.Value}}", label: "{{.Label}}" },
      {{end}}
    ].map(function (document) {
      var parts = String(document.label || "").split(" - ");
      document.soNumber = (parts.shift() || document.label || "").trim();
      document.customer = parts.join(" - ").trim();
      return document;
    });
    var salesStockGroups = [
      {{range index .Options "stock_groups"}}
      { id: "{{.Value}}", label: "{{.Label}}" },
      {{end}}
    ].reduce(function (map, item) {
      map[item.id] = item.label || "Ungrouped";
      return map;
    }, {});
    var expenseCodes = [
      {{range index .Options "expense_charts"}}
      { id: "{{.Value}}", label: "{{.Label}}" },
      {{end}}
    ];
    var otherIncomeCodes = [
      {{range index .Options "other_income_charts"}}
      { id: "{{.Value}}", label: "{{.Label}}" },
      {{end}}
    ];
    window.goStockCategoryRecord = function (id) {
      if (id) window.location.href = routeBase + "/" + id + "/edit";
    };
    window.goPurchaseRecord = function (direction) {
      var ids = Array.prototype.slice.call(document.querySelectorAll(".form-backdrop-table .data-row[data-record-id]"))
        .map(function (row) { return row.getAttribute("data-record-id"); })
        .filter(Boolean);
      if (ids.length === 0) return;
      var current = (window.location.pathname.match(/\/(\d+)\/edit$/) || [])[1] || "";
      var index = ids.indexOf(current);
      if (direction === "first") index = ids.length - 1;
      else if (direction === "last") index = 0;
      else if (direction === "previous") index = index < 0 ? ids.length - 1 : Math.min(ids.length - 1, index + 1);
      else if (direction === "next") index = index < 0 ? 0 : Math.max(0, index - 1);
      window.goStockCategoryRecord(ids[index]);
    };
    window.searchStockCategoryRecord = function () {
      var fields = Array.prototype.slice.call(document.querySelectorAll(".modal-form [name]"))
        .filter(function (field) {
          return !field.disabled && field.type !== "hidden" && field.type !== "submit";
        })
        .map(function (field) {
          var value = field.value;
          if (field.tagName === "SELECT" && field.selectedOptions && field.selectedOptions[0]) {
            value = (value + " " + field.selectedOptions[0].textContent).trim();
          }
          return {
            key: field.name,
            value: (field.type === "checkbox" ? (field.checked ? "yes true" : "") : value).trim().toLowerCase()
          };
        })
        .filter(function (field) {
          return field.value !== "";
        });
      if (fields.length === 0) {
        var search = document.querySelector("#page-query-form input[name='q']");
        if (search) search.focus();
        return;
      }
      var rows = Array.prototype.slice.call(document.querySelectorAll(".form-backdrop-table .data-row[data-record-id]"));
      var match = rows.find(function (row) {
        var rowSearch = (row.getAttribute("data-record-search") || "").toLowerCase();
        return fields.every(function (field) {
          return rowSearch.indexOf(field.value) !== -1;
        });
      });
      if (match) {
        window.goStockCategoryRecord(match.getAttribute("data-record-id"));
      } else {
        alert("No matching record found.");
      }
    };

    function restoreElementTabIndex(element) {
      if (!element) return;
      if (Object.prototype.hasOwnProperty.call(element.dataset, "originalTabindex")) {
        element.setAttribute("tabindex", element.dataset.originalTabindex);
      } else {
        element.removeAttribute("tabindex");
      }
    }

    function rememberFormModeState() {
      if (!formBody) return;
      formBody.querySelectorAll("input, select, textarea, button").forEach(function (element) {
        if (!Object.prototype.hasOwnProperty.call(element.dataset, "originalDisabled")) {
          element.dataset.originalDisabled = element.disabled ? "true" : "false";
        }
        if (!Object.prototype.hasOwnProperty.call(element.dataset, "originalReadonly")) {
          element.dataset.originalReadonly = element.readOnly ? "true" : "false";
        }
        if (element.hasAttribute("tabindex") && !Object.prototype.hasOwnProperty.call(element.dataset, "originalTabindex")) {
          element.dataset.originalTabindex = element.getAttribute("tabindex");
        }
      });
      formBody.querySelectorAll("[contenteditable]").forEach(function (element) {
        if (!Object.prototype.hasOwnProperty.call(element.dataset, "originalContenteditable")) {
          element.dataset.originalContenteditable = element.getAttribute("contenteditable") || "true";
        }
        if (element.hasAttribute("tabindex") && !Object.prototype.hasOwnProperty.call(element.dataset, "originalTabindex")) {
          element.dataset.originalTabindex = element.getAttribute("tabindex");
        }
      });
    }

    function setFormBodyLocked(locked) {
      if (!formBody) return;
      formBody.querySelectorAll("input, select, textarea").forEach(function (element) {
        var type = String(element.type || "").toLowerCase();
        var originalDisabled = element.dataset.originalDisabled === "true";
        var originalReadonly = element.dataset.originalReadonly === "true";
        if (type === "hidden" || type === "submit" || type === "button" || type === "reset") {
          return;
        }
        if (locked) {
          if (!originalDisabled && !originalReadonly) {
            element.disabled = true;
            element.setAttribute("tabindex", "-1");
          }
        } else {
          element.disabled = originalDisabled;
          if (!originalDisabled && !originalReadonly) {
            restoreElementTabIndex(element);
          }
        }
      });
      formBody.querySelectorAll("button").forEach(function (button) {
        var originalDisabled = button.dataset.originalDisabled === "true";
        var keepEnabledWhileLocked = button.matches("[data-purchase-tab], [data-sales-tab], [data-sales-edit-stock-out], [data-transfer-edit-stock-out]");
        button.disabled = locked && !keepEnabledWhileLocked ? true : originalDisabled;
        if (locked && !keepEnabledWhileLocked) button.setAttribute("tabindex", "-1");
        else restoreElementTabIndex(button);
      });
      formBody.querySelectorAll("[contenteditable]").forEach(function (element) {
        var originalValue = element.dataset.originalContenteditable || "true";
        element.setAttribute("contenteditable", locked ? "false" : originalValue);
        if (locked) element.setAttribute("tabindex", "-1");
        else restoreElementTabIndex(element);
      });
    }

    function setToolbarLinkDisabled(link, disabled) {
      if (!link) return;
      link.classList.toggle("is-disabled", disabled);
      link.setAttribute("aria-disabled", disabled ? "true" : "false");
      if (disabled) {
        link.setAttribute("tabindex", "-1");
      } else {
        restoreElementTabIndex(link);
      }
    }

    function setToolbarMode(toolbar, editing) {
      if (!toolbar) return;
      var saveButton = toolbar.querySelector("[data-form-mode-save]");
      var editButton = toolbar.querySelector("[data-form-mode-control='edit']");
      var closeButton = toolbar.querySelector("[data-form-mode-control='close-edit']");
      Array.prototype.forEach.call(toolbar.querySelectorAll("button"), function (button) {
        if (!Object.prototype.hasOwnProperty.call(button.dataset, "toolbarOriginalDisabled")) {
          button.dataset.toolbarOriginalDisabled = button.disabled ? "true" : "false";
        }
        if (button.hasAttribute("tabindex") && !Object.prototype.hasOwnProperty.call(button.dataset, "originalTabindex")) {
          button.dataset.originalTabindex = button.getAttribute("tabindex");
        }
      });
      Array.prototype.forEach.call(toolbar.querySelectorAll("a.button"), function (link) {
        if (link.hasAttribute("tabindex") && !Object.prototype.hasOwnProperty.call(link.dataset, "originalTabindex")) {
          link.dataset.originalTabindex = link.getAttribute("tabindex");
        }
      });
      Array.prototype.forEach.call(toolbar.querySelectorAll("button"), function (button) {
        if (button === saveButton || button === editButton || button === closeButton) return;
        if (editing) {
          button.disabled = true;
          button.setAttribute("tabindex", "-1");
        } else {
          button.disabled = button.dataset.toolbarOriginalDisabled === "true";
          restoreElementTabIndex(button);
        }
      });
      Array.prototype.forEach.call(toolbar.querySelectorAll("a.button"), function (link) {
        setToolbarLinkDisabled(link, editing);
      });
      if (saveButton) {
        var saveOriginalDisabled = saveButton.dataset.toolbarOriginalDisabled === "true";
        saveButton.disabled = editing ? saveOriginalDisabled : true;
        if (!editing) saveButton.setAttribute("tabindex", "-1");
        else restoreElementTabIndex(saveButton);
      }
      if (editButton) {
        editButton.hidden = editing;
        editButton.disabled = editing;
        editButton.style.display = editing ? "none" : "";
        if (editing) editButton.setAttribute("tabindex", "-1");
        else restoreElementTabIndex(editButton);
      }
      if (closeButton) {
        closeButton.hidden = !editing;
        closeButton.disabled = !editing;
        closeButton.style.display = !editing ? "none" : "";
        if (!editing) closeButton.setAttribute("tabindex", "-1");
        else restoreElementTabIndex(closeButton);
      }
      if (page) page.classList.toggle("is-editing", editing);
      if (formShell) formShell.dataset.formMode = editing ? "edit" : "view";
    }

    function createToolbarModeButtons() {
      if (!existingRecord) return;
      document.querySelectorAll(".legacy-form-toolbar").forEach(function (toolbar) {
        if (toolbar.querySelector("[data-form-mode-control='edit']")) return;
        var saveButton = toolbar.querySelector("button[type='submit'][aria-label='Save']");
        if (!saveButton) return;
        saveButton.setAttribute("data-form-mode-save", "");

        var editButton = document.createElement("button");
        editButton.type = "button";
        editButton.title = "Edit";
        editButton.setAttribute("aria-label", "Edit form");
        editButton.setAttribute("data-form-mode-control", "edit");
        editButton.className = "legacy-toolbar-edit";
        editButton.innerHTML = '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 20l4.5-1 9-9-3.5-3.5-9 9L4 20z"/><path d="M13.5 6.5l3.5 3.5"/><path d="M15 4l3 3"/></svg>';
        editButton.addEventListener("click", function () {
          setFormBodyLocked(false);
          setToolbarMode(toolbar, true);
        });

        var closeButton = document.createElement("button");
        closeButton.type = "button";
        closeButton.title = "Close Edit";
        closeButton.setAttribute("aria-label", "Close edit mode");
        closeButton.setAttribute("data-form-mode-control", "close-edit");
        closeButton.className = "legacy-toolbar-close-edit";
        closeButton.hidden = true;
        closeButton.innerHTML = '<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg>';
        closeButton.addEventListener("click", function () {
          window.location.reload();
        });

        saveButton.insertAdjacentElement("afterend", closeButton);
        saveButton.insertAdjacentElement("afterend", editButton);
      });
    }

    function setNewRecordToolbarMode() {
      if (existingRecord) return;
      document.querySelectorAll(".legacy-form-toolbar").forEach(function (toolbar) {
        var saveButton = toolbar.querySelector("button[type='submit'][aria-label='Save']");
        var newButton = toolbar.querySelector("[data-form-action='new']");
        if (newButton) {
          newButton.hidden = true;
          newButton.disabled = true;
          newButton.style.display = "none";
          newButton.setAttribute("tabindex", "-1");
        }
        Array.prototype.forEach.call(toolbar.querySelectorAll("button"), function (button) {
          if (button === saveButton || button === newButton) return;
          button.disabled = true;
          button.setAttribute("tabindex", "-1");
        });
        Array.prototype.forEach.call(toolbar.querySelectorAll("a.button"), function (link) {
          setToolbarLinkDisabled(link, true);
        });
      });
    }

    function parseMoney(value) {
      var text = String(value || "").trim();
      var negative = /^\(.*\)$/.test(text);
      var number = parseFloat(text.replace(/[(),%]/g, ""));
      if (negative && Number.isFinite(number)) number = -number;
      return Number.isFinite(number) ? number : 0;
    }

    function formatMoney(value) {
      if (!Number.isFinite(value) || value === 0) return "";
      return value.toFixed(2);
    }

    function formatPercent(value) {
      if (!Number.isFinite(value) || value === 0) return "";
      return (value * 100).toFixed(2) + "%";
    }

    function formatZeroMoney(value) {
      var number = Number.isFinite(value) ? value : parseMoney(value);
      if (!Number.isFinite(number) || number === 0) return "0";
      return number.toFixed(2);
    }

    function formatZeroPercent(value) {
      var number = Number.isFinite(value) ? value : parseMoney(value);
      if (!Number.isFinite(number) || number === 0) return "0";
      return (number * 100).toFixed(2) + "%";
    }

    function formatAccountingZeroMoney(value) {
      var number = Number.isFinite(value) ? value : parseMoney(value);
      if (!Number.isFinite(number) || number === 0) return "0";
      return number < 0 ? "(" + Math.abs(number).toFixed(2) + ")" : number.toFixed(2);
    }

    function formatAccountingZeroPercent(value) {
      var number = Number.isFinite(value) ? value : parseMoney(value);
      if (!Number.isFinite(number) || number === 0) return "0";
      var formatted = Math.abs(number * 100).toFixed(2) + "%";
      return number < 0 ? "(" + formatted + ")" : formatted;
    }

    function cellText(cell) {
      if (!cell) return "";
      if (cell && "value" in cell) return (cell.value || "").trim();
      return (cell.textContent || "").trim();
    }

    function setHidden(row, field, value) {
      var input = row.querySelector("[data-field-input='" + field + "']");
      if (input) input.value = value;
    }

    function findStock(query, field) {
      query = String(query || "").trim().toLowerCase();
      if (!query) return null;
      return purchaseStocks.find(function (stock) {
        return String(stock[field] || "").toLowerCase() === query || String(stock.label || "").toLowerCase() === query;
      }) || purchaseStocks.find(function (stock) {
        return String(stock[field] || "").toLowerCase().indexOf(query) === 0;
      }) || null;
    }

    function findExactStock(query, field) {
      query = String(query || "").trim().toLowerCase();
      if (!query) return null;
      return purchaseStocks.find(function (stock) {
        return String(stock[field] || "").toLowerCase() === query || String(stock.label || "").toLowerCase() === query;
      }) || null;
    }

    function isBlankStockPickerRow(row) {
      if (!row) return true;
      return ["stock_id", "stock_code", "stock_name", "qty", "unit_cost", "amount"].every(function (field) {
        if (field === "stock_id") {
          return !cellText(row.querySelector("[data-field-input='stock_id']"));
        }
        return !cellText(row.querySelector("[data-field='" + field + "']"));
      });
    }

    function clearStockPickerRow(row) {
      if (!row) return;
      row.querySelectorAll(".editable-cell").forEach(function (cell) {
        cell.textContent = "";
      });
      row.querySelectorAll(".cell-combobox").forEach(function (input) {
        input.value = "";
      });
      row.querySelectorAll("input[type='hidden']").forEach(function (input) {
        input.value = "";
      });
    }

    function syncPurchaseDetailRow(row, sourceCell) {
      var stockID = row.querySelector("[data-field-input='stock_id']");
      var codeCell = row.querySelector("[data-field='stock_code']");
      var nameCell = row.querySelector("[data-field='stock_name']");
      var qtyCell = row.querySelector("[data-field='qty']");
      var unitCostCell = row.querySelector("[data-field='unit_cost']");
      var amountCell = row.querySelector("[data-field='amount']");
      var stock = null;
      if (sourceCell && sourceCell.dataset.field === "stock_name") {
        stock = findExactStock(cellText(nameCell), "name");
      } else {
        stock = findExactStock(cellText(codeCell), "code");
      }
      if (stock) {
        codeCell.value = stock.code;
        nameCell.textContent = stock.name;
        if (stockID) stockID.value = stock.id;
      } else {
        if (stockID) stockID.value = "";
        if (!cellText(codeCell) && !cellText(nameCell)) {
          if (stockID) stockID.value = "";
        } else if (sourceCell && sourceCell.dataset.field === "stock_code") {
          nameCell.textContent = "";
        } else if (sourceCell && sourceCell.dataset.field === "stock_name" && !cellText(nameCell)) {
          codeCell.value = "";
        }
      }
      var qty = parseMoney(cellText(qtyCell));
      var unitCost = parseMoney(cellText(unitCostCell));
      if (qty && unitCost && (!cellText(amountCell) || sourceCell === qtyCell || sourceCell === unitCostCell)) {
        amountCell.textContent = formatMoney(qty * unitCost);
      }
      setHidden(row, "qty", cellText(qtyCell));
      setHidden(row, "unit_cost", cellText(unitCostCell));
      setHidden(row, "amount", cellText(amountCell));
      updatePurchaseTotals();
    }

    function syncPurchaseAdjustmentRow(row, sourceCell) {
      var qtyCell = row.querySelector("[data-field='qty']");
      var priceCell = row.querySelector("[data-field='price']");
      var amountCell = row.querySelector("[data-field='amount']");
      var qty = parseMoney(cellText(qtyCell));
      var price = parseMoney(cellText(priceCell));
      if (qty && price && (!cellText(amountCell) || sourceCell === qtyCell || sourceCell === priceCell)) {
        amountCell.textContent = formatMoney(qty * price);
      }
      ["particulars", "qty", "price", "amount"].forEach(function (field) {
        setHidden(row, field, cellText(row.querySelector("[data-field='" + field + "']")));
      });
      updatePurchaseTotals();
      updateSalesTotals();
    }

    function renumberPurchaseDetails() {
      document.querySelectorAll(".purchase-detail-row").forEach(function (row, index) {
        var no = row.querySelector(".row-no");
        if (no) no.textContent = String(index + 1) + ".";
      });
    }

    function sumInputs(selector) {
      return Array.prototype.slice.call(document.querySelectorAll(selector)).reduce(function (total, input) {
        return total + parseMoney(input.value);
      }, 0);
    }

    function updatePurchaseTotals() {
      var detailRows = Array.prototype.slice.call(document.querySelectorAll(".purchase-detail-row"));
      var totalQty = detailRows.reduce(function (total, row) {
        return total + parseMoney(cellText(row.querySelector("[data-field='qty']")));
      }, 0);
      var total = detailRows.reduce(function (sum, row) {
        return sum + parseMoney(cellText(row.querySelector("[data-field='amount']")));
      }, 0);
      var less = sumInputs("input[name='line_discounts_amount']");
      var add = sumInputs("input[name='line_additionals_amount']");
      [
        ["[data-purchase-total-qty]", totalQty],
        ["[data-purchase-total]", total],
        ["[data-purchase-less]", less],
        ["[data-purchase-add]", add],
        ["[data-purchase-net]", total - less + add]
      ].forEach(function (item) {
        var input = document.querySelector(item[0]);
        if (input) input.value = formatMoney(item[1]);
      });
    }

    function hydratePurchaseDetails() {
      document.querySelectorAll(".purchase-detail-row").forEach(function (row) {
        var stockID = (row.querySelector("[data-field-input='stock_id']") || {}).value || "";
        var stock = purchaseStocks.find(function (item) { return item.id === stockID; });
        if (stock) {
          row.querySelector("[data-field='stock_code']").value = stock.code;
          row.querySelector("[data-field='stock_name']").textContent = stock.name;
        }
        syncPurchaseDetailRow(row);
      });
      renumberPurchaseDetails();
      updatePurchaseTotals();
      ensureStockPickerBlankRow("purchase");
    }

    function hydratePurchaseAdjustments() {
      document.querySelectorAll(".purchase-adjustment-row").forEach(function (row) {
        syncPurchaseAdjustmentRow(row);
      });
      updatePurchaseTotals();
    }

    function findPurchaseSupplierByID(id) {
      return purchaseSuppliers.find(function (item) {
        return item.id === String(id || "");
      }) || null;
    }

    function syncPurchaseSupplier() {
      var select = document.querySelector("[data-purchase-party-select]");
      if (!select) return null;
      return findPurchaseSupplierByID(select.value);
    }

    function hydratePurchaseSupplier() {
      var select = document.querySelector("[data-purchase-party-select]");
      if (!select) return;
      if (select.value && !findPurchaseSupplierByID(select.value)) {
        select.value = "";
      }
      select.addEventListener("change", syncPurchaseSupplier);
    }

    var purchaseSupplierPickerState = {
      root: document.querySelector("[data-purchase-supplier-picker]"),
      search: document.querySelector("[data-purchase-supplier-picker-search]"),
      results: document.querySelector("[data-purchase-supplier-picker-results]"),
      empty: document.querySelector("[data-purchase-supplier-picker-empty]"),
      matches: [],
      selectedIndex: -1
    };

    if (purchaseSupplierPickerState.root) {
      purchaseSupplierPickerState.root.classList.add("is-hidden");
      purchaseSupplierPickerState.root.setAttribute("aria-hidden", "true");
    }

    function filterPurchaseSuppliers(query) {
      query = String(query || "").trim().toLowerCase();
      if (!query) return purchaseSuppliers.slice();
      return purchaseSuppliers.filter(function (supplier) {
        return String(supplier.label || "").toLowerCase().indexOf(query) !== -1;
      });
    }

    function highlightPurchaseSupplierPickerRow(index) {
      purchaseSupplierPickerState.selectedIndex = index;
      if (!purchaseSupplierPickerState.results) return;
      Array.prototype.forEach.call(purchaseSupplierPickerState.results.querySelectorAll("tr"), function (row, rowIndex) {
        row.classList.toggle("is-active", rowIndex === index);
        row.tabIndex = rowIndex === index ? 0 : -1;
        row.setAttribute("aria-selected", rowIndex === index ? "true" : "false");
      });
    }

    function focusPurchaseSupplierPickerRow(index) {
