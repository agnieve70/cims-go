        <label class="legacy-record-field">
          <span>Incharge:</span>
          <input name="incharge" value="{{fieldValue $.Record "incharge"}}">
        </label>
        <label class="legacy-record-field">
          <span>APS:</span>
          <input name="aps" value="{{fieldValue $.Record "aps"}}">
