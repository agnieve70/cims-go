    }

    document.querySelectorAll("[data-sales-dr-picker-close]").forEach(function (button) {
      button.addEventListener("click", function () {
        closeSalesDRPicker();
      });
    });

    if (transferDRPickerState.search) {
      transferDRPickerState.search.addEventListener("input", function () {
        renderTransferDRPicker(transferDRPickerState.search.value);
      });
      transferDRPickerState.search.addEventListener("keydown", function (event) {
        if (event.key === "Escape") {
          event.preventDefault();
          closeTransferDRPicker();
          return;
        }
        if (event.key === "Tab") {
          if (!transferDRPickerState.matches.length) return;
          event.preventDefault();
          focusTransferDRPickerRow(0);
          return;
        }
        if (!transferDRPickerState.matches.length) return;
        if (event.key === "ArrowDown") {
          event.preventDefault();
          focusTransferDRPickerRow(Math.min(transferDRPickerState.selectedIndex + 1, transferDRPickerState.matches.length - 1));
          return;
        }
        if (event.key === "ArrowUp") {
          event.preventDefault();
          focusTransferDRPickerRow(Math.max(transferDRPickerState.selectedIndex - 1, 0));
          return;
        }
        if (event.key === "Enter") {
          event.preventDefault();
          applyTransferDRSelection(transferDRPickerState.matches[transferDRPickerState.selectedIndex]);
        }
      });
    }

    if (transferDRPickerState.results) {
      transferDRPickerState.results.addEventListener("click", function (event) {
        var row = event.target.closest && event.target.closest("[data-transfer-dr-option]");
        if (!row) return;
        var index = parseInt(row.getAttribute("data-transfer-dr-index"), 10);
        applyTransferDRSelection(transferDRPickerState.matches[index]);
      });
      transferDRPickerState.results.addEventListener("keydown", function (event) {
        var row = event.target.closest && event.target.closest("[data-transfer-dr-option]");
        if (!row) return;
        event.stopPropagation();
        var index = parseInt(row.getAttribute("data-transfer-dr-index"), 10);
        if (event.key === "Escape") {
          event.preventDefault();
          closeTransferDRPicker();
          return;
        }
        if (event.key === "ArrowDown") {
          event.preventDefault();
          focusTransferDRPickerRow(Math.min(index + 1, transferDRPickerState.matches.length - 1));
          return;
        }
        if (event.key === "ArrowUp") {
          event.preventDefault();
          focusTransferDRPickerRow(Math.max(index - 1, 0));
          return;
        }
        if (event.key === "Enter") {
          event.preventDefault();
          applyTransferDRSelection(transferDRPickerState.matches[index]);
        }
      });
      transferDRPickerState.results.addEventListener("focusin", function (event) {
        var row = event.target.closest && event.target.closest("[data-transfer-dr-option]");
        if (!row) return;
        highlightTransferDRPickerRow(parseInt(row.getAttribute("data-transfer-dr-index"), 10));
      });
      transferDRPickerState.results.addEventListener("mousemove", function (event) {
        var row = event.target.closest && event.target.closest("[data-transfer-dr-option]");
        if (!row) return;
        highlightTransferDRPickerRow(parseInt(row.getAttribute("data-transfer-dr-index"), 10));
      });
    }

    document.querySelectorAll("[data-transfer-dr-picker-close]").forEach(function (button) {
      button.addEventListener("click", function () {
        closeTransferDRPicker();
      });
    });

    if (purchaseStockPickerState.search) {
      purchaseStockPickerState.search.addEventListener("input", function () {
        renderPurchaseStockPicker(purchaseStockPickerState.search.value);
      });
      purchaseStockPickerState.search.addEventListener("keydown", function (event) {
        if (event.key === "Escape") {
          event.preventDefault();
          closePurchaseStockPicker();
          return;
        }
        if (event.key === "Tab") {
          if (!purchaseStockPickerState.matches.length) return;
          event.preventDefault();
          focusPurchaseStockPickerRow(0);
          return;
        }
        if (!purchaseStockPickerState.matches.length) return;
        if (event.key === "ArrowDown") {
          event.preventDefault();
          highlightPurchaseStockPickerRow(Math.min(purchaseStockPickerState.selectedIndex + 1, purchaseStockPickerState.matches.length - 1));
          return;
        }
        if (event.key === "ArrowUp") {
          event.preventDefault();
          highlightPurchaseStockPickerRow(Math.max(purchaseStockPickerState.selectedIndex - 1, 0));
          return;
        }
        if (event.key === "Enter") {
          event.preventDefault();
          applyPurchaseStockSelection(purchaseStockPickerState.matches[purchaseStockPickerState.selectedIndex]);
        }
      });
    }

    if (purchaseStockPickerState.results) {
      purchaseStockPickerState.results.setAttribute("aria-label", "Stock search results");
      purchaseStockPickerState.results.addEventListener("keydown", function (event) {
        var row = event.target.closest && event.target.closest("[data-purchase-stock-option]");
        if (!row) return;
        event.stopPropagation();
        var index = parseInt(row.getAttribute("data-stock-index"), 10);
        if (event.key === "Escape") {
          event.preventDefault();
          closePurchaseStockPicker();
          return;
        }
        if (event.key === "ArrowDown") {
          event.preventDefault();
          focusPurchaseStockPickerRow(Math.min(index + 1, purchaseStockPickerState.matches.length - 1));
          return;
        }
        if (event.key === "ArrowUp") {
          event.preventDefault();
          focusPurchaseStockPickerRow(Math.max(index - 1, 0));
          return;
        }
        if (event.key === "Enter") {
          event.preventDefault();
          applyPurchaseStockSelection(purchaseStockPickerState.matches[index]);
          return;
        }
      });
      purchaseStockPickerState.results.addEventListener("click", function (event) {
        var row = event.target.closest && event.target.closest("[data-purchase-stock-option]");
        if (!row) return;
        var index = parseInt(row.getAttribute("data-stock-index"), 10);
        applyPurchaseStockSelection(purchaseStockPickerState.matches[index]);
      });
      purchaseStockPickerState.results.addEventListener("focusin", function (event) {
        var row = event.target.closest && event.target.closest("[data-purchase-stock-option]");
        if (!row) return;
        highlightPurchaseStockPickerRow(parseInt(row.getAttribute("data-stock-index"), 10));
      });
      purchaseStockPickerState.results.addEventListener("mousemove", function (event) {
        var row = event.target.closest && event.target.closest("[data-purchase-stock-option]");
        if (!row) return;
        highlightPurchaseStockPickerRow(parseInt(row.getAttribute("data-stock-index"), 10));
      });
    }

    if (purchaseStockPickerState.tableWrap) {
      purchaseStockPickerState.tableWrap.addEventListener("keydown", function (event) {
        if (event.key === "Escape") {
          event.preventDefault();
          closePurchaseStockPicker();
          return;
        }
        if (event.key === "Tab" && event.shiftKey) {
          event.preventDefault();
          if (purchaseStockPickerState.search) purchaseStockPickerState.search.focus();
          return;
        }
        if (!purchaseStockPickerState.matches.length) return;
        if (event.key === "ArrowDown") {
          event.preventDefault();
          focusPurchaseStockPickerRow(Math.min(purchaseStockPickerState.selectedIndex + 1, purchaseStockPickerState.matches.length - 1));
          return;
        }
        if (event.key === "ArrowUp") {
          event.preventDefault();
          focusPurchaseStockPickerRow(Math.max(purchaseStockPickerState.selectedIndex - 1, 0));
          return;
        }
        if (event.key === "Enter") {
          event.preventDefault();
          applyPurchaseStockSelection(purchaseStockPickerState.matches[purchaseStockPickerState.selectedIndex]);
        }
      });
    }

    document.querySelectorAll("[data-purchase-stock-picker-close]").forEach(function (button) {
      button.addEventListener("click", function () {
        closePurchaseStockPicker();
      });
    });

    hydratePurchaseDetails();
    hydratePurchaseAdjustments();
    hydratePurchasePaymentRows();
    hydratePurchaseSupplier();
    hydrateDRDetails();
    hydrateDRCustomer();
    hydrateARCreditCompany();
    hydrateAPDebitCompany();
    hydrateAPCreditCompany();
    hydrateARDebitCompany();
    hydrateRebatesCompany();
    hydrateExpenseRows();
    hydrateOtherIncomeRows();
    hydrateChecksInRows();
    hydrateSalesDetails();
    applyLinkedDetailEditsAfterReload();
    updatePurchaseTotals();
    updateSalesTotals();
    setPurchaseTab("adjustments");
    setSalesTab("markup");
    rememberFormModeState();
    createToolbarModeButtons();
    setNewRecordToolbarMode();
    if (existingRecord) {
      setFormBodyLocked(true);
      document.querySelectorAll(".legacy-form-toolbar").forEach(function (toolbar) {
        setToolbarMode(toolbar, false);
      });
    }

    document.querySelectorAll("[data-purchase-tab]").forEach(function (button) {
      button.addEventListener("click", function () {
        setPurchaseTab(button.dataset.purchaseTab);
      });
    });

    document.querySelectorAll("[data-sales-tab]").forEach(function (button) {
      button.addEventListener("click", function () {
        setSalesTab(button.dataset.salesTab);
      });
    });

    if (salesStockEditorState.trigger) {
      salesStockEditorState.trigger.addEventListener("click", openSalesStockEditor);
    }
    if (transferStockEditorState.trigger) {
      transferStockEditorState.trigger.addEventListener("click", openTransferStockEditor);
    }
    if (salesStockEditorState.frame) {
      salesStockEditorState.frame.addEventListener("load", resizeSalesStockEditorFrame);
    }
    if (transferStockEditorState.frame) {
      transferStockEditorState.frame.addEventListener("load", resizeTransferStockEditorFrame);
    }
    window.addEventListener("resize", resizeSalesStockEditorFrame);
    window.addEventListener("resize", resizeTransferStockEditorFrame);

    salesDetailRows().forEach(function (row) {
      row.addEventListener("click", function () {
        selectSalesDetailRow(row);
      });
    });

    document.querySelectorAll("[data-sales-stock-out-editor-close]").forEach(function (button) {
      button.addEventListener("click", closeSalesStockEditor);
    });
    document.querySelectorAll("[data-transfer-stock-out-editor-close]").forEach(function (button) {
      button.addEventListener("click", closeTransferStockEditor);
    });

    window.addEventListener("message", function (event) {
      if (event.origin !== window.location.origin || !event.data || typeof event.data !== "object") return;
      if (event.data.type === "cims-stock-saved") {
        applyUpdatedSalesStock(event.data.stock || {});
        closeSalesStockEditor();
      } else if (event.data.type === "cims-stock-out-saved") {
        saveLinkedDetailEditsForReload();
        closeSalesStockEditor();
        closeTransferStockEditor();
        var selectedDRDocumentID = selectedSalesDRDocumentID() || selectedTransferDRDocumentID();
        var drDocumentID = /^\d+$/.test(String(event.data.id || "")) ? String(event.data.id) : selectedDRDocumentID;
        if (drDocumentID) {
          window.location.replace(window.location.pathname + "?dr_document_id=" + encodeURIComponent(drDocumentID) + "&_=" + Date.now());
        }
      } else if (event.data.type === "cims-embedded-close") {
        closeSalesStockEditor();
        closeTransferStockEditor();
      }
    });

    document.querySelectorAll("[data-embedded-close]").forEach(function (button) {
      button.addEventListener("click", function (event) {
        event.preventDefault();
        closeEmbeddedForm();
      });
    });

    if (embeddedMode && embeddedSaved && formShell) {
      notifyEmbeddedParent({
        type: "cims-record-saved",
        kind: formShell.dataset.formKind || "",
        id: embeddedDocumentNumericID() || "{{fieldValue .Record "id"}}"
      });
    }

    if (embeddedMode && embeddedSaved && formShell && formShell.dataset.formKind === "stocks") {
      var stockCategoryField = document.querySelector("select[name='category_group']");
      var selectedCategory = stockCategoryField && stockCategoryField.selectedOptions && stockCategoryField.selectedOptions[0]
        ? stockCategoryField.selectedOptions[0].textContent.trim()
        : (stockCategoryField ? stockCategoryField.value : "");
      notifyEmbeddedParent({
        type: "cims-stock-saved",
        stock: {
          id: "{{fieldValue .Record "id"}}",
          code: "{{fieldValue .Record "code"}}",
          name: "{{fieldValue .Record "name"}}",
          categoryGroup: "{{fieldValue .Record "category_group"}}",
          categoryLabel: selectedCategory
        }
      });
    }
    if (embeddedMode && embeddedSaved && formShell && formShell.dataset.formKind === "dr") {
      notifyEmbeddedParent({
        type: "cims-stock-out-saved",
        id: embeddedDocumentNumericID()
      });
    }

    document.querySelectorAll("[data-form-action]").forEach(function (button) {
      button.addEventListener("click", function () {
        var action = button.getAttribute("data-form-action");
        if (action === "new") window.location.href = routeBase + "/new";
        if (action === "open-list") window.location.href = routeBase + "/";
      });
    });
  })();
</script>
{{end}}
{{template "foot" .}}
