    function syncARDebitCompany() {
      var input = document.querySelector("input[name='ar_debit_company_name']");
      var hidden = document.querySelector("[data-ar-debit-party-id]");
      if (!input || !hidden) return;
      var query = input.value.trim().toLowerCase();
