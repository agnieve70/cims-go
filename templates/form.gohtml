      });
      hidden.value = customer ? customer.id : "";
      if (customer && input.value !== customer.label) input.value = customer.label;
    }

    function hydrateARDebitCompany() {
      var input = document.querySelector("input[name='ar_debit_company_name']");
      var hidden = document.querySelector("[data-ar-debit-party-id]");
      if (!input || !hidden) return;
      var customer = drCustomers.find(function (item) {
        return item.id === hidden.value;
      });
      if (customer) input.value = customer.label;
      input.addEventListener("input", syncARDebitCompany);
      input.addEventListener("change", syncARDebitCompany);
      input.addEventListener("blur", syncARDebitCompany);
      var form = input.closest("form");
      if (form) form.addEventListener("submit", syncARDebitCompany);
    }

    function syncRebatesCompany() {
      var input = document.querySelector("input[name='rebates_company_name']");
      var hidden = document.querySelector("[data-rebates-party-id]");
      if (!input || !hidden) return;
      var query = input.value.trim().toLowerCase();
      var customer = drCustomers.find(function (item) {
        return item.label.toLowerCase() === query;
      }) || drCustomers.find(function (item) {
        return item.label.toLowerCase().indexOf(query) === 0;
      });
      hidden.value = customer ? customer.id : "";
      if (customer && input.value !== customer.label) input.value = customer.label;
    }

    function hydrateRebatesCompany() {
      var input = document.querySelector("input[name='rebates_company_name']");
      var hidden = document.querySelector("[data-rebates-party-id]");
      if (!input || !hidden) return;
      var customer = drCustomers.find(function (item) {
        return item.id === hidden.value;
      });
      if (customer) input.value = customer.label;
      input.addEventListener("input", syncRebatesCompany);
      input.addEventListener("change", syncRebatesCompany);
      input.addEventListener("blur", syncRebatesCompany);
      var form = input.closest("form");
      if (form) form.addEventListener("submit", syncRebatesCompany);
    }

    function syncSalesDetailRow(row) {
      var qty = parseMoney(cellText(row.querySelector("[data-field='qty']")));
      var unitCost = parseMoney(cellText(row.querySelector("[data-field='unit_cost']")));
      var amountCell = row.querySelector("[data-field='amount']");
      var discount = parseMoney(cellText(row.querySelector("[data-field='discount']")));
      var otherDiscount = parseMoney(cellText(row.querySelector("[data-field='other_discount']")));
      var capitalCell = row.querySelector("[data-field='capital']");
      var capitalInput = row.querySelector("[data-field-input='capital']");
      var capital = parseMoney((capitalInput && capitalInput.value) || cellText(capitalCell));
      var totalCapital = qty && capital ? qty * capital : capital;
      var amount = 0;
      if (amountCell && (qty || unitCost)) {
        amount = qty * unitCost;
        amountCell.textContent = formatMoney(amount);
      } else {
        amount = parseMoney(cellText(amountCell));
      }
      var net = amount - discount - otherDiscount;
      var markup = net - totalCapital;
      var markupPct = totalCapital ? markup / totalCapital : 0;
      var netCell = row.querySelector("[data-field='net_amount']");
      var markupCell = row.querySelector("[data-field='markup']");
      var markupPctCell = row.querySelector("[data-field='markup_pct']");
      if (netCell) netCell.textContent = formatMoney(net);
      if (capitalCell) capitalCell.textContent = formatMoney(totalCapital);
      if (markupCell) markupCell.textContent = formatAccountingZeroMoney(markup);
      if (markupPctCell) markupPctCell.textContent = formatAccountingZeroPercent(markupPct);
      ["stock_label", "qty", "unit_cost", "amount", "capital", "discount", "other_discount", "markup", "markup_pct"].forEach(function (field) {
        if (field === "stock_label") {
          var code = cellText(row.querySelector("[data-field='stock_code']"));
          var name = cellText(row.querySelector("[data-field='stock_name']"));
          setHidden(row, field, name ? code + " - " + name : code);
        } else if (field === "capital") {
          setHidden(row, field, formatMoney(capital));
        } else if (field === "markup") {
          setHidden(row, field, formatZeroMoney(markup));
        } else if (field === "markup_pct") {
          setHidden(row, field, formatZeroMoney(markupPct * 100));
        } else {
          setHidden(row, field, cellText(row.querySelector("[data-field='" + field + "']")));
        }
      });
      var groupInput = row.querySelector("[data-field-input='stock_group']");
      var stockID = (row.querySelector("[data-field-input='stock_id']") || {}).value || "";
      if (groupInput && !groupInput.value) groupInput.value = salesStockGroups[stockID] || "Ungrouped";
    }

    function hydrateSalesDetails() {
      document.querySelectorAll(".sales-detail-row").forEach(function (row, index) {
        var no = row.querySelector(".row-no");
        var label = (row.querySelector("[data-field-input='stock_label']") || {}).value || cellText(row.querySelector("[data-field='stock_code']"));
        var groupInput = row.querySelector("[data-field-input='stock_group']");
        var stockID = (row.querySelector("[data-field-input='stock_id']") || {}).value || "";
        var parts = label.split(" - ");
        var code = (parts.shift() || label).trim();
        var name = parts.join(" - ").trim();
        if (no) no.textContent = String(index + 1) + ".";
        row.querySelector("[data-field='stock_code']").textContent = code;
        row.querySelector("[data-field='stock_name']").textContent = name;
        ["discount", "other_discount"].forEach(function (field) {
          var cell = row.querySelector("[data-field='" + field + "']");
          if (cell && !cellText(cell)) cell.textContent = "0";
        });
        if (groupInput && !groupInput.value) groupInput.value = salesStockGroups[stockID] || "Ungrouped";
        syncSalesDetailRow(row);
      });
      updateSalesTotals();
      ensureSelectedSalesDetailRow();
    }

    function renderSalesMarkupSummary(groups) {
      var tbody = document.querySelector("#sales-markup-summary-rows");
      if (!tbody) return;
      tbody.innerHTML = "";
      Object.keys(groups).sort().forEach(function (groupName, index) {
        var group = groups[groupName];
        var avgMarkup = group.capital ? group.markup / group.capital : 0;
        var tr = document.createElement("tr");
        [String(index + 1) + ".", groupName, formatMoney(group.net), formatMoney(group.capital), formatZeroMoney(group.markup), formatZeroPercent(avgMarkup)].forEach(function (value) {
          var td = document.createElement("td");
          td.textContent = value;
          tr.appendChild(td);
        });
        tbody.appendChild(tr);
      });
    }

    function updateSalesTotals() {
      var rows = Array.prototype.slice.call(document.querySelectorAll(".sales-detail-row"));
      var totalQty = 0;
      var gross = 0;
      var capital = 0;
      var lineDiscount = 0;
      var markup = 0;
      var groups = {};
      rows.forEach(function (row) {
        syncSalesDetailRow(row);
        var groupName = ((row.querySelector("[data-field-input='stock_group']") || {}).value || "Ungrouped").trim() || "Ungrouped";
        if (!groups[groupName]) groups[groupName] = { net: 0, capital: 0, markup: 0 };
        var netAmountCell = row.querySelector("[data-field='net_amount']");
        var rowNet = parseMoney(cellText(netAmountCell || row.querySelector("[data-field='amount']")));
        var rowCapital = parseMoney(cellText(row.querySelector("[data-field='capital']")));
        var rowMarkup = rowNet - rowCapital;
        totalQty += parseMoney(cellText(row.querySelector("[data-field='qty']")));
        gross += parseMoney(cellText(row.querySelector("[data-field='amount']")));
        capital += rowCapital;
        lineDiscount += parseMoney(cellText(row.querySelector("[data-field='discount']"))) + parseMoney(cellText(row.querySelector("[data-field='other_discount']")));
        markup += rowMarkup;
        groups[groupName].net += rowNet;
        groups[groupName].capital += rowCapital;
        groups[groupName].markup += rowMarkup;
      });
      renderSalesMarkupSummary(groups);
      var deductions = sumInputs("input[name='line_deductions_amount']") || sumInputs("input[name='line_discounts_amount']");
      var additionals = sumInputs("input[name='line_additionals_amount']");
      var net = gross - lineDiscount - deductions + additionals;
      var checkTotal = sumInputs("input[name='line_payments_amount']");
      var balance = net - checkTotal;
      [
        ["[data-sales-total-qty]", totalQty],
        ["[data-sales-total-net]", net],
        ["[data-sales-total]", gross],
        ["[data-sales-less-a]", deductions],
        ["[data-sales-less-m]", lineDiscount],
        ["[data-sales-add]", additionals],
        ["[data-sales-net]", net],
        ["[data-sales-check-total]", checkTotal],
        ["[data-sales-balance]", balance]
      ].forEach(function (item) {
        var el = document.querySelector(item[0]);
        if (!el) return;
        if ("value" in el) el.value = formatMoney(item[1]);
        else el.textContent = formatMoney(item[1]);
      });
    }

    function setSalesTab(tab) {
      document.querySelectorAll("[data-sales-tab]").forEach(function (button) {
        button.classList.toggle("is-active", button.dataset.salesTab === tab);
      });
      document.querySelectorAll("[data-sales-panel]").forEach(function (panel) {
        panel.classList.toggle("is-hidden", panel.dataset.salesPanel !== tab);
      });
    }

    function notifyEmbeddedParent(message) {
      if (!embeddedMode || !window.parent || window.parent === window) return;
      window.parent.postMessage(message, window.location.origin);
    }

    function closeEmbeddedForm() {
      if (embeddedMode) {
        notifyEmbeddedParent({ type: "cims-embedded-close", kind: formShell ? formShell.dataset.formKind : "" });
        return;
      }
      window.location.href = routeBase + "/";
    }

    function embeddedDocumentNumericID() {
      var match = window.location.pathname.match(/\/(\d+)\/edit$/);
      return match ? match[1] : "";
    }

    var salesStockEditorState = {
      root: document.querySelector("[data-sales-stock-out-editor]"),
      frame: document.querySelector("[data-sales-stock-out-editor-frame]"),
      trigger: document.querySelector("[data-sales-edit-stock-out]"),
      activeRow: null
    };
    if (salesStockEditorState.root && salesStockEditorState.root.parentElement !== document.body) {
      document.body.appendChild(salesStockEditorState.root);
    }
    var transferStockEditorState = {
      root: document.querySelector("[data-transfer-stock-out-editor]"),
      frame: document.querySelector("[data-transfer-stock-out-editor-frame]"),
      trigger: document.querySelector("[data-transfer-edit-stock-out]")
    };
    if (transferStockEditorState.root && transferStockEditorState.root.parentElement !== document.body) {
      document.body.appendChild(transferStockEditorState.root);
    }

    function salesDetailRows() {
      return Array.prototype.slice.call(document.querySelectorAll(".sales-detail-row"));
    }

    function salesDetailStockID(row) {
      return row && (row.querySelector("[data-field-input='stock_id']") || {}).value || "";
    }

    function selectedSalesDRDocumentID() {
      var select = document.querySelector("[data-sales-dr-select]");
      return select ? select.value : "";
    }

    function selectedTransferDRDocumentID() {
      var select = document.querySelector("[data-transfer-dr-select]");
      return select ? select.value : "";
    }

    function linkedDetailEditStorageKey() {
      return "cims-linked-detail-edits:" + window.location.pathname;
    }

    function linkedDetailEditableValue(row, field) {
      var cell = row.querySelector("[data-field='" + field + "']");
      var hidden = row.querySelector("[data-field-input='" + field + "']");
      return cellText(cell) || (hidden ? hidden.value : "");
    }

    function linkedDetailEditableFields() {
      var fields = ["unit_cost"];
      if (formShell && formShell.dataset.formKind === "sales") {
        fields.push("discount", "other_discount");
      }
      return fields;
    }

    function saveLinkedDetailEditsForReload() {
      if (!window.sessionStorage) return;
      var editableFields = linkedDetailEditableFields();
      var rows = salesDetailRows().map(function (row) {
        var values = {};
        editableFields.forEach(function (field) {
          values[field] = linkedDetailEditableValue(row, field);
        });
        return {
          drLineID: (row.querySelector("[data-field-input='dr_line_id']") || {}).value || "",
          stockID: (row.querySelector("[data-field-input='stock_id']") || {}).value || "",
          stockLabel: (row.querySelector("[data-field-input='stock_label']") || {}).value || "",
          values: values
        };
      }).filter(function (row) {
        return row.drLineID || row.stockID || row.stockLabel;
      });
      try {
        window.sessionStorage.setItem(linkedDetailEditStorageKey(), JSON.stringify(rows));
      } catch (error) {
        // Storage can be unavailable in private contexts; server-side merge still handles saved edits.
      }
    }

    function applyLinkedDetailEditsAfterReload() {
      if (!window.sessionStorage) return;
      var raw = window.sessionStorage.getItem(linkedDetailEditStorageKey());
      if (!raw) return;
      window.sessionStorage.removeItem(linkedDetailEditStorageKey());
      var savedRows = [];
      try {
        savedRows = JSON.parse(raw) || [];
      } catch (error) {
        return;
      }
      var byDRLineID = {};
      var byStockID = {};
      var byStockLabel = {};
      savedRows.forEach(function (row) {
        if (row.drLineID) byDRLineID[row.drLineID] = row;
        if (row.stockID) byStockID[row.stockID] = row;
        if (row.stockLabel) byStockLabel[row.stockLabel] = row;
      });
      salesDetailRows().forEach(function (row) {
        var drLineID = (row.querySelector("[data-field-input='dr_line_id']") || {}).value || "";
        var stockID = (row.querySelector("[data-field-input='stock_id']") || {}).value || "";
        var stockLabel = (row.querySelector("[data-field-input='stock_label']") || {}).value || "";
        var saved = byDRLineID[drLineID] || byStockID[stockID] || byStockLabel[stockLabel];
        if (!saved || !saved.values) return;
        linkedDetailEditableFields().forEach(function (field) {
          var value = saved.values[field];
          if (value === undefined || value === null || value === "") return;
          var cell = row.querySelector("[data-field='" + field + "']");
          if (cell) cell.textContent = value;
          setHidden(row, field, value);
        });
        syncSalesDetailRow(row);
      });
      updateSalesTotals();
    }

    function setSalesEditStockButtonState() {
      if (!salesStockEditorState.trigger) return;
      salesStockEditorState.trigger.disabled = !selectedSalesDRDocumentID();
    }

    function setTransferEditStockButtonState() {
      if (!transferStockEditorState.trigger) return;
      transferStockEditorState.trigger.disabled = !selectedTransferDRDocumentID();
    }

    function selectSalesDetailRow(row) {
      salesStockEditorState.activeRow = row || null;
      salesDetailRows().forEach(function (detailRow) {
        detailRow.classList.toggle("is-selected", detailRow === salesStockEditorState.activeRow);
      });
      setSalesEditStockButtonState();
      setTransferEditStockButtonState();
    }

    function ensureSelectedSalesDetailRow() {
      var rows = salesDetailRows();
      if (!rows.length) {
        selectSalesDetailRow(null);
        return;
      }
      if (salesStockEditorState.activeRow && rows.indexOf(salesStockEditorState.activeRow) !== -1) {
        setSalesEditStockButtonState();
        return;
      }
      var defaultRow = rows.find(function (row) {
        return !!salesDetailStockID(row);
      }) || rows[0];
      selectSalesDetailRow(defaultRow);
    }

    function closeSalesStockEditor() {
      if (!salesStockEditorState.root) return;
      salesStockEditorState.root.classList.add("is-hidden");
      salesStockEditorState.root.setAttribute("aria-hidden", "true");
      if (salesStockEditorState.frame) {
        salesStockEditorState.frame.removeAttribute("src");
      }
      if (salesStockEditorState.trigger) {
        salesStockEditorState.trigger.focus();
      }
    }

    function closeTransferStockEditor() {
      if (!transferStockEditorState.root) return;
      transferStockEditorState.root.classList.add("is-hidden");
      transferStockEditorState.root.setAttribute("aria-hidden", "true");
      if (transferStockEditorState.frame) {
        transferStockEditorState.frame.removeAttribute("src");
      }
      if (transferStockEditorState.trigger) {
        transferStockEditorState.trigger.focus();
      }
    }

    function openSalesStockEditor() {
      var drDocumentID = selectedSalesDRDocumentID();
      if (!drDocumentID || !salesStockEditorState.root || !salesStockEditorState.frame) return;
      salesStockEditorState.root.classList.remove("is-hidden");
      salesStockEditorState.root.setAttribute("aria-hidden", "false");
      salesStockEditorState.frame.src = "/transactions/dr/" + encodeURIComponent(drDocumentID) + "/edit?embedded=1";
    }

    function openTransferStockEditor() {
      var drDocumentID = selectedTransferDRDocumentID();
      if (!drDocumentID || !transferStockEditorState.root || !transferStockEditorState.frame) return;
      transferStockEditorState.root.classList.remove("is-hidden");
      transferStockEditorState.root.setAttribute("aria-hidden", "false");
      transferStockEditorState.frame.src = "/transactions/dr/" + encodeURIComponent(drDocumentID) + "/edit?embedded=1";
    }

    function resizeSalesStockEditorFrame() {
      if (!salesStockEditorState.frame) return;
      try {
        var frameDocument = salesStockEditorState.frame.contentDocument;
        if (!frameDocument || !frameDocument.body) return;
        var contentHeight = Math.max(
          frameDocument.body.scrollHeight,
          frameDocument.documentElement ? frameDocument.documentElement.scrollHeight : 0
        );
        var maxHeight = Math.max(320, window.innerHeight - 110);
        salesStockEditorState.frame.style.height = Math.min(contentHeight, maxHeight) + "px";
      } catch (error) {
        // Same-origin iframe today; keep the CSS fallback if that ever changes.
      }
    }

    function resizeTransferStockEditorFrame() {
      if (!transferStockEditorState.frame) return;
      try {
        var frameDocument = transferStockEditorState.frame.contentDocument;
        if (!frameDocument || !frameDocument.body) return;
        var contentHeight = Math.max(
          frameDocument.body.scrollHeight,
          frameDocument.documentElement ? frameDocument.documentElement.scrollHeight : 0
        );
        var maxHeight = Math.max(320, window.innerHeight - 110);
        transferStockEditorState.frame.style.height = Math.min(contentHeight, maxHeight) + "px";
      } catch (error) {
        // Same-origin iframe today; keep the CSS fallback if that ever changes.
      }
    }

    function upsertSalesStockReference(stock) {
      if (!stock || !stock.id) return;
      var label = [stock.code, stock.name].filter(Boolean).join(" - ");
      var existingStock = purchaseStocks.find(function (item) {
        return item.id === String(stock.id);
      });
      if (existingStock) {
        existingStock.code = stock.code || existingStock.code || "";
        existingStock.name = stock.name || existingStock.name || "";
        existingStock.label = label || existingStock.label || "";
      } else {
        purchaseStocks.push({
          id: String(stock.id),
          code: stock.code || "",
          name: stock.name || "",
          label: label
        });
      }
      salesStockGroups[String(stock.id)] = stock.categoryLabel || stock.categoryGroup || salesStockGroups[String(stock.id)] || "Ungrouped";
    }

    function applyUpdatedSalesStock(stock) {
      if (!stock || !stock.id) return;
      upsertSalesStockReference(stock);
      salesDetailRows().forEach(function (row) {
        if (salesDetailStockID(row) !== String(stock.id)) return;
        var codeCell = row.querySelector("[data-field='stock_code']");
        var nameCell = row.querySelector("[data-field='stock_name']");
        var groupInput = row.querySelector("[data-field-input='stock_group']");
        if (codeCell) codeCell.textContent = stock.code || "";
        if (nameCell) nameCell.textContent = stock.name || "";
        if (groupInput) {
          groupInput.value = stock.categoryLabel || stock.categoryGroup || "Ungrouped";
        }
        setHidden(row, "stock_label", [stock.code, stock.name].filter(Boolean).join(" - "));
        syncSalesDetailRow(row);
      });
      updateSalesTotals();
      setSalesEditStockButtonState();
    }

    function findExpenseCode(query) {
      query = String(query || "").trim().toLowerCase();
      if (!query) return null;
      return expenseCodes.find(function (item) {
        return item.label.toLowerCase() === query;
      }) || expenseCodes.find(function (item) {
        return item.label.toLowerCase().indexOf(query) === 0;
      }) || null;
    }

    function syncExpenseRow(row, sourceCell) {
      var codeInput = row.querySelector("[data-field='code_label']");
      var code = findExpenseCode(cellText(codeInput));
      if (code) {
        codeInput.value = code.label;
        setHidden(row, "code_id", code.id);
      } else if (!cellText(codeInput)) {
        setHidden(row, "code_id", "");
      }
      var cash = parseMoney(cellText(row.querySelector("[data-field='cash']")));
      var check = parseMoney(cellText(row.querySelector("[data-field='check']")));
      var totalCell = row.querySelector("[data-field='total']");
      if ((cash || check) && (!cellText(totalCell) || sourceCell && (sourceCell.dataset.field === "cash" || sourceCell.dataset.field === "check"))) {
        totalCell.textContent = formatMoney(cash + check);
      }
      ["reference", "cash", "check", "total"].forEach(function (field) {
        setHidden(row, field, cellText(row.querySelector("[data-field='" + field + "']")));
      });
    }

    function updateExpenseTotals() {
      var cash = 0;
      var check = 0;
      var total = 0;
      document.querySelectorAll(".expense-detail-row").forEach(function (row) {
        syncExpenseRow(row);
        cash += parseMoney(cellText(row.querySelector("[data-field='cash']")));
        check += parseMoney(cellText(row.querySelector("[data-field='check']")));
        total += parseMoney(cellText(row.querySelector("[data-field='total']")));
      });
      [["[data-expense-cash-total]", cash], ["[data-expense-check-total]", check], ["[data-expense-grand-total]", total]].forEach(function (item) {
        var input = document.querySelector(item[0]);
        if (input) input.value = formatMoney(item[1]);
      });
    }

    function hydrateExpenseRows() {
      document.querySelectorAll(".expense-detail-row").forEach(function (row, index) {
        var no = row.querySelector(".row-no");
        var codeID = (row.querySelector("[data-field-input='code_id']") || {}).value || "";
        var code = expenseCodes.find(function (item) { return item.id === codeID; });
        if (no) no.textContent = String(index + 1) + ".";
        if (code) row.querySelector("[data-field='code_label']").value = code.label;
        syncExpenseRow(row);
      });
      updateExpenseTotals();
    }

    window.addExpenseRow = function (options) {
      options = options || {};
      var tbody = document.querySelector("#rows-details");
      var template = document.querySelector(".expense-detail-row");
      if (!tbody || !template) return;
      var row = template.cloneNode(true);
      row.querySelectorAll(".editable-cell").forEach(function (cell) { cell.textContent = ""; });
      row.querySelectorAll(".cell-combobox").forEach(function (input) { input.value = ""; });
      row.querySelectorAll("input[type='hidden']").forEach(function (input) { input.value = ""; });
      tbody.appendChild(row);
      hydrateExpenseRows();
      var first = row.querySelector(".cell-combobox, .editable-cell");
      if (first && !options.silent) first.focus();
      return row;
    };

    function findOtherIncomeCode(query) {
      query = String(query || "").trim().toLowerCase();
      if (!query) return null;
      return otherIncomeCodes.find(function (item) {
        return item.label.toLowerCase() === query;
      }) || otherIncomeCodes.find(function (item) {
        return item.label.toLowerCase().indexOf(query) === 0;
      }) || null;
    }

    function syncOtherIncomeRow(row, sourceCell) {
      var codeInput = row.querySelector("[data-field='code_label']");
      var code = findOtherIncomeCode(cellText(codeInput));
      if (code) {
        codeInput.value = code.label;
        setHidden(row, "code_id", code.id);
      } else if (!cellText(codeInput)) {
        setHidden(row, "code_id", "");
      }
      var cash = parseMoney(cellText(row.querySelector("[data-field='cash']")));
      var check = parseMoney(cellText(row.querySelector("[data-field='check']")));
      var totalCell = row.querySelector("[data-field='total']");
      if ((cash || check) && (!cellText(totalCell) || sourceCell && (sourceCell.dataset.field === "cash" || sourceCell.dataset.field === "check"))) {
        totalCell.textContent = formatMoney(cash + check);
      }
      ["reference", "cash", "check", "total"].forEach(function (field) {
        setHidden(row, field, cellText(row.querySelector("[data-field='" + field + "']")));
      });
    }

    function updateOtherIncomeTotals() {
      var cash = 0;
      var check = 0;
      var total = 0;
      document.querySelectorAll(".other-income-detail-row").forEach(function (row) {
        syncOtherIncomeRow(row);
        cash += parseMoney(cellText(row.querySelector("[data-field='cash']")));
        check += parseMoney(cellText(row.querySelector("[data-field='check']")));
        total += parseMoney(cellText(row.querySelector("[data-field='total']")));
      });
      [["[data-other-income-cash-total]", cash], ["[data-other-income-check-total]", check], ["[data-other-income-grand-total]", total]].forEach(function (item) {
        var input = document.querySelector(item[0]);
        if (input) input.value = formatMoney(item[1]);
      });
    }

    function hydrateOtherIncomeRows() {
      document.querySelectorAll(".other-income-detail-row").forEach(function (row, index) {
        var no = row.querySelector(".row-no");
        var codeID = (row.querySelector("[data-field-input='code_id']") || {}).value || "";
        var code = otherIncomeCodes.find(function (item) { return item.id === codeID; });
        if (no) no.textContent = String(index + 1) + ".";
        if (code) row.querySelector("[data-field='code_label']").value = code.label;
        syncOtherIncomeRow(row);
      });
      updateOtherIncomeTotals();
    }

    window.addOtherIncomeRow = function (options) {
      options = options || {};
      var tbody = document.querySelector("#rows-details");
      var template = document.querySelector(".other-income-detail-row");
      if (!tbody || !template) return;
      var row = template.cloneNode(true);
      row.querySelectorAll(".editable-cell").forEach(function (cell) { cell.textContent = ""; });
      row.querySelectorAll(".cell-combobox").forEach(function (input) { input.value = ""; });
      row.querySelectorAll("input[type='hidden']").forEach(function (input) { input.value = ""; });
      tbody.appendChild(row);
      hydrateOtherIncomeRows();
      var first = row.querySelector(".cell-combobox, .editable-cell");
      if (first && !options.silent) first.focus();
      return row;
    };

    function syncChecksInRow(row) {
      if (!row) return;
      ["number", "date", "bank_name", "amount", "nature"].forEach(function (field) {
        setHidden(row, field, cellText(row.querySelector("[data-field='" + field + "']")));
      });
    }

    function updateCreditPaymentTotals() {
      var checkTotal = 0;
      document.querySelectorAll(".credit-line-checks .checks-in-detail-row").forEach(function (row) {
        checkTotal += parseMoney(cellText(row.querySelector("[data-field='amount']")));
      });
      var cashInput = document.querySelector(".credit-cash input[name='cash_amount']");
      var cashTotal = cashInput ? parseMoney(cashInput.value) : 0;
      var checkTotalInput = document.querySelector("[data-credit-check-total]");
      var paymentTotalInput = document.querySelector("[data-credit-payment-total]");
      if (checkTotalInput) checkTotalInput.value = formatMoney(checkTotal);
      if (paymentTotalInput) paymentTotalInput.value = formatMoney(cashTotal + checkTotal);
    }

    function syncPurchasePaymentRow(row) {
      if (!row) return;
      ["number", "date", "bank_name", "amount", "nature"].forEach(function (field) {
        setHidden(row, field, cellText(row.querySelector("[data-field='" + field + "']")));
      });
    }

    function hydratePurchasePaymentRows() {
      document.querySelectorAll(".purchase-payment-row").forEach(syncPurchasePaymentRow);
    }

    window.addPurchasePaymentRow = function (options) {
      options = options || {};
      var tbody = document.querySelector("#rows-payments");
      var template = document.querySelector(".purchase-payment-row");
      if (!tbody || !template) return;
      var row = template.cloneNode(true);
      row.querySelectorAll(".editable-cell").forEach(function (cell) { cell.textContent = ""; });
      row.querySelectorAll(".cell-date").forEach(function (input) { input.value = ""; });
      row.querySelectorAll("input[type='hidden']").forEach(function (input) { input.value = ""; });
      tbody.appendChild(row);
      var first = row.querySelector(".editable-cell, .cell-date");
      if (first && !options.silent) first.focus();
      return row;
    };

    function renumberChecksInRows() {
      document.querySelectorAll(".checks-in-detail-row").forEach(function (row, index) {
        var no = row.querySelector(".row-no");
        if (no) no.textContent = String(index + 1) + ".";
      });
    }

    function hydrateChecksInRows() {
      document.querySelectorAll(".checks-in-detail-row").forEach(syncChecksInRow);
      renumberChecksInRows();
      updateCreditPaymentTotals();
    }

    window.addChecksInRow = function (options) {
      options = options || {};
      var tbody = document.querySelector("#rows-checks");
      var template = document.querySelector(".checks-in-detail-row");
      if (!tbody || !template) return;
      var row = template.cloneNode(true);
      row.querySelectorAll(".editable-cell").forEach(function (cell) { cell.textContent = ""; });
      row.querySelectorAll(".cell-date").forEach(function (input) { input.value = ""; });
      row.querySelectorAll("input[type='hidden']").forEach(function (input) { input.value = ""; });
      tbody.appendChild(row);
      renumberChecksInRows();
      updateCreditPaymentTotals();
      var first = row.querySelector(".editable-cell, .cell-date");
      if (first && !options.silent) first.focus();
      return row;
    };

    function setPurchaseTab(tab) {
      document.querySelectorAll("[data-purchase-tab]").forEach(function (button) {
        button.classList.toggle("is-active", button.dataset.purchaseTab === tab);
      });
      var adjustments = document.querySelector(".purchase-summary-grid");
      var payments = document.querySelector(".purchase-line-payments");
      if (adjustments) adjustments.classList.toggle("is-hidden", tab !== "adjustments");
      if (payments) payments.classList.toggle("is-hidden", tab !== "payments");
    }

    function focusEditableGridTarget(target) {
      if (!target) return;
      target.focus();
      if (target.isContentEditable) {
        var selection = window.getSelection && window.getSelection();
        if (selection) {
          var range = document.createRange();
          range.selectNodeContents(target);
          selection.removeAllRanges();
          selection.addRange(range);
        }
        return;
      }
      if (typeof target.select === "function" && target.type !== "date") {
        target.select();
      }
    }

    function getEditableGridTarget(target) {
      var gridTarget = target && target.closest && target.closest(".editable-cell, .cell-combobox, .cell-date");
      if (gridTarget && gridTarget.hasAttribute("data-readonly-cell")) return null;
      return gridTarget;
    }

    function getEditableGridRow(target) {
      if (!target || !target.closest) return null;
      return target.closest("[data-stock-picker-row], .purchase-adjustment-row, .purchase-payment-row, .sales-detail-row, .expense-detail-row, .other-income-detail-row, .checks-in-detail-row");
    }

    function getEditableGridTargets(row) {
      if (!row) return [];
      return Array.prototype.filter.call(row.querySelectorAll(".cell-combobox, .editable-cell, .cell-date"), function (target) {
        return !target.hidden && !target.disabled && !target.hasAttribute("data-readonly-cell") && !target.closest(".hidden-col");
      });
    }

    function getEditableGridRowSelector(row) {
      if (!row) return "";
      if (row.hasAttribute("data-stock-picker-row")) {
        return "[data-stock-picker-row='" + row.getAttribute("data-stock-picker-row") + "']";
      }
      if (row.classList.contains("purchase-adjustment-row")) {
        return ".purchase-adjustment-row[data-adjustment-group='" + row.getAttribute("data-adjustment-group") + "']";
      }
      if (row.classList.contains("purchase-payment-row")) return ".purchase-payment-row";
      if (row.classList.contains("sales-detail-row")) return ".sales-detail-row";
      if (row.classList.contains("expense-detail-row")) return ".expense-detail-row";
      if (row.classList.contains("other-income-detail-row")) return ".other-income-detail-row";
      if (row.classList.contains("checks-in-detail-row")) return ".checks-in-detail-row";
      return "";
    }

    function syncEditableGridRow(row, target) {
      if (!row) return;
      if (row.hasAttribute("data-stock-picker-row")) {
        syncStockPickerRow(row, target);
        return;
      }
      if (row.classList.contains("purchase-adjustment-row")) {
        syncPurchaseAdjustmentRow(row, target);
        return;
      }
      if (row.classList.contains("purchase-payment-row")) {
        syncPurchasePaymentRow(row);
        return;
      }
      if (row.classList.contains("sales-detail-row")) {
        syncSalesDetailRow(row);
        updateSalesTotals();
        return;
      }
      if (row.classList.contains("expense-detail-row")) {
        syncExpenseRow(row, target);
        updateExpenseTotals();
        return;
      }
      if (row.classList.contains("other-income-detail-row")) {
        syncOtherIncomeRow(row, target);
        updateOtherIncomeTotals();
        return;
      }
      if (row.classList.contains("checks-in-detail-row")) {
        syncChecksInRow(row);
      }
    }

    function appendEditableGridRow(row) {
      if (!row) return null;
      if (row.hasAttribute("data-stock-picker-row")) {
        ensureStockPickerBlankRow(row.getAttribute("data-stock-picker-row") || "purchase");
        return null;
      }
      if (row.classList.contains("purchase-adjustment-row")) {
        return window.addPurchaseAdjustmentRow(row.getAttribute("data-adjustment-group"), { silent: true });
      }
      if (row.classList.contains("purchase-payment-row")) {
        return window.addPurchasePaymentRow({ silent: true });
      }
      if (row.classList.contains("expense-detail-row")) {
        return window.addExpenseRow({ silent: true });
      }
      if (row.classList.contains("other-income-detail-row")) {
        return window.addOtherIncomeRow({ silent: true });
      }
      if (row.classList.contains("checks-in-detail-row")) {
        return window.addChecksInRow({ silent: true });
      }
      return null;
    }

    function isDeletableDetailGridRow(row) {
      return !!row && (
        row.hasAttribute("data-stock-picker-row") ||
        row.classList.contains("sales-detail-row") ||
        row.classList.contains("expense-detail-row") ||
        row.classList.contains("other-income-detail-row") ||
        row.classList.contains("checks-in-detail-row")
      );
    }

    function clearEditableGridRow(row) {
      if (!row) return;
      if (row.hasAttribute("data-stock-picker-row")) {
        clearStockPickerRow(row);
        return;
      }
      row.querySelectorAll(".editable-cell").forEach(function (cell) {
        cell.textContent = "";
      });
      row.querySelectorAll(".cell-combobox, .cell-date").forEach(function (input) {
        input.value = "";
      });
      row.querySelectorAll("input[type='hidden']").forEach(function (input) {
        input.value = "";
      });
    }

    function refreshEditableGridAfterDelete(row) {
      if (!row) return;
      if (row.hasAttribute("data-stock-picker-row")) {
        var kind = row.getAttribute("data-stock-picker-row") || "purchase";
        if (kind === "dr") {
          renumberDRDetails();
        } else {
          renumberPurchaseDetails();
          updatePurchaseTotals();
        }
        return;
      }
      if (row.classList.contains("sales-detail-row")) {
        hydrateSalesDetails();
        return;
      }
      if (row.classList.contains("expense-detail-row")) {
        hydrateExpenseRows();
        return;
      }
      if (row.classList.contains("other-income-detail-row")) {
        hydrateOtherIncomeRows();
        return;
      }
      if (row.classList.contains("checks-in-detail-row")) {
        hydrateChecksInRows();
      }
    }

    function deleteEditableDetailGridRow(target) {
      var currentTarget = getEditableGridTarget(target);
      var row = getEditableGridRow(currentTarget);
      if (!currentTarget || !isDeletableDetailGridRow(row)) return false;
      var selector = getEditableGridRowSelector(row);
      var rows = selector ? Array.prototype.slice.call(document.querySelectorAll(selector)) : [row];
      var index = rows.indexOf(row);
      var targetIndex = getEditableGridTargets(row).indexOf(currentTarget);
      var focusRow = rows[index - 1] || rows[index + 1] || row;
      if (rows.length <= 1) {
        clearEditableGridRow(row);
        refreshEditableGridAfterDelete(row);
        focusRow = row;
      } else {
        row.remove();
        refreshEditableGridAfterDelete(row);
      }
      var nextTargets = getEditableGridTargets(focusRow);
      if (nextTargets.length) {
        focusEditableGridTarget(nextTargets[Math.min(Math.max(targetIndex, 0), nextTargets.length - 1)]);
      }
      return true;
    }

    function findNextEditableGridRow(row) {
      var selector = getEditableGridRowSelector(row);
      if (!selector) return null;
      var rows = Array.prototype.slice.call(document.querySelectorAll(selector));
      var index = rows.indexOf(row);
      if (index === -1) return null;
      if (rows[index + 1]) return rows[index + 1];
      var appended = appendEditableGridRow(row);
      if (appended) return appended;
      rows = Array.prototype.slice.call(document.querySelectorAll(selector));
      return rows[index + 1] || null;
    }

    function moveToNextEditableGridTarget(target) {
      var currentTarget = getEditableGridTarget(target);
      var row = getEditableGridRow(currentTarget);
      if (!currentTarget || !row) return false;
      syncEditableGridRow(row, currentTarget);
      if (row.classList.contains("sales-detail-row") && currentTarget.getAttribute("data-field") === "discount") {
        var otherDiscountCell = row.querySelector("[data-field='other_discount']");
        if (otherDiscountCell && !otherDiscountCell.hasAttribute("data-readonly-cell")) {
          focusEditableGridTarget(otherDiscountCell);
          return true;
        }
      }
      var targets = getEditableGridTargets(row);
      var currentIndex = targets.indexOf(currentTarget);
      if (currentIndex === -1) return false;
      if (targets[currentIndex + 1]) {
        focusEditableGridTarget(targets[currentIndex + 1]);
        return true;
      }
      var nextRow = findNextEditableGridRow(row);
      if (!nextRow) return false;
      var nextTargets = getEditableGridTargets(nextRow);
      if (!nextTargets.length) return false;
      focusEditableGridTarget(nextTargets[0]);
      return true;
    }

    window.addPurchaseDetailRow = function (options) {
      options = options || {};
      var tbody = document.querySelector("#rows-details");
      var template = document.querySelector(".purchase-detail-row");
      if (!tbody || !template) return;
      var row = template.cloneNode(true);
      clearStockPickerRow(row);
      tbody.appendChild(row);
      renumberPurchaseDetails();
      updatePurchaseTotals();
      var first = row.querySelector(".cell-combobox, .editable-cell");
      if (first && !options.silent) first.focus();
      return row;
    };

    window.addPurchaseAdjustmentRow = function (group, options) {
      options = options || {};
      var tbody = document.querySelector("#rows-" + group);
      var template = tbody && tbody.querySelector(".purchase-adjustment-row");
      if (!tbody || !template) return;
      var row = template.cloneNode(true);
      row.querySelectorAll(".editable-cell").forEach(function (cell) {
        cell.textContent = "";
      });
      row.querySelectorAll("input[type='hidden']").forEach(function (input) {
        input.value = "";
      });
      tbody.appendChild(row);
      updatePurchaseTotals();
      var first = row.querySelector(".editable-cell");
      if (first && !options.silent) first.focus();
      return row;
    };

    window.addDRDetailRow = function (options) {
      options = options || {};
      var tbody = document.querySelector("#rows-details");
      var template = document.querySelector(".dr-detail-row");
      if (!tbody || !template) return;
      var row = template.cloneNode(true);
      clearStockPickerRow(row);
      tbody.appendChild(row);
      renumberDRDetails();
      var first = row.querySelector(".cell-combobox, .editable-cell");
      if (first && !options.silent) first.focus();
      return row;
    };

    function appendStockPickerRow(kind, options) {
      if (kind === "dr") return window.addDRDetailRow(options);
      return window.addPurchaseDetailRow(options);
    }

    function ensureStockPickerBlankRow(kind) {
      var rows = Array.prototype.slice.call(document.querySelectorAll("[data-stock-picker-row='" + kind + "']"));
      if (!rows.length) return;
      var hasBlankRow = rows.some(isBlankStockPickerRow);
      if (!hasBlankRow) appendStockPickerRow(kind, { silent: true });
    }

    function syncStockPickerRow(row, sourceCell) {
      if (!row) return;
      var kind = row.getAttribute("data-stock-picker-row") || "purchase";
      if (kind === "dr") syncDRDetailRow(row, sourceCell);
      else syncPurchaseDetailRow(row, sourceCell);
      if (!isBlankStockPickerRow(row)) ensureStockPickerBlankRow(kind);
    }

    document.addEventListener("click", function (event) {
      var button = event.target.closest && event.target.closest("[data-purchase-supplier-browse]");
      if (!button) return;
      openPurchaseSupplierPicker();
    });

    document.addEventListener("click", function (event) {
      var button = event.target.closest && event.target.closest("[data-dr-customer-browse]");
      if (!button) return;
      openDRCustomerPicker();
    });

    document.addEventListener("click", function (event) {
      var button = event.target.closest && event.target.closest("[data-sales-dr-browse]");
      if (!button) return;
      openSalesDRPicker();
    });

    document.addEventListener("click", function (event) {
      var button = event.target.closest && event.target.closest("[data-transfer-dr-browse]");
      if (!button) return;
      openTransferDRPicker();
    });

    document.addEventListener("change", function (event) {
      var select = event.target.closest && event.target.closest("[data-sales-dr-select]");
      if (!select) return;
      navigateToSalesDRSelection(select.value);
    });

    document.addEventListener("change", function (event) {
      var select = event.target.closest && event.target.closest("[data-transfer-dr-select]");
      if (!select) return;
      navigateToTransferDRSelection(select.value);
    });

    document.addEventListener("keydown", function (event) {
      var input = event.target.closest && event.target.closest("[data-purchase-stock-trigger]");
      if (!input || event.key !== "Enter") return;
      event.preventDefault();
      openPurchaseStockPicker(input);
    });

    document.addEventListener("keydown", function (event) {
      if (event.key !== "Escape" || event.shiftKey || event.altKey || event.ctrlKey || event.metaKey) return;
      if (!deleteEditableDetailGridRow(event.target)) return;
      event.preventDefault();
      event.stopPropagation();
    });

    document.addEventListener("keydown", function (event) {
      if (event.key !== "Enter" || event.shiftKey || event.altKey || event.ctrlKey || event.metaKey) return;
      var target = getEditableGridTarget(event.target);
      if (!target || target.matches("[data-purchase-stock-trigger]")) return;
      if (!getEditableGridRow(target)) return;
      event.preventDefault();
      moveToNextEditableGridTarget(target);
    });

    document.addEventListener("input", function (event) {
      var stockCell = event.target.closest && event.target.closest("[data-stock-picker-row] .editable-cell, [data-stock-picker-row] .cell-combobox");
      if (stockCell) {
        syncStockPickerRow(stockCell.closest("[data-stock-picker-row]"), stockCell);
        return;
      }
    });

    document.addEventListener("input", function (event) {
      if (event.target.matches("input[name='line_discounts_amount'], input[name='line_additionals_amount']")) {
        updatePurchaseTotals();
      }
      if (event.target.matches("input[name='line_deductions_amount'], input[name='line_additionals_amount']")) {
        updateSalesTotals();
      }
      var adjustmentCell = event.target.closest && event.target.closest(".purchase-adjustment-row .editable-cell");
      if (adjustmentCell) {
        syncPurchaseAdjustmentRow(adjustmentCell.closest(".purchase-adjustment-row"), adjustmentCell);
      }
      var paymentCell = event.target.closest && event.target.closest(".purchase-payment-row .editable-cell, .purchase-payment-row .cell-date");
      if (paymentCell) {
        syncPurchasePaymentRow(paymentCell.closest(".purchase-payment-row"));
        updateSalesTotals();
      }
      var salesCell = event.target.closest && event.target.closest(".sales-detail-row .editable-cell");
      if (salesCell) {
        syncSalesDetailRow(salesCell.closest(".sales-detail-row"));
        updateSalesTotals();
      }
      var expenseCell = event.target.closest && event.target.closest(".expense-detail-row .editable-cell, .expense-detail-row .cell-combobox");
      if (expenseCell) {
        syncExpenseRow(expenseCell.closest(".expense-detail-row"), expenseCell);
        updateExpenseTotals();
      }
      var otherIncomeCell = event.target.closest && event.target.closest(".other-income-detail-row .editable-cell, .other-income-detail-row .cell-combobox");
      if (otherIncomeCell) {
        syncOtherIncomeRow(otherIncomeCell.closest(".other-income-detail-row"), otherIncomeCell);
        updateOtherIncomeTotals();
      }
      var checksInCell = event.target.closest && event.target.closest(".checks-in-detail-row .editable-cell, .checks-in-detail-row .cell-date");
      if (checksInCell) {
        syncChecksInRow(checksInCell.closest(".checks-in-detail-row"));
        updateCreditPaymentTotals();
      }
      if (event.target.matches && event.target.matches(".credit-cash input[name='cash_amount']")) updateCreditPaymentTotals();
    });

    document.addEventListener("blur", function (event) {
      var stockCell = event.target.closest && event.target.closest("[data-stock-picker-row] .editable-cell, [data-stock-picker-row] .cell-combobox");
      if (stockCell) syncStockPickerRow(stockCell.closest("[data-stock-picker-row]"), stockCell);
      var adjustmentCell = event.target.closest && event.target.closest(".purchase-adjustment-row .editable-cell");
      if (adjustmentCell) syncPurchaseAdjustmentRow(adjustmentCell.closest(".purchase-adjustment-row"), adjustmentCell);
      var paymentCell = event.target.closest && event.target.closest(".purchase-payment-row .editable-cell, .purchase-payment-row .cell-date");
      if (paymentCell) {
        syncPurchasePaymentRow(paymentCell.closest(".purchase-payment-row"));
        updateSalesTotals();
      }
      var salesCell = event.target.closest && event.target.closest(".sales-detail-row .editable-cell");
      if (salesCell) {
        syncSalesDetailRow(salesCell.closest(".sales-detail-row"));
        updateSalesTotals();
      }
      var expenseCell = event.target.closest && event.target.closest(".expense-detail-row .editable-cell, .expense-detail-row .cell-combobox");
      if (expenseCell) {
        syncExpenseRow(expenseCell.closest(".expense-detail-row"), expenseCell);
        updateExpenseTotals();
      }
      var otherIncomeCell = event.target.closest && event.target.closest(".other-income-detail-row .editable-cell, .other-income-detail-row .cell-combobox");
      if (otherIncomeCell) {
        syncOtherIncomeRow(otherIncomeCell.closest(".other-income-detail-row"), otherIncomeCell);
        updateOtherIncomeTotals();
      }
      var checksInCell = event.target.closest && event.target.closest(".checks-in-detail-row .editable-cell, .checks-in-detail-row .cell-date");
      if (checksInCell) {
        syncChecksInRow(checksInCell.closest(".checks-in-detail-row"));
        updateCreditPaymentTotals();
      }
      if (event.target.matches && event.target.matches(".credit-cash input[name='cash_amount']")) updateCreditPaymentTotals();
    }, true);

    if (purchaseSupplierPickerState.search) {
      purchaseSupplierPickerState.search.addEventListener("input", function () {
        renderPurchaseSupplierPicker(purchaseSupplierPickerState.search.value);
      });
      purchaseSupplierPickerState.search.addEventListener("keydown", function (event) {
        if (event.key === "Escape") {
          event.preventDefault();
          closePurchaseSupplierPicker();
          return;
        }
        if (event.key === "Tab") {
          if (!purchaseSupplierPickerState.matches.length) return;
          event.preventDefault();
          focusPurchaseSupplierPickerRow(0);
          return;
        }
        if (!purchaseSupplierPickerState.matches.length) return;
        if (event.key === "ArrowDown") {
          event.preventDefault();
          focusPurchaseSupplierPickerRow(Math.min(purchaseSupplierPickerState.selectedIndex + 1, purchaseSupplierPickerState.matches.length - 1));
          return;
        }
        if (event.key === "ArrowUp") {
          event.preventDefault();
          focusPurchaseSupplierPickerRow(Math.max(purchaseSupplierPickerState.selectedIndex - 1, 0));
          return;
        }
        if (event.key === "Enter") {
          event.preventDefault();
          applyPurchaseSupplierSelection(purchaseSupplierPickerState.matches[purchaseSupplierPickerState.selectedIndex]);
        }
      });
    }

    if (purchaseSupplierPickerState.results) {
      purchaseSupplierPickerState.results.addEventListener("click", function (event) {
        var row = event.target.closest && event.target.closest("[data-purchase-supplier-option]");
        if (!row) return;
        var index = parseInt(row.getAttribute("data-supplier-index"), 10);
        applyPurchaseSupplierSelection(purchaseSupplierPickerState.matches[index]);
      });
      purchaseSupplierPickerState.results.addEventListener("keydown", function (event) {
        var row = event.target.closest && event.target.closest("[data-purchase-supplier-option]");
        if (!row) return;
        event.stopPropagation();
        var index = parseInt(row.getAttribute("data-supplier-index"), 10);
        if (event.key === "Escape") {
          event.preventDefault();
          closePurchaseSupplierPicker();
          return;
        }
