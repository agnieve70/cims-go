{{template "head" .}}
{{if not .Embedded}}
{{template "topbar" .}}
{{end}}
{{define "direct_adjustment_row"}}
<tr class="purchase-adjustment-row" data-adjustment-group="{{.LineGroup.Key}}">
  <td class="editable-cell" contenteditable="true" data-field="particulars">{{fieldValue .Record "particulars"}}</td>
  <td class="editable-cell number-cell" contenteditable="true" data-field="qty">{{fieldValue .Record "qty"}}</td>
  <td class="editable-cell number-cell" contenteditable="true" data-field="price">{{fieldValue .Record "price"}}</td>
  <td class="editable-cell number-cell calculated-cell" contenteditable="false" data-readonly-cell data-field="amount">{{fieldValue .Record "amount"}}</td>
  <td class="hidden-col">
    <input type="hidden" name="{{lineName .LineGroup.Key "particulars"}}" data-field-input="particulars" value="{{fieldValue .Record "particulars"}}">
    <input type="hidden" name="{{lineName .LineGroup.Key "qty"}}" data-field-input="qty" value="{{fieldValue .Record "qty"}}">
    <input type="hidden" name="{{lineName .LineGroup.Key "price"}}" data-field-input="price" value="{{fieldValue .Record "price"}}">
    <input type="hidden" name="{{lineName .LineGroup.Key "amount"}}" data-field-input="amount" value="{{fieldValue .Record "amount"}}">
  </td>
</tr>
{{end}}
{{define "direct_payment_row"}}
<tr class="purchase-payment-row">
  <td class="editable-cell" contenteditable="true" data-field="number">{{fieldValue .Record "number"}}</td>
  <td><input class="cell-date" type="date" data-field="date" value="{{fieldValue .Record "date"}}"></td>
  <td class="editable-cell" contenteditable="true" data-field="bank_name">{{fieldValue .Record "bank_name"}}</td>
  <td class="editable-cell number-cell" contenteditable="true" data-field="amount">{{fieldValue .Record "amount"}}</td>
  <td class="editable-cell" contenteditable="true" data-field="nature">{{fieldValue .Record "nature"}}</td>
  <td class="hidden-col">
    <input type="hidden" name="{{lineName .LineGroup.Key "number"}}" data-field-input="number" value="{{fieldValue .Record "number"}}">
    <input type="hidden" name="{{lineName .LineGroup.Key "date"}}" data-field-input="date" value="{{fieldValue .Record "date"}}">
    <input type="hidden" name="{{lineName .LineGroup.Key "bank_name"}}" data-field-input="bank_name" value="{{fieldValue .Record "bank_name"}}">
    <input type="hidden" name="{{lineName .LineGroup.Key "amount"}}" data-field-input="amount" value="{{fieldValue .Record "amount"}}">
    <input type="hidden" name="{{lineName .LineGroup.Key "nature"}}" data-field-input="nature" value="{{fieldValue .Record "nature"}}">
  </td>
</tr>
{{end}}
{{define "direct_checks_row"}}
<tr class="checks-in-detail-row">
  <td class="row-no"></td>
  <td class="editable-cell" contenteditable="true" data-field="number">{{fieldValue .Record "number"}}</td>
  <td><input class="cell-date" type="date" data-field="date" value="{{fieldValue .Record "date"}}"></td>
  <td class="editable-cell" contenteditable="true" data-field="bank_name">{{fieldValue .Record "bank_name"}}</td>
  <td class="editable-cell number-cell" contenteditable="true" data-field="amount">{{fieldValue .Record "amount"}}</td>
  <td class="editable-cell" contenteditable="true" data-field="nature">{{fieldValue .Record "nature"}}</td>
  <td class="hidden-col">
    <input type="hidden" name="{{lineName .LineGroup.Key "number"}}" data-field-input="number" value="{{fieldValue .Record "number"}}">
    <input type="hidden" name="{{lineName .LineGroup.Key "date"}}" data-field-input="date" value="{{fieldValue .Record "date"}}">
    <input type="hidden" name="{{lineName .LineGroup.Key "bank_name"}}" data-field-input="bank_name" value="{{fieldValue .Record "bank_name"}}">
    <input type="hidden" name="{{lineName .LineGroup.Key "amount"}}" data-field-input="amount" value="{{fieldValue .Record "amount"}}">
    <input type="hidden" name="{{lineName .LineGroup.Key "nature"}}" data-field-input="nature" value="{{fieldValue .Record "nature"}}">
  </td>
</tr>
{{end}}
<main class="page form-page{{if .Embedded}} form-page-embedded{{end}}">
  <form method="post" action="{{.Action}}" class="form-shell modal-form{{if .Embedded}} modal-form-embedded{{end}}" data-existing-record="{{if .CanDelete}}true{{else}}false{{end}}" data-form-kind="{{.Form.Kind}}" data-embedded="{{if .Embedded}}true{{else}}false{{end}}" data-embedded-saved="{{if .EmbeddedSaved}}true{{else}}false{{end}}">
    <div class="modal-titlebar">
      <div class="modal-title">
        <span class="modal-icon" aria-hidden="true"></span>
        <strong>{{.Form.Title}}</strong>
      </div>
      <a class="modal-close" href="{{if .Embedded}}#{{else}}{{.Form.RouteBase}}/{{end}}" aria-label="Close" {{if .Embedded}}data-embedded-close{{end}}>×</a>
    </div>
    <div class="modal-body">
      {{if .Error}}<div class="alert">{{.Error}}</div>{{end}}
      {{if eq .Form.Kind "purchases"}}
      <section class="purchase-legacy-form">
        <label class="purchase-field purchase-entry-id">
          <span>Entry ID:</span>
          <input value="{{fieldValue $.Record "id"}}" readonly>
        </label>
        <label class="purchase-field purchase-updated-by">
          <span>Last Update By:</span>
          <input value="{{fieldValue $.Record "updated_by"}}" readonly tabindex="-1" aria-readonly="true">
        </label>
        <label class="purchase-field purchase-entry-date">
          <span>Entry Date:</span>
          <input name="entry_date" type="date" value="{{fieldValue $.Record "entry_date"}}" required>
        </label>
        <label class="purchase-field purchase-cash">
          <span class="purchase-checkbox-copy">
            <input type="checkbox" name="cash" {{if truthy (fieldValue $.Record "cash")}}checked{{end}}>
            <span>Cash</span>
          </span>
        </label>
        <label class="purchase-field purchase-or-ci">
          <span>OR/CI Number:</span>
          <input name="or_ci_number" value="{{fieldValue $.Record "or_ci_number"}}">
        </label>
        <label class="purchase-field purchase-supplier">
          <span>Supplier:</span>
          <span class="purchase-supplier-control">
            <select name="party_id" data-purchase-party-select required>
              <option value="">Select supplier</option>
              {{range index $.Options "suppliers"}}
                <option value="{{.Value}}" {{if eq (fieldValue $.Record "party_id") .Value}}selected{{end}}>{{.Label}}</option>
              {{end}}
            </select>
            <button type="button" class="purchase-supplier-browse" data-purchase-supplier-browse>Browse</button>
          </span>
        </label>
        <label class="purchase-field purchase-date">
          <span>Purchase Date:</span>
          <input name="purchase_date" type="date" value="{{fieldValue $.Record "purchase_date"}}">
        </label>
      </section>
      <div class="purchase-supplier-picker is-hidden" data-purchase-supplier-picker aria-hidden="true">
        <div class="purchase-supplier-picker-backdrop" data-purchase-supplier-picker-close></div>
        <div class="purchase-supplier-picker-dialog" role="dialog" aria-modal="true" aria-labelledby="purchase-supplier-picker-title">
          <div class="purchase-supplier-picker-titlebar">
            <h3 id="purchase-supplier-picker-title">Supplier List</h3>
            <button type="button" class="purchase-supplier-picker-close" data-purchase-supplier-picker-close aria-label="Close">×</button>
          </div>
          <div class="purchase-supplier-picker-body">
            <label class="purchase-supplier-picker-search">
              <span>Search:</span>
              <input type="search" data-purchase-supplier-picker-search placeholder="Type supplier name">
            </label>
            <div class="purchase-supplier-picker-table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Supplier</th>
                  </tr>
                </thead>
                <tbody data-purchase-supplier-picker-results></tbody>
              </table>
              <p class="purchase-supplier-picker-empty is-hidden" data-purchase-supplier-picker-empty>No matching supplier found.</p>
            </div>
          </div>
        </div>
      </div>

      {{$detailsGroup := index .Form.LineGroups 0}}
      <section class="line-section modal-line-section purchase-line-section purchase-line-details">
        <div class="section-head">
          <h2>{{$detailsGroup.Label}}</h2>
        </div>
        <div class="table-wrap modal-table">
          <table class="editable-grid purchase-details-grid">
            <thead>
              <tr>
                <th>No.</th>
                <th>Stock Code</th>
                <th>Stock Name</th>
                <th>Qty</th>
                <th>Unit Cost</th>
                <th>Amount</th>
              </tr>
            </thead>
            <tbody id="rows-details">
              {{$rows := index $.LineRows "details"}}
              {{if $rows}}
                {{range $rows}}
                <tr class="purchase-detail-row" data-stock-picker-row="purchase">
                  <td class="row-no"></td>
                  <td class="stock-code-cell"><input class="cell-combobox" data-field="stock_code" data-purchase-stock-trigger autocomplete="off" placeholder="Press Enter"></td>
                  <td class="editable-cell stock-name-cell" contenteditable="true" data-field="stock_name"></td>
                  <td class="editable-cell number-cell" contenteditable="true" data-field="qty">{{fieldValue . "qty"}}</td>
                  <td class="editable-cell number-cell" contenteditable="true" data-field="unit_cost">{{fieldValue . "unit_cost"}}</td>
                  <td class="editable-cell number-cell calculated-cell" contenteditable="false" data-readonly-cell data-field="amount">{{fieldValue . "amount"}}</td>
                  <td class="hidden-col">
                    <input type="hidden" name="line_details_stock_id" data-field-input="stock_id" value="{{fieldValue . "stock_id"}}">
                    <input type="hidden" name="line_details_qty" value="{{fieldValue . "qty"}}" readonly data-field-input="qty">
                    <input type="hidden" name="line_details_unit_cost" data-field-input="unit_cost" value="{{fieldValue . "unit_cost"}}">
                    <input type="hidden" name="line_details_amount" data-field-input="amount" value="{{fieldValue . "amount"}}">
                  </td>
                </tr>
                {{end}}
              {{else}}
                <tr class="purchase-detail-row" data-stock-picker-row="purchase">
                  <td class="row-no"></td>
                  <td class="stock-code-cell"><input class="cell-combobox" data-field="stock_code" data-purchase-stock-trigger autocomplete="off" placeholder="Press Enter"></td>
                  <td class="editable-cell stock-name-cell" contenteditable="true" data-field="stock_name"></td>
                  <td class="editable-cell number-cell" contenteditable="true" data-field="qty"></td>
                  <td class="editable-cell number-cell" contenteditable="true" data-field="unit_cost"></td>
                  <td class="editable-cell number-cell calculated-cell" contenteditable="false" data-readonly-cell data-field="amount"></td>
                  <td class="hidden-col">
                    <input type="hidden" name="line_details_stock_id" data-field-input="stock_id">
                    <input type="hidden" name="line_details_qty" data-field-input="qty">
                    <input type="hidden" name="line_details_unit_cost" data-field-input="unit_cost">
                    <input type="hidden" name="line_details_amount" data-field-input="amount">
                  </td>
                </tr>
              {{end}}
            </tbody>
          </table>
        </div>
        <div class="purchase-stock-picker is-hidden" data-purchase-stock-picker aria-hidden="true">
          <div class="purchase-stock-picker-backdrop" data-purchase-stock-picker-close></div>
          <div class="purchase-stock-picker-dialog" role="dialog" aria-modal="true" aria-labelledby="purchase-stock-picker-title">
            <div class="purchase-stock-picker-titlebar">
              <h3 id="purchase-stock-picker-title">Stock List</h3>
              <button type="button" class="purchase-stock-picker-close" data-purchase-stock-picker-close aria-label="Close">×</button>
            </div>
            <div class="purchase-stock-picker-body">
              <label class="purchase-stock-picker-search">
                <span>Search:</span>
                <input type="search" data-purchase-stock-picker-search placeholder="Type stock code or stock name">
              </label>
              <div class="purchase-stock-picker-table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>Stock Code</th>
                      <th>Stock Name</th>
                    </tr>
                  </thead>
                  <tbody data-purchase-stock-picker-results></tbody>
                </table>
                <p class="purchase-stock-picker-empty is-hidden" data-purchase-stock-picker-empty>No matching stock found.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      {{$discountGroup := index .Form.LineGroups 1}}
      {{$additionalGroup := index .Form.LineGroups 2}}
      {{$paymentGroup := index .Form.LineGroups 3}}
      <section class="purchase-summary">
        <div class="purchase-summary-tabs">
          <button type="button" class="purchase-tab is-active" data-purchase-tab="adjustments">Discounts/Additionals/Totals</button>
          <button type="button" class="purchase-tab" data-purchase-tab="payments">Mode Of Payment</button>
          <label>Total Qty:<input readonly data-purchase-total-qty></label>
        </div>
        <div class="purchase-summary-grid">
          <section class="purchase-adjustment purchase-discounts">
            <div class="section-head">
              <h2>{{$discountGroup.Label}}</h2>
            </div>
            <div class="table-wrap modal-table">
              <table class="editable-grid purchase-adjustment-grid">
                <thead>
                  <tr><th>Particulars</th><th>Qty</th><th>Price</th><th>Amount</th></tr>
                </thead>
                <tbody id="rows-{{$discountGroup.Key}}">
                  {{$rows := index $.LineRows $discountGroup.Key}}
                  {{if $rows}}
                    {{range $rows}}
                    <tr class="purchase-adjustment-row" data-adjustment-group="discounts">
                      <td class="editable-cell" contenteditable="true" data-field="particulars">{{fieldValue . "particulars"}}</td>
                      <td class="editable-cell number-cell" contenteditable="true" data-field="qty">{{fieldValue . "qty"}}</td>
                      <td class="editable-cell number-cell" contenteditable="true" data-field="price">{{fieldValue . "price"}}</td>
                      <td class="editable-cell number-cell calculated-cell" contenteditable="false" data-readonly-cell data-field="amount">{{fieldValue . "amount"}}</td>
                      <td class="hidden-col">
                        <input type="hidden" name="line_discounts_particulars" data-field-input="particulars" value="{{fieldValue . "particulars"}}">
                        <input type="hidden" name="line_discounts_qty" data-field-input="qty" value="{{fieldValue . "qty"}}">
                        <input type="hidden" name="line_discounts_price" data-field-input="price" value="{{fieldValue . "price"}}">
                        <input type="hidden" name="line_discounts_amount" data-field-input="amount" value="{{fieldValue . "amount"}}">
                      </td>
                    </tr>
                    {{end}}
                  {{else}}
                    <tr class="purchase-adjustment-row" data-adjustment-group="discounts">
                      <td class="editable-cell" contenteditable="true" data-field="particulars"></td>
                      <td class="editable-cell number-cell" contenteditable="true" data-field="qty"></td>
                      <td class="editable-cell number-cell" contenteditable="true" data-field="price"></td>
                      <td class="editable-cell number-cell calculated-cell" contenteditable="false" data-readonly-cell data-field="amount"></td>
                      <td class="hidden-col">
                        <input type="hidden" name="line_discounts_particulars" data-field-input="particulars">
                        <input type="hidden" name="line_discounts_qty" data-field-input="qty">
                        <input type="hidden" name="line_discounts_price" data-field-input="price">
                        <input type="hidden" name="line_discounts_amount" data-field-input="amount">
                      </td>
                    </tr>
                  {{end}}
                </tbody>
              </table>
            </div>
          </section>
          <section class="purchase-adjustment purchase-additionals">
            <div class="section-head">
              <h2>{{$additionalGroup.Label}}</h2>
            </div>
            <div class="table-wrap modal-table">
              <table class="editable-grid purchase-adjustment-grid">
                <thead>
                  <tr><th>Particulars</th><th>Qty</th><th>Price</th><th>Amount</th></tr>
                </thead>
                <tbody id="rows-{{$additionalGroup.Key}}">
                  {{$rows := index $.LineRows $additionalGroup.Key}}
                  {{if $rows}}
                    {{range $rows}}
                    <tr class="purchase-adjustment-row" data-adjustment-group="additionals">
                      <td class="editable-cell" contenteditable="true" data-field="particulars">{{fieldValue . "particulars"}}</td>
                      <td class="editable-cell number-cell" contenteditable="true" data-field="qty">{{fieldValue . "qty"}}</td>
                      <td class="editable-cell number-cell" contenteditable="true" data-field="price">{{fieldValue . "price"}}</td>
                      <td class="editable-cell number-cell calculated-cell" contenteditable="false" data-readonly-cell data-field="amount">{{fieldValue . "amount"}}</td>
                      <td class="hidden-col">
                        <input type="hidden" name="line_additionals_particulars" data-field-input="particulars" value="{{fieldValue . "particulars"}}">
                        <input type="hidden" name="line_additionals_qty" data-field-input="qty" value="{{fieldValue . "qty"}}">
                        <input type="hidden" name="line_additionals_price" data-field-input="price" value="{{fieldValue . "price"}}">
                        <input type="hidden" name="line_additionals_amount" data-field-input="amount" value="{{fieldValue . "amount"}}">
                      </td>
                    </tr>
                    {{end}}
                  {{else}}
                    <tr class="purchase-adjustment-row" data-adjustment-group="additionals">
                      <td class="editable-cell" contenteditable="true" data-field="particulars"></td>
                      <td class="editable-cell number-cell" contenteditable="true" data-field="qty"></td>
                      <td class="editable-cell number-cell" contenteditable="true" data-field="price"></td>
                      <td class="editable-cell number-cell calculated-cell" contenteditable="false" data-readonly-cell data-field="amount"></td>
                      <td class="hidden-col">
                        <input type="hidden" name="line_additionals_particulars" data-field-input="particulars">
                        <input type="hidden" name="line_additionals_qty" data-field-input="qty">
                        <input type="hidden" name="line_additionals_price" data-field-input="price">
                        <input type="hidden" name="line_additionals_amount" data-field-input="amount">
                      </td>
                    </tr>
                  {{end}}
                </tbody>
              </table>
            </div>
          </section>
          <section class="purchase-totals">
            <label>Total:<input readonly data-purchase-total></label>
            <label>Less:<input readonly data-purchase-less></label>
            <label>Add:<input readonly data-purchase-add></label>
            <label>Net:<input readonly data-purchase-net></label>
          </section>
        </div>
      </section>

      <section class="line-section modal-line-section purchase-line-section purchase-line-payments">
        <div class="section-head">
          <h2>{{$paymentGroup.Label}}</h2>
        </div>
        <div class="table-wrap modal-table">
          <table class="editable-grid purchase-payment-grid">
            <thead>
              <tr><th>Number</th><th>Date</th><th>Bank Name</th><th>Amount</th><th>Nature</th></tr>
            </thead>
            <tbody id="rows-{{$paymentGroup.Key}}">
              {{$rows := index $.LineRows $paymentGroup.Key}}
              {{if $rows}}
                {{range $rows}}
                  <tr class="purchase-payment-row">
                    <td class="editable-cell" contenteditable="true" data-field="number">{{fieldValue . "number"}}</td>
                    <td><input class="cell-date" type="date" data-field="date" value="{{fieldValue . "date"}}"></td>
                    <td class="editable-cell" contenteditable="true" data-field="bank_name">{{fieldValue . "bank_name"}}</td>
                    <td class="editable-cell number-cell" contenteditable="true" data-field="amount">{{fieldValue . "amount"}}</td>
                    <td class="editable-cell" contenteditable="true" data-field="nature">{{fieldValue . "nature"}}</td>
                    <td class="hidden-col">
                      <input type="hidden" name="line_payments_number" data-field-input="number" value="{{fieldValue . "number"}}">
                      <input type="hidden" name="line_payments_date" data-field-input="date" value="{{fieldValue . "date"}}">
                      <input type="hidden" name="line_payments_bank_name" data-field-input="bank_name" value="{{fieldValue . "bank_name"}}">
                      <input type="hidden" name="line_payments_amount" data-field-input="amount" value="{{fieldValue . "amount"}}">
                      <input type="hidden" name="line_payments_nature" data-field-input="nature" value="{{fieldValue . "nature"}}">
                    </td>
                  </tr>
                {{end}}
              {{else}}
                <tr class="purchase-payment-row">
                  <td class="editable-cell" contenteditable="true" data-field="number"></td>
                  <td><input class="cell-date" type="date" data-field="date"></td>
                  <td class="editable-cell" contenteditable="true" data-field="bank_name"></td>
                  <td class="editable-cell number-cell" contenteditable="true" data-field="amount"></td>
                  <td class="editable-cell" contenteditable="true" data-field="nature"></td>
                  <td class="hidden-col">
                    <input type="hidden" name="line_payments_number" data-field-input="number">
                    <input type="hidden" name="line_payments_date" data-field-input="date">
                    <input type="hidden" name="line_payments_bank_name" data-field-input="bank_name">
                    <input type="hidden" name="line_payments_amount" data-field-input="amount">
                    <input type="hidden" name="line_payments_nature" data-field-input="nature">
                  </td>
                </tr>
              {{end}}
            </tbody>
          </table>
        </div>
      </section>
      {{else if eq .Form.Kind "sales"}}
      <section class="sales-legacy-form">
        <label class="sales-field sales-entry-id">
          <span>Entry ID:</span>
          <input value="{{fieldValue $.Record "id"}}" readonly>
        </label>
        <input type="hidden" name="party_id" value="{{fieldValue $.Record "party_id"}}">
        <label class="sales-field sales-entry-date">
          <span>Entry Date:</span>
          <input name="entry_date" type="date" value="{{fieldValue $.Record "entry_date"}}" required>
        </label>
        <label class="sales-field sales-dr-file">
          <span>SO Number:</span>
          <span class="purchase-supplier-control">
            <select name="dr_document_id" required data-sales-dr-select>
              <option value="">Select SO Number</option>
              {{$currentDR := fieldValue $.Record "dr_document_id"}}
              {{$currentDRLabel := fieldValue $.Record "dr_document_label"}}
              {{if and $currentDR $currentDRLabel}}<option value="{{$currentDR}}" selected>{{$currentDRLabel}}</option>{{end}}
              {{range index $.Options "dr_documents"}}
                {{if and $currentDRLabel (eq .Value $currentDR)}}{{else}}<option value="{{.Value}}" {{if eq .Value $currentDR}}selected{{end}}>{{.Label}}</option>{{end}}
              {{end}}
            </select>
            <button type="button" class="purchase-supplier-browse" data-sales-dr-browse>Browse</button>
          </span>
        </label>
        <label class="sales-field sales-sales-date">
          <span>Sales Date:</span>
          <input name="sales_date" type="date" value="{{fieldValue $.Record "sales_date"}}">
        </label>
        <label class="sales-field sales-cash">
          <span class="purchase-checkbox-copy">
            <input type="checkbox" name="cash" {{if truthy (fieldValue $.Record "cash")}}checked{{end}}>
            <span>Cash</span>
          </span>
        </label>
        <label class="sales-field sales-or-ci">
          <span>OR/CI Number:</span>
          <input name="or_ci_number" value="{{fieldValue $.Record "or_ci_number"}}">
        </label>
        <label class="sales-field sales-updated-by">
          <span>Last Update By:</span>
          <input value="{{fieldValue $.Record "updated_by"}}" readonly tabindex="-1" aria-readonly="true">
        </label>
        <label class="sales-field sales-remarks">
          <span>Remarks:</span>
          <textarea name="remarks" rows="2">{{fieldValue $.Record "remarks"}}</textarea>
        </label>
      </section>
      <div class="purchase-supplier-picker is-hidden" data-sales-dr-picker aria-hidden="true">
        <div class="purchase-supplier-picker-backdrop" data-sales-dr-picker-close></div>
        <div class="purchase-supplier-picker-dialog" role="dialog" aria-modal="true" aria-labelledby="sales-dr-picker-title">
          <div class="purchase-supplier-picker-titlebar">
            <h3 id="sales-dr-picker-title">SO Number List</h3>
            <button type="button" class="purchase-supplier-picker-close" data-sales-dr-picker-close aria-label="Close">×</button>
          </div>
          <div class="purchase-supplier-picker-body">
            <label class="purchase-supplier-picker-search">
              <span>Search:</span>
              <input type="search" data-sales-dr-picker-search placeholder="Type SO number or customer name">
            </label>
            <div class="purchase-supplier-picker-table-wrap">
              <table>
                <thead><tr><th>SO Number</th><th>Customer</th></tr></thead>
                <tbody data-sales-dr-picker-results></tbody>
              </table>
              <p class="purchase-supplier-picker-empty is-hidden" data-sales-dr-picker-empty>No matching SO number found.</p>
            </div>
          </div>
        </div>
      </div>

      {{$salesDetailsGroup := index .Form.LineGroups 0}}
      <section class="line-section modal-line-section purchase-line-section sales-line-details">
        <div class="section-head">
          <h2>{{$salesDetailsGroup.Label}}</h2>
          <button type="button" class="section-inline-action" data-sales-edit-stock-out disabled>Edit Stock Out File</button>
          {{if not (fieldValue $.Record "dr_document_id")}}<span class="muted">Select an SO number first.</span>{{end}}
        </div>
        <div class="table-wrap modal-table">
          <table class="editable-grid sales-details-grid">
            <thead>
              <tr>
                <th>No.</th><th>Code</th><th>Stock Name</th><th>Qty</th><th>Unit Cost</th><th>Amount</th><th>Discount</th><th>Other Disc.</th><th>Net Amount</th><th>Capital</th><th>Markup</th><th>MU %</th>
              </tr>
            </thead>
            <tbody id="rows-details">
              {{$rows := index $.LineRows "details"}}
              {{if $rows}}
                {{range $rows}}
                <tr class="sales-detail-row" data-sales-detail-row>
                  <td class="row-no"></td>
                  <td class="editable-cell calculated-cell" contenteditable="false" data-readonly-cell data-field="stock_code">{{fieldValue . "stock_label"}}</td>
                  <td class="editable-cell calculated-cell" contenteditable="false" data-readonly-cell data-field="stock_name"></td>
                  <td class="editable-cell number-cell calculated-cell" contenteditable="false" data-readonly-cell data-field="qty">{{fieldValue . "qty"}}</td>
                  <td class="editable-cell number-cell" contenteditable="true" data-field="unit_cost">{{fieldValue . "unit_cost"}}</td>
                  <td class="editable-cell number-cell calculated-cell" contenteditable="false" data-readonly-cell data-field="amount">{{fieldValue . "amount"}}</td>
                  <td class="editable-cell number-cell" contenteditable="true" data-field="discount">{{fieldValue . "discount"}}</td>
                  <td class="editable-cell number-cell" contenteditable="true" data-field="other_discount">{{fieldValue . "other_discount"}}</td>
                  <td class="editable-cell number-cell calculated-cell" contenteditable="false" data-readonly-cell data-field="net_amount"></td>
                  <td class="editable-cell number-cell calculated-cell" contenteditable="false" data-readonly-cell data-field="capital">{{fieldValue . "capital"}}</td>
                  <td class="editable-cell number-cell calculated-cell" contenteditable="false" data-readonly-cell data-field="markup">{{fieldValue . "markup"}}</td>
                  <td class="editable-cell number-cell calculated-cell" contenteditable="false" data-readonly-cell data-field="markup_pct">{{fieldValue . "markup_pct"}}</td>
                  <td class="hidden-col">
                    <input type="hidden" name="line_details_dr_line_id" data-field-input="dr_line_id" value="{{fieldValue . "dr_line_id"}}">
                    <input type="hidden" name="line_details_stock_id" data-field-input="stock_id" value="{{fieldValue . "stock_id"}}">
                    <input type="hidden" name="line_details_stock_label" data-field-input="stock_label" value="{{fieldValue . "stock_label"}}">
                    <input type="hidden" data-field-input="stock_group" value="{{fieldValue . "stock_group"}}">
                    <input type="hidden" name="line_details_qty" value="{{fieldValue . "qty"}}" readonly data-field-input="qty">
                    <input type="hidden" name="line_details_unit_cost" data-field-input="unit_cost" value="{{fieldValue . "unit_cost"}}">
                    <input type="hidden" name="line_details_amount" data-field-input="amount" value="{{fieldValue . "amount"}}">
                    <input type="hidden" name="line_details_capital" data-field-input="capital" value="{{fieldValue . "capital"}}">
                    <input type="hidden" name="line_details_discount" data-field-input="discount" value="{{fieldValue . "discount"}}">
                    <input type="hidden" name="line_details_other_discount" data-field-input="other_discount" value="{{fieldValue . "other_discount"}}">
                    <input type="hidden" name="line_details_markup" data-field-input="markup" value="{{fieldValue . "markup"}}">
                    <input type="hidden" name="line_details_markup_pct" data-field-input="markup_pct" value="{{fieldValue . "markup_pct"}}">
                  </td>
                </tr>
                {{end}}
              {{else}}
                <tr><td colspan="12" class="empty">Select a Stock Out file to load detail quantities.</td></tr>
              {{end}}
            </tbody>
          </table>
        </div>
      </section>
      <div class="embedded-record-modal is-hidden" data-sales-stock-out-editor aria-hidden="true">
        <div class="embedded-record-modal-backdrop" data-sales-stock-out-editor-close></div>
        <div class="embedded-record-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="sales-stock-out-editor-title">
          <div class="embedded-record-modal-titlebar">
            <h3 id="sales-stock-out-editor-title">Edit Stock Out File</h3>
            <button type="button" class="embedded-record-modal-close" data-sales-stock-out-editor-close aria-label="Close">×</button>
          </div>
          <iframe class="embedded-record-modal-frame" data-sales-stock-out-editor-frame title="Stock Out File Editor" loading="lazy"></iframe>
        </div>
      </div>

      {{$deductionGroup := index .Form.LineGroups 1}}
      {{$salesAdditionalGroup := index .Form.LineGroups 2}}
      {{$salesPaymentGroup := index .Form.LineGroups 3}}
      <section class="sales-summary">
        <div class="sales-summary-tabs">
          <button type="button" class="sales-tab is-active" data-sales-tab="markup">Markup Summary/Totals</button>
          <button type="button" class="sales-tab" data-sales-tab="payments">Mode Of Payment</button>
          <button type="button" class="sales-tab" data-sales-tab="adjustments">Other Deductions/Additionals</button>
          <label>Total Qty:<input readonly data-sales-total-qty></label>
          <label>Total Net Amnt:<input readonly data-sales-total-net></label>
        </div>
        <div class="sales-summary-body">
          <div class="sales-summary-panels">
            <div class="sales-summary-grid" data-sales-panel="markup">
              <section class="sales-markup-summary">
                <div class="table-wrap modal-table">
                  <table class="editable-grid">
                    <thead><tr><th>No.</th><th>Item Group</th><th>Total Net Amount</th><th>Total Capital</th><th>Total Markup (Amnt.)</th><th>Avg. Markup (%)</th></tr></thead>
                    <tbody id="sales-markup-summary-rows"></tbody>
                  </table>
                </div>
              </section>
            </div>
            <section class="line-section modal-line-section purchase-line-section sales-line-payments is-hidden" data-sales-panel="payments">
              <div class="section-head"><h2>{{$salesPaymentGroup.Label}}</h2></div>
              <div class="sales-payment-grid">
                <div class="table-wrap modal-table"><table class="editable-grid purchase-payment-grid"><thead><tr><th>Number</th><th>Date</th><th>Bank Name</th><th>Amount</th><th>Nature</th></tr></thead><tbody id="rows-{{$salesPaymentGroup.Key}}">{{$rows := index $.LineRows $salesPaymentGroup.Key}}{{if $rows}}{{range $rows}}{{template "direct_payment_row" dictRow $salesPaymentGroup $.Options .}}{{end}}{{else}}{{template "direct_payment_row" dictLine $salesPaymentGroup $.Options}}{{end}}</tbody></table></div>
                <section class="sales-payment-amount">
                  <h2>AMOUNT</h2>
                  <label>Check:<input readonly data-sales-check-total></label>
                  <label>Balance:<input readonly data-sales-balance></label>
                </section>
              </div>
            </section>
            <div class="sales-adjustments is-hidden" data-sales-panel="adjustments">
              <section class="purchase-adjustment">
                <div class="section-head"><h2>{{$deductionGroup.Label}}</h2></div>
                <div class="table-wrap modal-table"><table class="editable-grid purchase-adjustment-grid"><thead><tr><th>Particulars</th><th>Qty</th><th>Price</th><th>Amount</th></tr></thead><tbody id="rows-deductions">{{$rows := index $.LineRows $deductionGroup.Key}}{{if $rows}}{{range $rows}}{{template "direct_adjustment_row" dictRow $deductionGroup $.Options .}}{{end}}{{else}}{{template "direct_adjustment_row" dictLine $deductionGroup $.Options}}{{end}}</tbody></table></div>
              </section>
              <section class="purchase-adjustment">
                <div class="section-head"><h2>{{$salesAdditionalGroup.Label}}</h2></div>
                <div class="table-wrap modal-table"><table class="editable-grid purchase-adjustment-grid"><thead><tr><th>Particulars</th><th>Qty</th><th>Price</th><th>Amount</th></tr></thead><tbody id="rows-additionals">{{$rows := index $.LineRows $salesAdditionalGroup.Key}}{{if $rows}}{{range $rows}}{{template "direct_adjustment_row" dictRow $salesAdditionalGroup $.Options .}}{{end}}{{else}}{{template "direct_adjustment_row" dictLine $salesAdditionalGroup $.Options}}{{end}}</tbody></table></div>
              </section>
            </div>
          </div>
          <section class="sales-totals">
            <label>Total:<input readonly data-sales-total></label>
            <label>Less (A):<input readonly data-sales-less-a></label>
            <label>Less (M):<input readonly data-sales-less-m></label>
            <label>Add:<input readonly data-sales-add></label>
            <label>Net:<input readonly data-sales-net></label>
          </section>
        </div>
      </section>
      {{else if eq .Form.Kind "stock-transactions"}}
      <section class="transfer-legacy-form">
        <label class="transfer-field transfer-entry-id"><span>Entry ID:</span><input value="{{fieldValue $.Record "id"}}" readonly></label>
        <label class="transfer-field transfer-entry-date"><span>Entry Date:</span><input name="entry_date" type="date" value="{{fieldValue $.Record "entry_date"}}" required></label>
        <label class="transfer-field transfer-date"><span>Transfer Date:</span><input name="transfer_date" type="date" value="{{fieldValue $.Record "transfer_date"}}"></label>
        <label class="transfer-field transfer-id"><span>Transfer ID:</span><input name="transfer_id" value="{{fieldValue $.Record "transfer_id"}}"></label>
        <label class="transfer-field transfer-transaction">
          <span>Transaction:</span>
          <select name="transaction">
            {{$currentTransaction := fieldValue $.Record "transaction"}}
            <option value="0 - Stock Transfer" {{if eq $currentTransaction "0 - Stock Transfer"}}selected{{end}}>0 - Stock Transfer</option>
            <option value="1 - Sales Return" {{if eq $currentTransaction "1 - Sales Return"}}selected{{end}}>1 - Sales Return</option>
            <option value="2 - Stock Return" {{if eq $currentTransaction "2 - Stock Return"}}selected{{end}}>2 - Stock Return</option>
          </select>
        </label>
        <label class="transfer-field transfer-branch"><span>Branch/Location:</span><select name="branch_location"><option value="">Select</option>{{$currentBranch := fieldValue $.Record "branch_location"}}{{range index $.Options "branches"}}<option value="{{.Value}}" {{if eq .Value $currentBranch}}selected{{end}}>{{.Label}}</option>{{end}}</select></label>
        <label class="transfer-field transfer-dr-file">
          <span>SO Number:</span>
          <span class="purchase-supplier-control">
            <select name="dr_document_id" required data-transfer-dr-select>
              <option value="">Select SO Number</option>
              {{$currentDR := fieldValue $.Record "dr_document_id"}}
              {{$currentDRLabel := fieldValue $.Record "dr_document_label"}}
              {{if and $currentDR $currentDRLabel}}<option value="{{$currentDR}}" selected>{{$currentDRLabel}}</option>{{end}}
              {{range index $.Options "dr_documents"}}
                {{if and $currentDRLabel (eq .Value $currentDR)}}{{else}}<option value="{{.Value}}" {{if eq .Value $currentDR}}selected{{end}}>{{.Label}}</option>{{end}}
              {{end}}
            </select>
            <button type="button" class="purchase-supplier-browse" data-transfer-dr-browse>Browse</button>
          </span>
        </label>
        <label class="transfer-field transfer-remarks"><span>Remarks:</span><textarea name="remarks" rows="2">{{fieldValue $.Record "remarks"}}</textarea></label>
        <label class="transfer-field transfer-updated-by"><span>Last Update By:</span><input value="{{fieldValue $.Record "updated_by"}}" readonly tabindex="-1" aria-readonly="true"></label>
      </section>
      <div class="purchase-supplier-picker is-hidden" data-transfer-dr-picker aria-hidden="true">
        <div class="purchase-supplier-picker-backdrop" data-transfer-dr-picker-close></div>
        <div class="purchase-supplier-picker-dialog" role="dialog" aria-modal="true" aria-labelledby="transfer-dr-picker-title">
          <div class="purchase-supplier-picker-titlebar">
            <h3 id="transfer-dr-picker-title">SO Number List</h3>
            <button type="button" class="purchase-supplier-picker-close" data-transfer-dr-picker-close aria-label="Close">×</button>
          </div>
          <div class="purchase-supplier-picker-body">
            <label class="purchase-supplier-picker-search">
              <span>Search:</span>
              <input type="search" data-transfer-dr-picker-search placeholder="Type SO number or customer name">
            </label>
            <div class="purchase-supplier-picker-table-wrap">
              <table>
                <thead><tr><th>SO Number</th><th>Customer</th></tr></thead>
                <tbody data-transfer-dr-picker-results></tbody>
              </table>
              <p class="purchase-supplier-picker-empty is-hidden" data-transfer-dr-picker-empty>No matching SO number found.</p>
            </div>
          </div>
        </div>
      </div>

      {{$transferDetailsGroup := index .Form.LineGroups 0}}
      <section class="line-section modal-line-section purchase-line-section sales-line-details">
        <div class="section-head">
          <h2>{{$transferDetailsGroup.Label}}</h2>
          <button type="button" class="section-inline-action" data-transfer-edit-stock-out disabled>Edit Stock Out File</button>
          {{if not (fieldValue $.Record "dr_document_id")}}<span class="muted">Select an SO number first.</span>{{end}}
        </div>
        <div class="table-wrap modal-table">
          <table class="editable-grid sales-details-grid">
            <thead><tr><th>No.</th><th>Stock Code</th><th>Stock Name</th><th>Qty</th><th>Unit Cost</th><th>Amount</th><th>Capital</th><th>Markup</th><th>MU %</th></tr></thead>
            <tbody id="rows-details">
              {{$rows := index $.LineRows "details"}}
              {{if $rows}}{{range $rows}}
              <tr class="sales-detail-row" data-sales-detail-row>
                <td class="row-no"></td>
                <td class="editable-cell calculated-cell" contenteditable="false" data-readonly-cell data-field="stock_code">{{fieldValue . "stock_label"}}</td>
                <td class="editable-cell calculated-cell" contenteditable="false" data-readonly-cell data-field="stock_name"></td>
                <td class="editable-cell number-cell calculated-cell" contenteditable="false" data-readonly-cell data-field="qty">{{fieldValue . "qty"}}</td>
                <td class="editable-cell number-cell" contenteditable="true" data-field="unit_cost">{{fieldValue . "unit_cost"}}</td>
                <td class="editable-cell number-cell calculated-cell" contenteditable="false" data-readonly-cell data-field="amount">{{fieldValue . "amount"}}</td>
                <td class="editable-cell number-cell calculated-cell" contenteditable="false" data-readonly-cell data-field="capital">{{fieldValue . "capital"}}</td>
                <td class="editable-cell number-cell calculated-cell" contenteditable="false" data-readonly-cell data-field="markup">{{fieldValue . "markup"}}</td>
                <td class="editable-cell number-cell calculated-cell" contenteditable="false" data-readonly-cell data-field="markup_pct">{{fieldValue . "markup_pct"}}</td>
                <td class="hidden-col">
                  <input type="hidden" name="line_details_dr_line_id" data-field-input="dr_line_id" value="{{fieldValue . "dr_line_id"}}">
                  <input type="hidden" name="line_details_stock_id" data-field-input="stock_id" value="{{fieldValue . "stock_id"}}">
                  <input type="hidden" name="line_details_stock_label" data-field-input="stock_label" value="{{fieldValue . "stock_label"}}">
                  <input type="hidden" data-field-input="stock_group" value="{{fieldValue . "stock_group"}}">
                  <input type="hidden" name="line_details_qty" value="{{fieldValue . "qty"}}" readonly data-field-input="qty">
                  <input type="hidden" name="line_details_unit_cost" data-field-input="unit_cost" value="{{fieldValue . "unit_cost"}}">
                  <input type="hidden" name="line_details_amount" data-field-input="amount" value="{{fieldValue . "amount"}}">
                  <input type="hidden" name="line_details_capital" data-field-input="capital" value="{{fieldValue . "capital"}}">
                  <input type="hidden" name="line_details_discount" data-field-input="discount" value="{{fieldValue . "discount"}}">
                  <input type="hidden" name="line_details_other_discount" data-field-input="other_discount" value="{{fieldValue . "other_discount"}}">
                  <input type="hidden" name="line_details_markup" data-field-input="markup" value="{{fieldValue . "markup"}}">
                  <input type="hidden" name="line_details_markup_pct" data-field-input="markup_pct" value="{{fieldValue . "markup_pct"}}">
                </td>
              </tr>
              {{end}}{{else}}<tr><td colspan="9" class="empty">Select a Stock Out file to load detail quantities.</td></tr>{{end}}
            </tbody>
          </table>
        </div>
      </section>

      <div class="embedded-record-modal is-hidden" data-transfer-stock-out-editor aria-hidden="true">
        <div class="embedded-record-modal-backdrop" data-transfer-stock-out-editor-close></div>
        <div class="embedded-record-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="transfer-stock-out-editor-title">
          <div class="embedded-record-modal-titlebar">
            <h3 id="transfer-stock-out-editor-title">Edit Stock Out File</h3>
            <button type="button" class="embedded-record-modal-close" data-transfer-stock-out-editor-close aria-label="Close">×</button>
          </div>
          <iframe class="embedded-record-modal-frame" data-transfer-stock-out-editor-frame title="Stock Out File Editor" loading="lazy"></iframe>
        </div>
      </div>

      {{$transferDiscountGroup := index .Form.LineGroups 1}}
      {{$transferAdditionalGroup := index .Form.LineGroups 2}}
      <section class="sales-summary">
        <div class="sales-summary-tabs transfer-summary-tabs">
          <button type="button" class="sales-tab is-active" data-sales-tab="markup">Markup Summary</button>
          <button type="button" class="sales-tab" data-sales-tab="adjustments">Discounts/Additionals/Summary</button>
        </div>
        <div class="sales-summary-body transfer-summary-body">
          <div class="sales-summary-panels">
            <div class="sales-summary-grid" data-sales-panel="markup">
              <section class="sales-markup-summary"><div class="table-wrap modal-table"><table class="editable-grid"><thead><tr><th>No.</th><th>Item Group</th><th>Total Net Amount</th><th>Total Capital</th><th>Total Markup (Amnt.)</th><th>Avg. Markup (%)</th></tr></thead><tbody id="sales-markup-summary-rows"></tbody></table></div></section>
            </div>
            <div class="sales-adjustments is-hidden" data-sales-panel="adjustments">
              <section class="purchase-adjustment"><div class="section-head"><h2>{{$transferDiscountGroup.Label}}</h2></div><div class="table-wrap modal-table"><table class="editable-grid purchase-adjustment-grid"><thead><tr><th>Particulars</th><th>Qty</th><th>Price</th><th>Amount</th></tr></thead><tbody id="rows-discounts">{{$rows := index $.LineRows $transferDiscountGroup.Key}}{{if $rows}}{{range $rows}}{{template "direct_adjustment_row" dictRow $transferDiscountGroup $.Options .}}{{end}}{{else}}{{template "direct_adjustment_row" dictLine $transferDiscountGroup $.Options}}{{end}}</tbody></table></div></section>
              <section class="purchase-adjustment"><div class="section-head"><h2>{{$transferAdditionalGroup.Label}}</h2></div><div class="table-wrap modal-table"><table class="editable-grid purchase-adjustment-grid"><thead><tr><th>Particulars</th><th>Qty</th><th>Price</th><th>Amount</th></tr></thead><tbody id="rows-additionals">{{$rows := index $.LineRows $transferAdditionalGroup.Key}}{{if $rows}}{{range $rows}}{{template "direct_adjustment_row" dictRow $transferAdditionalGroup $.Options .}}{{end}}{{else}}{{template "direct_adjustment_row" dictLine $transferAdditionalGroup $.Options}}{{end}}</tbody></table></div></section>
            </div>
          </div>
          <section class="sales-totals"><label>Total:<input readonly data-sales-total></label><label>Less:<input readonly data-sales-less-a></label><label>Add:<input readonly data-sales-add></label><label>Net:<input readonly data-sales-net></label></section>
        </div>
      </section>
      {{else if eq .Form.Kind "ap-credit"}}
      <section class="credit-legacy-form ap-credit-legacy-form">
        <label class="credit-field credit-entry-id"><span>Entry ID:</span><input value="{{fieldValue $.Record "id"}}" readonly></label>
        <label class="credit-field credit-date"><span>Date:</span><input name="entry_date" type="date" value="{{fieldValue $.Record "entry_date"}}" required></label>
        <label class="credit-field credit-reference"><span>Reference:</span><input name="reference" value="{{fieldValue $.Record "reference"}}"></label>
        <label class="credit-field credit-company"><span>Company:</span><span class="credit-combobox-wrap"><input name="ap_credit_company_name" list="ap-credit-company-options" autocomplete="off" required><button type="button" disabled>Browse...</button><input type="hidden" name="party_id" value="{{fieldValue $.Record "party_id"}}" data-ap-credit-party-id><datalist id="ap-credit-company-options">{{range index $.Options "suppliers"}}<option value="{{.Label}}"></option>{{end}}</datalist></span></label>
        <label class="credit-field credit-balance"><span>Balance:</span><input value="{{fieldValue $.Record "balance"}}" readonly tabindex="-1" aria-readonly="true"></label>
        <label class="credit-field credit-cash"><span>Cash Amount:</span><input name="cash_amount" type="number" step="0.01" value="{{fieldValue $.Record "cash_amount"}}"></label>
        <label class="credit-field credit-encoder"><span>Encoder:</span><input value="{{fieldValue $.Record "encoder"}}" readonly tabindex="-1" aria-readonly="true"></label>
        <input type="hidden" name="remarks" value="{{fieldValue $.Record "remarks"}}">
        <div class="credit-payment-label">PAYMENT</div>
      </section>

      {{$creditChecksGroup := index .Form.LineGroups 0}}
      <section class="line-section modal-line-section purchase-line-section credit-line-checks">
        <div class="section-head"><h2>{{$creditChecksGroup.Label}}</h2></div>
        <div class="table-wrap modal-table">
          <table class="editable-grid checks-in-details-grid">
            <thead><tr><th>No.</th><th>Number</th><th>Date</th><th>Bank Name</th><th>Amount</th><th class="credit-hidden-check-nature">Nature</th></tr></thead>
            <tbody id="rows-{{$creditChecksGroup.Key}}">
              {{$rows := index $.LineRows $creditChecksGroup.Key}}
              {{if $rows}}{{range $rows}}{{template "direct_checks_row" dictRow $creditChecksGroup $.Options .}}{{end}}{{else}}{{template "direct_checks_row" dictLine $creditChecksGroup $.Options}}{{end}}
            </tbody>
          </table>
        </div>
      </section>
      <section class="credit-payment-totals">
        <label>Check Amount:<input readonly data-credit-check-total></label>
        <label>Total Payment:<input readonly data-credit-payment-total></label>
      </section>
      {{else if eq .Form.Kind "ar-credit"}}
      <section class="credit-legacy-form">
        <label class="credit-field credit-entry-id"><span>Entry ID:</span><input value="{{fieldValue $.Record "id"}}" readonly></label>
        <label class="credit-field credit-date"><span>Date:</span><input name="entry_date" type="date" value="{{fieldValue $.Record "entry_date"}}" required></label>
        <label class="credit-field credit-reference"><span>Reference:</span><input name="reference" value="{{fieldValue $.Record "reference"}}"></label>
        <label class="credit-field credit-company"><span>Company:</span><span class="credit-combobox-wrap"><input name="ar_credit_company_name" list="ar-credit-company-options" autocomplete="off" required><input type="hidden" name="party_id" value="{{fieldValue $.Record "party_id"}}" data-ar-credit-party-id><datalist id="ar-credit-company-options">{{range index $.Options "customers"}}<option value="{{.Label}}"></option>{{end}}</datalist></span></label>
        <label class="credit-field credit-balance"><span>Balance:</span><input value="{{fieldValue $.Record "balance"}}" readonly tabindex="-1" aria-readonly="true"></label>
        <label class="credit-field credit-cash"><span>Cash Amount:</span><input name="cash_amount" type="number" step="0.01" value="{{fieldValue $.Record "cash_amount"}}"></label>
        <label class="credit-field credit-encoder"><span>Encoder:</span><input value="{{fieldValue $.Record "encoder"}}" readonly tabindex="-1" aria-readonly="true"></label>
        <label class="credit-field credit-remarks"><span>Remarks:</span><textarea name="remarks" rows="2">{{fieldValue $.Record "remarks"}}</textarea></label>
      </section>

      {{$creditChecksGroup := index .Form.LineGroups 0}}
      <section class="line-section modal-line-section purchase-line-section credit-line-checks">
        <div class="section-head"><h2>{{$creditChecksGroup.Label}}</h2></div>
        <div class="table-wrap modal-table">
          <table class="editable-grid checks-in-details-grid">
            <thead><tr><th>No.</th><th>Number</th><th>Date</th><th>Bank Name</th><th>Amount</th><th>Nature</th></tr></thead>
            <tbody id="rows-{{$creditChecksGroup.Key}}">
              {{$rows := index $.LineRows $creditChecksGroup.Key}}
              {{if $rows}}{{range $rows}}{{template "direct_checks_row" dictRow $creditChecksGroup $.Options .}}{{end}}{{else}}{{template "direct_checks_row" dictLine $creditChecksGroup $.Options}}{{end}}
            </tbody>
          </table>
        </div>
      </section>
      {{else if eq .Form.Kind "rebates"}}
      <section class="credit-legacy-form">
        <label class="credit-field credit-entry-id"><span>Entry ID:</span><input value="{{fieldValue $.Record "id"}}" readonly></label>
        <label class="credit-field credit-date"><span>Date:</span><input name="entry_date" type="date" value="{{fieldValue $.Record "entry_date"}}" required></label>
        <label class="credit-field credit-reference"><span>Reference:</span><input name="reference" value="{{fieldValue $.Record "reference"}}"></label>
        <label class="credit-field credit-company"><span>Company:</span><span class="credit-combobox-wrap"><input name="rebates_company_name" list="rebates-company-options" autocomplete="off" required><input type="hidden" name="party_id" value="{{fieldValue $.Record "party_id"}}" data-rebates-party-id><datalist id="rebates-company-options">{{range index $.Options "customers"}}<option value="{{.Label}}"></option>{{end}}</datalist></span></label>
        <label class="credit-field credit-balance"><span>Balance:</span><input value="{{fieldValue $.Record "balance"}}" readonly tabindex="-1" aria-readonly="true"></label>
        <label class="credit-field credit-cash"><span>Cash Amount:</span><input name="cash_amount" type="number" step="0.01" value="{{fieldValue $.Record "cash_amount"}}"></label>
        <label class="credit-field credit-encoder"><span>Encoder:</span><input value="{{fieldValue $.Record "encoder"}}" readonly tabindex="-1" aria-readonly="true"></label>
        <label class="credit-field credit-remarks"><span>Remarks:</span><textarea name="remarks" rows="2">{{fieldValue $.Record "remarks"}}</textarea></label>
      </section>

      {{$creditChecksGroup := index .Form.LineGroups 0}}
      <section class="line-section modal-line-section purchase-line-section credit-line-checks">
        <div class="section-head"><h2>{{$creditChecksGroup.Label}}</h2></div>
        <div class="table-wrap modal-table">
          <table class="editable-grid checks-in-details-grid">
            <thead><tr><th>No.</th><th>Number</th><th>Date</th><th>Bank Name</th><th>Amount</th><th>Nature</th></tr></thead>
            <tbody id="rows-{{$creditChecksGroup.Key}}">
              {{$rows := index $.LineRows $creditChecksGroup.Key}}
              {{if $rows}}{{range $rows}}{{template "direct_checks_row" dictRow $creditChecksGroup $.Options .}}{{end}}{{else}}{{template "direct_checks_row" dictLine $creditChecksGroup $.Options}}{{end}}
            </tbody>
          </table>
        </div>
      </section>
      {{else if eq .Form.Kind "ap-debit"}}
      <section class="debit-legacy-form ap-debit-legacy-form">
        <label class="debit-field debit-entry-id"><span>EntryID:</span><input value="{{fieldValue $.Record "id"}}" readonly></label>
        <label class="debit-field debit-date"><span>Entry Date:</span><input name="entry_date" type="date" value="{{fieldValue $.Record "entry_date"}}" required></label>
        <label class="debit-field debit-company"><span>Company:</span><span class="credit-combobox-wrap"><input name="ap_debit_company_name" list="ap-debit-company-options" autocomplete="off" required><button type="button" disabled>Browse...</button><input type="hidden" name="party_id" value="{{fieldValue $.Record "party_id"}}" data-ap-debit-party-id><datalist id="ap-debit-company-options">{{range index $.Options "suppliers"}}<option value="{{.Label}}"></option>{{end}}</datalist></span></label>
        <label class="debit-field debit-amount"><span>Amount:</span><input name="amount" type="number" step="0.01" value="{{fieldValue $.Record "amount"}}" required></label>
        <label class="debit-field debit-encoder"><span>Encoder:</span><input value="{{fieldValue $.Record "encoder"}}" readonly tabindex="-1" aria-readonly="true"></label>
        <label class="debit-field debit-remarks"><span>Remarks:</span><textarea name="remarks" rows="2">{{fieldValue $.Record "remarks"}}</textarea></label>
      </section>
      {{else if eq .Form.Kind "ar-debit"}}
      <section class="debit-legacy-form ar-debit-legacy-form">
        <label class="debit-field debit-entry-id"><span>Entry ID:</span><input value="{{fieldValue $.Record "id"}}" readonly></label>
        <label class="debit-field debit-date"><span>Entry Date:</span><input name="entry_date" type="date" value="{{fieldValue $.Record "entry_date"}}" required></label>
        <label class="debit-field debit-company"><span>Company:</span><span class="credit-combobox-wrap"><input name="ar_debit_company_name" list="ar-debit-company-options" autocomplete="off" required><input type="hidden" name="party_id" value="{{fieldValue $.Record "party_id"}}" data-ar-debit-party-id><datalist id="ar-debit-company-options">{{range index $.Options "customers"}}<option value="{{.Label}}"></option>{{end}}</datalist></span></label>
        <label class="debit-field debit-amount"><span>Amount:</span><input name="amount" type="number" step="0.01" value="{{fieldValue $.Record "amount"}}" required></label>
        <label class="debit-field debit-encoder"><span>Encoder:</span><input value="{{fieldValue $.Record "encoder"}}" readonly tabindex="-1" aria-readonly="true"></label>
        <label class="debit-field debit-remarks"><span>Remarks:</span><textarea name="remarks" rows="2">{{fieldValue $.Record "remarks"}}</textarea></label>
      </section>
      {{else if eq .Form.Kind "expenses"}}
      <section class="expense-legacy-form">
        <label class="expense-field expense-entry-id"><span>Entry ID:</span><input value="{{fieldValue $.Record "id"}}" readonly></label>
        <label class="expense-field expense-entry-date"><span>Entry Date:</span><input name="entry_date" type="date" value="{{fieldValue $.Record "entry_date"}}" required></label>
        <label class="expense-field expense-encoder"><span>Encoder:</span><input value="{{fieldValue $.Record "encoder"}}" readonly tabindex="-1" aria-readonly="true"></label>
        <label class="expense-field expense-remarks"><span>Remarks:</span><textarea name="remarks" rows="2">{{fieldValue $.Record "remarks"}}</textarea></label>
      </section>

      {{$expenseDetailsGroup := index .Form.LineGroups 0}}
      <section class="line-section modal-line-section purchase-line-section expense-line-details">
        <div class="section-head"><h2>{{$expenseDetailsGroup.Label}}</h2></div>
        <div class="table-wrap modal-table">
          <table class="editable-grid expense-details-grid">
            <datalist id="expense-code-options">{{range index $.Options "expense_charts"}}<option value="{{.Label}}"></option>{{end}}</datalist>
            <thead><tr><th>No.</th><th>Code</th><th>Reference</th><th>Cash</th><th>Check</th><th>Total</th></tr></thead>
            <tbody id="rows-details">
              {{$rows := index $.LineRows "details"}}
              {{if $rows}}{{range $rows}}
              <tr class="expense-detail-row">
                <td class="row-no"></td>
                <td><input class="cell-combobox" list="expense-code-options" data-field="code_label" autocomplete="off"></td>
                <td class="editable-cell" contenteditable="true" data-field="reference">{{fieldValue . "reference"}}</td>
                <td class="editable-cell number-cell" contenteditable="true" data-field="cash">{{fieldValue . "cash"}}</td>
                <td class="editable-cell number-cell" contenteditable="true" data-field="check">{{fieldValue . "check"}}</td>
                <td class="editable-cell number-cell" contenteditable="true" data-field="total">{{fieldValue . "total"}}</td>
                <td class="hidden-col">
                  <input type="hidden" name="line_details_code_id" data-field-input="code_id" value="{{fieldValue . "code_id"}}">
                  <input type="hidden" name="line_details_reference" data-field-input="reference" value="{{fieldValue . "reference"}}">
                  <input type="hidden" name="line_details_cash" data-field-input="cash" value="{{fieldValue . "cash"}}">
                  <input type="hidden" name="line_details_check" data-field-input="check" value="{{fieldValue . "check"}}">
                  <input type="hidden" name="line_details_total" data-field-input="total" value="{{fieldValue . "total"}}">
                </td>
              </tr>
              {{end}}{{else}}
              <tr class="expense-detail-row"><td class="row-no"></td><td><input class="cell-combobox" list="expense-code-options" data-field="code_label" autocomplete="off"></td><td class="editable-cell" contenteditable="true" data-field="reference"></td><td class="editable-cell number-cell" contenteditable="true" data-field="cash"></td><td class="editable-cell number-cell" contenteditable="true" data-field="check"></td><td class="editable-cell number-cell" contenteditable="true" data-field="total"></td><td class="hidden-col"><input type="hidden" name="line_details_code_id" data-field-input="code_id"><input type="hidden" name="line_details_reference" data-field-input="reference"><input type="hidden" name="line_details_cash" data-field-input="cash"><input type="hidden" name="line_details_check" data-field-input="check"><input type="hidden" name="line_details_total" data-field-input="total"></td></tr>
              {{end}}
            </tbody>
          </table>
        </div>
      </section>
      <section class="expense-totals"><label>Cash:<input readonly data-expense-cash-total></label><label>Check:<input readonly data-expense-check-total></label><label>Total:<input readonly data-expense-grand-total></label></section>
      {{else if eq .Form.Kind "other-income"}}
      <section class="other-income-legacy-form">
        <label class="other-income-field other-income-entry-id"><span>Entry ID:</span><input value="{{fieldValue $.Record "id"}}" readonly></label>
        <label class="other-income-field other-income-entry-date"><span>Entry Date:</span><input name="entry_date" type="date" value="{{fieldValue $.Record "entry_date"}}" required></label>
        <label class="other-income-field other-income-branch"><span>Branch:</span><select name="branch_id"><option value="">Select</option>{{$currentBranch := fieldValue $.Record "branch_id"}}{{range index $.Options "branches"}}<option value="{{.Value}}" {{if eq .Value $currentBranch}}selected{{end}}>{{.Label}}</option>{{end}}</select></label>
        <label class="other-income-field other-income-encoder"><span>Encoder:</span><input value="{{fieldValue $.Record "encoder"}}" readonly tabindex="-1" aria-readonly="true"></label>
        <label class="other-income-field other-income-remarks"><span>Remarks:</span><textarea name="remarks" rows="2">{{fieldValue $.Record "remarks"}}</textarea></label>
      </section>

      {{$otherIncomeDetailsGroup := index .Form.LineGroups 0}}
      <section class="line-section modal-line-section purchase-line-section other-income-line-details">
        <div class="section-head"><h2>{{$otherIncomeDetailsGroup.Label}}</h2></div>
        <div class="table-wrap modal-table">
          <table class="editable-grid other-income-details-grid">
            <datalist id="other-income-code-options">{{range index $.Options "other_income_charts"}}<option value="{{.Label}}"></option>{{end}}</datalist>
            <thead><tr><th>No.</th><th>Code</th><th>Reference</th><th>Cash</th><th>Check</th><th>Total</th></tr></thead>
            <tbody id="rows-details">
              {{$rows := index $.LineRows "details"}}
              {{if $rows}}{{range $rows}}
              <tr class="other-income-detail-row"><td class="row-no"></td><td><input class="cell-combobox" list="other-income-code-options" data-field="code_label" autocomplete="off"></td><td class="editable-cell" contenteditable="true" data-field="reference">{{fieldValue . "reference"}}</td><td class="editable-cell number-cell" contenteditable="true" data-field="cash">{{fieldValue . "cash"}}</td><td class="editable-cell number-cell" contenteditable="true" data-field="check">{{fieldValue . "check"}}</td><td class="editable-cell number-cell" contenteditable="true" data-field="total">{{fieldValue . "total"}}</td><td class="hidden-col"><input type="hidden" name="line_details_code_id" data-field-input="code_id" value="{{fieldValue . "code_id"}}"><input type="hidden" name="line_details_reference" data-field-input="reference" value="{{fieldValue . "reference"}}"><input type="hidden" name="line_details_cash" data-field-input="cash" value="{{fieldValue . "cash"}}"><input type="hidden" name="line_details_check" data-field-input="check" value="{{fieldValue . "check"}}"><input type="hidden" name="line_details_total" data-field-input="total" value="{{fieldValue . "total"}}"></td></tr>
              {{end}}{{else}}
              <tr class="other-income-detail-row"><td class="row-no"></td><td><input class="cell-combobox" list="other-income-code-options" data-field="code_label" autocomplete="off"></td><td class="editable-cell" contenteditable="true" data-field="reference"></td><td class="editable-cell number-cell" contenteditable="true" data-field="cash"></td><td class="editable-cell number-cell" contenteditable="true" data-field="check"></td><td class="editable-cell number-cell" contenteditable="true" data-field="total"></td><td class="hidden-col"><input type="hidden" name="line_details_code_id" data-field-input="code_id"><input type="hidden" name="line_details_reference" data-field-input="reference"><input type="hidden" name="line_details_cash" data-field-input="cash"><input type="hidden" name="line_details_check" data-field-input="check"><input type="hidden" name="line_details_total" data-field-input="total"></td></tr>
              {{end}}
            </tbody>
          </table>
        </div>
      </section>
      <section class="other-income-totals"><label>Cash:<input readonly data-other-income-cash-total></label><label>Check:<input readonly data-other-income-check-total></label><label>Total:<input readonly data-other-income-grand-total></label></section>
      {{else if or (eq .Form.Kind "stock-in") (eq .Form.Kind "stock-out")}}
      <section class="stock-in-legacy-form">
        <label class="stock-in-field stock-in-entry-id"><span>Entry ID:</span><input value="{{fieldValue $.Record "id"}}" readonly></label>
        <label class="stock-in-field stock-in-date"><span>Entry Date:</span><input name="entry_date" type="date" value="{{fieldValue $.Record "entry_date"}}" required></label>
        <label class="stock-in-field stock-in-encoder"><span>Encoder:</span><input value="{{fieldValue $.Record "encoder"}}" readonly tabindex="-1" aria-readonly="true"></label>
        <label class="stock-in-field stock-in-remarks"><span>Remarks:</span><textarea name="remarks" rows="2">{{fieldValue $.Record "remarks"}}</textarea></label>
      </section>

      {{$stockInDetailsGroup := index .Form.LineGroups 0}}
      <section class="line-section modal-line-section stock-in-line-details">
        <div class="section-head"><h2>{{$stockInDetailsGroup.Label}}</h2></div>
        <div class="table-wrap modal-table">
          <table class="editable-grid stock-in-details-grid">
            <thead><tr><th>No.</th><th>Stock Code</th><th>Stock Name</th><th>Qty</th><th>Unit Cost</th><th>Amount</th></tr></thead>
            <tbody id="rows-details">
              {{$rows := index $.LineRows "details"}}
              {{if $rows}}
                {{range $rows}}
                <tr class="purchase-detail-row stock-in-detail-row" data-stock-picker-row="purchase"><td class="row-no"></td><td class="stock-code-cell"><input class="cell-combobox" data-field="stock_code" data-purchase-stock-trigger autocomplete="off" placeholder="Press Enter" value="{{optionCode $.Options "stocks" (fieldValue . "stock_id")}}"></td><td class="editable-cell stock-name-cell" contenteditable="true" data-field="stock_name">{{optionName $.Options "stocks" (fieldValue . "stock_id")}}</td><td class="editable-cell number-cell" contenteditable="true" data-field="qty">{{fieldValue . "qty"}}</td><td class="editable-cell number-cell" contenteditable="true" data-field="unit_cost">{{fieldValue . "unit_cost"}}</td><td class="editable-cell number-cell calculated-cell" contenteditable="false" data-readonly-cell data-field="amount">{{fieldValue . "amount"}}</td><td class="hidden-col"><input type="hidden" name="line_details_stock_id" data-field-input="stock_id" value="{{fieldValue . "stock_id"}}"><input type="hidden" name="line_details_qty" data-field-input="qty" value="{{fieldValue . "qty"}}"><input type="hidden" name="line_details_unit_cost" data-field-input="unit_cost" value="{{fieldValue . "unit_cost"}}"><input type="hidden" name="line_details_amount" data-field-input="amount" value="{{fieldValue . "amount"}}"></td></tr>
                {{end}}
              {{else}}
                <tr class="purchase-detail-row stock-in-detail-row" data-stock-picker-row="purchase"><td class="row-no"></td><td class="stock-code-cell"><input class="cell-combobox" data-field="stock_code" data-purchase-stock-trigger autocomplete="off" placeholder="Press Enter"></td><td class="editable-cell stock-name-cell" contenteditable="true" data-field="stock_name"></td><td class="editable-cell number-cell" contenteditable="true" data-field="qty"></td><td class="editable-cell number-cell" contenteditable="true" data-field="unit_cost"></td><td class="editable-cell number-cell calculated-cell" contenteditable="false" data-readonly-cell data-field="amount"></td><td class="hidden-col"><input type="hidden" name="line_details_stock_id" data-field-input="stock_id"><input type="hidden" name="line_details_qty" data-field-input="qty"><input type="hidden" name="line_details_unit_cost" data-field-input="unit_cost"><input type="hidden" name="line_details_amount" data-field-input="amount"></td></tr>
              {{end}}
            </tbody>
          </table>
        </div>
        <div class="purchase-stock-picker is-hidden" data-purchase-stock-picker aria-hidden="true">
          <div class="purchase-stock-picker-backdrop" data-purchase-stock-picker-close></div>
          <div class="purchase-stock-picker-dialog" role="dialog" aria-modal="true" aria-labelledby="purchase-stock-picker-title">
            <div class="purchase-stock-picker-titlebar">
              <h3 id="purchase-stock-picker-title">Stock List</h3>
              <button type="button" class="purchase-stock-picker-close" data-purchase-stock-picker-close aria-label="Close">×</button>
            </div>
            <div class="purchase-stock-picker-body">
              <label class="purchase-stock-picker-search">
                <span>Search:</span>
                <input type="search" data-purchase-stock-picker-search placeholder="Type stock code or stock name">
              </label>
              <div class="purchase-stock-picker-table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>Stock Code</th>
                      <th>Stock Name</th>
                    </tr>
                  </thead>
                  <tbody data-purchase-stock-picker-results></tbody>
                </table>
                <p class="purchase-stock-picker-empty is-hidden" data-purchase-stock-picker-empty>No matching stock found.</p>
              </div>
            </div>
          </div>
        </div>
      </section>
      {{else if eq .Form.Kind "checks-in"}}
      <section class="checks-in-legacy-form">
        <label class="checks-in-field checks-in-entry-id"><span>Entry ID:</span><input value="{{fieldValue $.Record "id"}}" readonly></label>
        <label class="checks-in-field checks-in-date"><span>Entry Date:</span><input name="entry_date" type="date" value="{{fieldValue $.Record "entry_date"}}" required></label>
        <label class="checks-in-field checks-in-encoder"><span>Encoder:</span><input value="{{fieldValue $.Record "encoder"}}" readonly tabindex="-1" aria-readonly="true"></label>
        <label class="checks-in-field checks-in-remarks"><span>Remarks:</span><textarea name="remarks" rows="2">{{fieldValue $.Record "remarks"}}</textarea></label>
      </section>

      {{$checksInGroup := index .Form.LineGroups 0}}
      <section class="line-section modal-line-section checks-in-line-details">
        <div class="section-head"><h2>{{$checksInGroup.Label}}</h2></div>
        <div class="table-wrap modal-table">
          <table class="editable-grid checks-in-details-grid">
            <thead><tr><th>No.</th><th>Number</th><th>Date</th><th>Bank Name</th><th>Amount</th><th>Nature</th></tr></thead>
            <tbody id="rows-checks">
              {{$rows := index $.LineRows "checks"}}
              {{if $rows}}
                {{range $rows}}
                <tr class="checks-in-detail-row"><td class="row-no"></td><td class="editable-cell" contenteditable="true" data-field="number">{{fieldValue . "number"}}</td><td><input class="cell-date" type="date" data-field="date" value="{{fieldValue . "date"}}"></td><td class="editable-cell" contenteditable="true" data-field="bank_name">{{fieldValue . "bank_name"}}</td><td class="editable-cell number-cell" contenteditable="true" data-field="amount">{{fieldValue . "amount"}}</td><td class="editable-cell" contenteditable="true" data-field="nature">{{fieldValue . "nature"}}</td><td class="hidden-col"><input type="hidden" name="line_checks_number" data-field-input="number" value="{{fieldValue . "number"}}"><input type="hidden" name="line_checks_date" data-field-input="date" value="{{fieldValue . "date"}}"><input type="hidden" name="line_checks_bank_name" data-field-input="bank_name" value="{{fieldValue . "bank_name"}}"><input type="hidden" name="line_checks_amount" data-field-input="amount" value="{{fieldValue . "amount"}}"><input type="hidden" name="line_checks_nature" data-field-input="nature" value="{{fieldValue . "nature"}}"></td></tr>
                {{end}}
              {{else}}
                <tr class="checks-in-detail-row"><td class="row-no"></td><td class="editable-cell" contenteditable="true" data-field="number"></td><td><input class="cell-date" type="date" data-field="date"></td><td class="editable-cell" contenteditable="true" data-field="bank_name"></td><td class="editable-cell number-cell" contenteditable="true" data-field="amount"></td><td class="editable-cell" contenteditable="true" data-field="nature"></td><td class="hidden-col"><input type="hidden" name="line_checks_number" data-field-input="number"><input type="hidden" name="line_checks_date" data-field-input="date"><input type="hidden" name="line_checks_bank_name" data-field-input="bank_name"><input type="hidden" name="line_checks_amount" data-field-input="amount"><input type="hidden" name="line_checks_nature" data-field-input="nature"></td></tr>
              {{end}}
            </tbody>
          </table>
        </div>
      </section>
      {{else if eq .Form.Kind "dr"}}
      <section class="dr-legacy-form">
        <label class="dr-field dr-customer">
          <span>Customer:</span>
          <span class="purchase-supplier-control">
            <select name="party_id" data-dr-party-select required>
              <option value="">Select customer</option>
              {{$currentDRCustomer := fieldValue $.Record "party_id"}}
              {{range index $.Options "customers"}}
                <option value="{{.Value}}" {{if eq .Value $currentDRCustomer}}selected{{end}}>{{.Label}}</option>
              {{end}}
            </select>
            <button type="button" class="purchase-supplier-browse" data-dr-customer-browse>Browse</button>
          </span>
        </label>
        <div class="purchase-supplier-picker is-hidden" data-dr-customer-picker aria-hidden="true">
          <div class="purchase-supplier-picker-backdrop" data-dr-customer-picker-close></div>
          <div class="purchase-supplier-picker-dialog" role="dialog" aria-modal="true" aria-labelledby="dr-customer-picker-title">
            <div class="purchase-supplier-picker-titlebar">
              <h3 id="dr-customer-picker-title">Customer List</h3>
              <button type="button" class="purchase-supplier-picker-close" data-dr-customer-picker-close aria-label="Close">×</button>
            </div>
            <div class="purchase-supplier-picker-body">
              <label class="purchase-supplier-picker-search">
                <span>Search:</span>
                <input type="search" data-dr-customer-picker-search placeholder="Type customer name">
              </label>
              <div class="purchase-supplier-picker-table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>Customer</th>
                    </tr>
                  </thead>
                  <tbody data-dr-customer-picker-results></tbody>
                </table>
                <p class="purchase-supplier-picker-empty is-hidden" data-dr-customer-picker-empty>No matching customer found.</p>
              </div>
            </div>
          </div>
        </div>
        <label class="dr-field dr-entry-date">
          <span>Entry Date:</span>
          <input name="entry_date" type="date" value="{{fieldValue $.Record "entry_date"}}" required>
        </label>
        <label class="dr-field dr-number">
          <span>SO Number:</span>
          <input name="reference" value="{{fieldValue $.Record "reference"}}">
        </label>
        <label class="dr-field dr-date">
          <span>DR Date:</span>
          <input name="sales_date" type="date" value="{{fieldValue $.Record "sales_date"}}">
        </label>
        <label class="dr-field dr-remarks">
          <span>Remarks:</span>
          <textarea name="remarks" rows="2">{{fieldValue $.Record "remarks"}}</textarea>
        </label>
      </section>

      {{$drDetailsGroup := index .Form.LineGroups 0}}
      <section class="line-section modal-line-section purchase-line-section dr-line-section">
        <div class="section-head">
          <h2>{{$drDetailsGroup.Label}}</h2>
        </div>
        <div class="table-wrap modal-table">
          <table class="editable-grid dr-details-grid">
            <thead>
              <tr>
                <th>No.</th>
                <th>Stock Code</th>
                <th>Stock Name</th>
                <th>Qty</th>
              </tr>
            </thead>
            <tbody id="rows-details">
              {{$rows := index $.LineRows "details"}}
              {{if $rows}}
                {{range $rows}}
                <tr class="dr-detail-row" data-stock-picker-row="dr">
                  <td class="row-no"></td>
                  <td class="stock-code-cell"><input class="cell-combobox" data-field="stock_code" data-purchase-stock-trigger autocomplete="off" placeholder="Press Enter"></td>
                  <td class="editable-cell stock-name-cell" contenteditable="true" data-field="stock_name"></td>
                  <td class="editable-cell number-cell" contenteditable="true" data-field="qty">{{fieldValue . "qty"}}</td>
                  <td class="hidden-col">
                    <input type="hidden" name="line_details_stock_id" data-field-input="stock_id" value="{{fieldValue . "stock_id"}}">
                    <input type="hidden" name="line_details_qty" data-field-input="qty" value="{{fieldValue . "qty"}}">
                  </td>
                </tr>
                {{end}}
              {{else}}
                <tr class="dr-detail-row" data-stock-picker-row="dr">
                  <td class="row-no"></td>
                  <td class="stock-code-cell"><input class="cell-combobox" data-field="stock_code" data-purchase-stock-trigger autocomplete="off" placeholder="Press Enter"></td>
                  <td class="editable-cell stock-name-cell" contenteditable="true" data-field="stock_name"></td>
                  <td class="editable-cell number-cell" contenteditable="true" data-field="qty"></td>
                  <td class="hidden-col">
                    <input type="hidden" name="line_details_stock_id" data-field-input="stock_id">
                    <input type="hidden" name="line_details_qty" data-field-input="qty">
                  </td>
                </tr>
              {{end}}
            </tbody>
          </table>
        </div>
        <div class="purchase-stock-picker is-hidden" data-purchase-stock-picker aria-hidden="true">
          <div class="purchase-stock-picker-backdrop" data-purchase-stock-picker-close></div>
          <div class="purchase-stock-picker-dialog" role="dialog" aria-modal="true" aria-labelledby="purchase-stock-picker-title">
            <div class="purchase-stock-picker-titlebar">
              <h3 id="purchase-stock-picker-title">Stock List</h3>
              <button type="button" class="purchase-stock-picker-close" data-purchase-stock-picker-close aria-label="Close">×</button>
            </div>
            <div class="purchase-stock-picker-body">
              <label class="purchase-stock-picker-search">
                <span>Search:</span>
                <input type="search" data-purchase-stock-picker-search placeholder="Type stock code or stock name">
              </label>
              <div class="purchase-stock-picker-table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>Stock Code</th>
                      <th>Stock Name</th>
                    </tr>
                  </thead>
                  <tbody data-purchase-stock-picker-results></tbody>
                </table>
                <p class="purchase-stock-picker-empty is-hidden" data-purchase-stock-picker-empty>No matching stock found.</p>
              </div>
            </div>
          </div>
        </div>
      </section>
      {{else if eq .Form.Kind "stock-categories"}}
      <section class="stock-category-legacy-form">
        <label class="legacy-record-field legacy-record-id">
          <span>ID:</span>
          <input value="{{fieldValue $.Record "id"}}" readonly>
        </label>
        <label class="legacy-record-field">
          <span>Name:</span>
          <input name="name" value="{{fieldValue $.Record "name"}}" required>
        </label>
        <label class="legacy-record-field">
          <span>Group:</span>
          <input name="group_name" list="list-group_name" value="{{fieldValue $.Record "group_name"}}" required>
          <datalist id="list-group_name">
            {{range index $.Options "stock_category_groups"}}
              <option value="{{.Value}}">{{.Label}}</option>
            {{end}}
          </datalist>
        </label>
        <label class="legacy-record-field legacy-monitor-field">
          <span></span>
          <span class="legacy-checkbox-copy">
            <input type="checkbox" name="aps_monitor" {{if truthy (fieldValue $.Record "aps_monitor")}}checked{{end}}>
            <span>Show in APS Monitor Stock Reports</span>
          </span>
        </label>
        <label class="legacy-record-field">
          <span>Encoder:</span>
          <input value="{{fieldValue $.Record "encoder"}}" readonly tabindex="-1" aria-readonly="true">
        </label>
        <label class="legacy-record-field legacy-record-date">
          <span>Last Update:</span>
          <input value="{{fieldValue $.Record "last_update"}}" readonly tabindex="-1" aria-readonly="true">
        </label>
        <label class="legacy-record-field">
          <span>Last Update By:</span>
          <input value="{{fieldValue $.Record "updated_by"}}" readonly tabindex="-1" aria-readonly="true">
        </label>
      </section>
      {{else if eq .Form.Kind "stocks"}}
