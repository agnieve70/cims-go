        {{if and .CanDelete (not .Embedded)}}<a class="button secondary" href="/transactions/stock-transactions/{{fieldValue .Record "record_id"}}/withdrawal" target="_blank" rel="noopener">Print STW</a>{{else}}<span class="button secondary is-disabled">Print STW</span>{{end}}
        <span class="legacy-toolbar-spacer"></span>
        <button type="button" title="Open" aria-label="Open list" data-form-action="open-list"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 7h7l2 2h9v10H3z"/><path d="M3 7v12"/></svg></button>
