              <tr class="expense-detail-row"><td class="row-no"></td><td><input class="cell-combobox" list="expense-code-options" data-field="code_label" autocomplete="off"></td><td class="editable-cell" contenteditable="true" data-field="reference"></td><td class="editable-cell number-cell" contenteditable="true" data-field="cash"></td><td class="editable-cell number-cell" contenteditable="true" data-field="check"></td><td class="editable-cell number-cell" contenteditable="true" data-field="total"></td><td class="hidden-col"><input type="hidden" name="line_details_code_id" data-field-input="code_id"><input type="hidden" name="line_details_reference" data-field-input="reference"><input type="hidden" name="line_details_cash" data-field-input="cash"><input type="hidden" name="line_details_check" data-field-input="check"><input type="hidden" name="line_details_total" data-field-input="total"></td></tr>
              <tr class="expense-detail-row"><td class="row-no"></td><td><input class="cell-combobox" list="expense-code-options" data-field="code_label" autocomplete="off"></td><td class="editable-cell" contenteditable="true" data-field="reference"></td><td class="editable-cell number-cell" contenteditable="true" data-field="cash"></td><td class="editable-cell number-cell" contenteditable="true" data-field="check"></td><td class="editable-cell number-cell" contenteditable="true" data-field="total"></td><td class="hidden-col"><input type="hidden" name="line_details_code_id" data-field-input="code_id"><input type="hidden" name="line_details_reference" data-field-input="reference"><input type="hidden" name="line_details_cash" data-field-input="cash"><input type="hidden" name="line_details_check" data-field-input="check"><input type="hidden" name="line_details_total" data-field-input="total"></td></tr>
              {{end}}
            </tbody>
          </table>
        </div>
      </section>
      <section class="expense-totals"><label>Cash:<input readonly data-expense-cash-total></label><label>Check:<input readonly data-expense-check-total></label><label>Total:<input readonly data-expense-grand-total></label></section>
      {{else if eq .Form.Kind "other-income"}}
      <section class="other-income-legacy-form">
