        <button type="button" title="Previous" aria-label="Previous record" onclick="goPurchaseRecord('previous')"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16 6l-8 6 8 6z"/></svg></button>
        <button type="button" title="Next" aria-label="Next record" onclick="goPurchaseRecord('next')"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 6l8 6-8 6z"/></svg></button>
        <button type="button" title="Last" aria-label="Last record" onclick="goPurchaseRecord('last')"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 5v14"/><path d="M6 6l8 6-8 6z"/></svg></button>
