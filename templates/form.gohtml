        <label class="legacy-record-field legacy-record-date">
          <span>Last Update:</span>
          <input value="{{fieldValue $.Record "last_update"}}" readonly tabindex="-1" aria-readonly="true">
        </label>
        <label class="legacy-record-field">
          <span>Last Update By:</span>
          <input value="{{fieldValue $.Record "updated_by"}}" readonly tabindex="-1" aria-readonly="true">
        </label>
      </section>
      {{else if eq .Form.Kind "customers"}}
      <section class="stock-category-legacy-form stock-legacy-form">
        <label class="legacy-record-field legacy-record-id">
          <span>ID:</span>
          <input value="{{fieldValue $.Record "id"}}" readonly>
        </label>
        <label class="legacy-record-field">
          <span>Client Code:</span>
          <input name="code" value="{{fieldValue $.Record "code"}}" required>
        </label>
        <label class="legacy-record-field">
          <span>Company:</span>
          <input name="company" value="{{fieldValue $.Record "company"}}">
        </label>
        <label class="legacy-record-field">
          <span>Lastname:</span>
          <input name="lastname" value="{{fieldValue $.Record "lastname"}}">
        </label>
        <label class="legacy-record-field">
          <span>Firstname:</span>
          <input name="firstname" value="{{fieldValue $.Record "firstname"}}">
        </label>
        <label class="legacy-record-field">
          <span>Middle Name:</span>
          <input name="middlename" value="{{fieldValue $.Record "middlename"}}">
        </label>
        <label class="legacy-record-field">
          <span>Phone Number:</span>
          <input name="phone_number" value="{{fieldValue $.Record "phone_number"}}">
        </label>
        <label class="legacy-record-field">
          <span>Address:</span>
          <textarea name="address" rows="3">{{fieldValue $.Record "address"}}</textarea>
        </label>
        <label class="legacy-record-field legacy-record-date">
          <span>Balance:</span>
          <input name="balance" type="number" step="0.01" value="{{fieldValue $.Record "balance"}}">
        </label>
