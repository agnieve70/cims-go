    function updateOtherIncomeTotals() {
      var cash = 0;
      var check = 0;
      var total = 0;
      document.querySelectorAll(".other-income-detail-row").forEach(function (row) {
        syncOtherIncomeRow(row);
        cash += parseMoney(cellText(row.querySelector("[data-field='cash']")));
        check += parseMoney(cellText(row.querySelector("[data-field='check']")));
        total += parseMoney(cellText(row.querySelector("[data-field='total']")));
      });
      [["[data-other-income-cash-total]", cash], ["[data-other-income-check-total]", check], ["[data-other-income-grand-total]", total]].forEach(function (item) {
        var input = document.querySelector(item[0]);
        if (input) input.value = formatMoney(item[1]);
      });
    }

    function hydrateOtherIncomeRows() {
      document.querySelectorAll(".other-income-detail-row").forEach(function (row, index) {
        var no = row.querySelector(".row-no");
        var codeID = (row.querySelector("[data-field-input='code_id']") || {}).value || "";
        var code = otherIncomeCodes.find(function (item) { return item.id === codeID; });
        if (no) no.textContent = String(index + 1) + ".";
        if (code) row.querySelector("[data-field='code_label']").value = code.label;
        syncOtherIncomeRow(row);
      });
      updateOtherIncomeTotals();
    }

    window.addOtherIncomeRow = function () {
      var tbody = document.querySelector("#rows-details");
      var template = document.querySelector(".other-income-detail-row");
      if (!tbody || !template) return;
      var row = template.cloneNode(true);
      row.querySelectorAll(".editable-cell").forEach(function (cell) { cell.textContent = ""; });
      row.querySelectorAll(".cell-combobox").forEach(function (input) { input.value = ""; });
      row.querySelectorAll("input[type='hidden']").forEach(function (input) { input.value = ""; });
      tbody.appendChild(row);
      hydrateOtherIncomeRows();
      var first = row.querySelector(".cell-combobox, .editable-cell");
      if (first) first.focus();
    };

    function syncChecksInRow(row) {
      if (!row) return;
      ["number", "date", "bank_name", "amount", "nature"].forEach(function (field) {
        setHidden(row, field, cellText(row.querySelector("[data-field='" + field + "']")));
      });
    }

    function renumberChecksInRows() {
      document.querySelectorAll(".checks-in-detail-row").forEach(function (row, index) {
        var no = row.querySelector(".row-no");
        if (no) no.textContent = String(index + 1) + ".";
      });
    }

    function hydrateChecksInRows() {
      document.querySelectorAll(".checks-in-detail-row").forEach(syncChecksInRow);
      renumberChecksInRows();
    }

    window.addChecksInRow = function () {
      var tbody = document.querySelector("#rows-checks");
      var template = document.querySelector(".checks-in-detail-row");
      if (!tbody || !template) return;
      var row = template.cloneNode(true);
      row.querySelectorAll(".editable-cell").forEach(function (cell) { cell.textContent = ""; });
      row.querySelectorAll(".cell-date").forEach(function (input) { input.value = ""; });
      row.querySelectorAll("input[type='hidden']").forEach(function (input) { input.value = ""; });
      tbody.appendChild(row);
      renumberChecksInRows();
      var first = row.querySelector(".editable-cell, .cell-date");
      if (first) first.focus();
    };

    function setPurchaseTab(tab) {
      document.querySelectorAll("[data-purchase-tab]").forEach(function (button) {
        button.classList.toggle("is-active", button.dataset.purchaseTab === tab);
      });
      var adjustments = document.querySelector(".purchase-summary-grid");
      var payments = document.querySelector(".purchase-line-payments");
      if (adjustments) adjustments.classList.toggle("is-hidden", tab !== "adjustments");
      if (payments) payments.classList.toggle("is-hidden", tab !== "payments");
    }

    window.addPurchaseDetailRow = function () {
      var tbody = document.querySelector("#rows-details");
      var template = document.querySelector(".purchase-detail-row");
      if (!tbody || !template) return;
      var row = template.cloneNode(true);
      row.querySelectorAll(".editable-cell").forEach(function (cell) {
        cell.textContent = "";
      });
      row.querySelectorAll(".cell-combobox").forEach(function (input) {
        input.value = "";
      });
      row.querySelectorAll("input[type='hidden']").forEach(function (input) {
        input.value = "";
      });
      tbody.appendChild(row);
      renumberPurchaseDetails();
      updatePurchaseTotals();
      var first = row.querySelector(".cell-combobox, .editable-cell");
      if (first) first.focus();
    };

    window.addPurchaseAdjustmentRow = function (group) {
      var tbody = document.querySelector("#rows-" + group);
      var template = tbody && tbody.querySelector(".purchase-adjustment-row");
      if (!tbody || !template) return;
      var row = template.cloneNode(true);
      row.querySelectorAll(".editable-cell").forEach(function (cell) {
        cell.textContent = "";
      });
      row.querySelectorAll("input[type='hidden']").forEach(function (input) {
        input.value = "";
      });
      tbody.appendChild(row);
      updatePurchaseTotals();
      var first = row.querySelector(".editable-cell");
      if (first) first.focus();
    };

    window.addDRDetailRow = function () {
      var tbody = document.querySelector("#rows-details");
      var template = document.querySelector(".dr-detail-row");
      if (!tbody || !template) return;
      var row = template.cloneNode(true);
      row.querySelectorAll(".editable-cell").forEach(function (cell) {
        cell.textContent = "";
      });
      row.querySelectorAll(".cell-combobox").forEach(function (input) {
        input.value = "";
      });
      row.querySelectorAll("input[type='hidden']").forEach(function (input) {
        input.value = "";
      });
      tbody.appendChild(row);
      renumberDRDetails();
      var first = row.querySelector(".cell-combobox, .editable-cell");
      if (first) first.focus();
    };

    function openStockInPicker(input) {
      if (!input || typeof input.showPicker !== "function") return;
      try {
        input.showPicker();
      } catch (error) {
        // Browser may restrict showPicker unless the event is a direct user action.
      }
    }

    document.addEventListener("mousedown", function (event) {
      var input = event.target.closest && event.target.closest(".stock-in-detail-row .cell-combobox");
      openStockInPicker(input);
    });

    document.addEventListener("focus", function (event) {
      if (!event.target.matches(".stock-in-detail-row .cell-combobox")) return;
      setTimeout(function () { openStockInPicker(event.target); }, 0);
    }, true);

    document.addEventListener("click", function (event) {
      var input = event.target.closest && event.target.closest(".stock-in-detail-row .cell-combobox");
      openStockInPicker(input);
    });

    document.addEventListener("input", function (event) {
      var cell = event.target.closest && event.target.closest(".purchase-detail-row .editable-cell, .purchase-detail-row .cell-combobox");
      if (!cell) return;
      syncPurchaseDetailRow(cell.closest(".purchase-detail-row"), cell);
    });

    document.addEventListener("input", function (event) {
      var cell = event.target.closest && event.target.closest(".dr-detail-row .editable-cell, .dr-detail-row .cell-combobox");
      if (!cell) return;
      syncDRDetailRow(cell.closest(".dr-detail-row"), cell);
    });

    document.addEventListener("input", function (event) {
      if (event.target.matches("input[name='line_discounts_amount'], input[name='line_additionals_amount']")) {
        updatePurchaseTotals();
      }
      if (event.target.matches("input[name='line_deductions_amount'], input[name='line_additionals_amount']")) {
        updateSalesTotals();
      }
      var adjustmentCell = event.target.closest && event.target.closest(".purchase-adjustment-row .editable-cell");
      if (adjustmentCell) {
        syncPurchaseAdjustmentRow(adjustmentCell.closest(".purchase-adjustment-row"), adjustmentCell);
      }
      var salesCell = event.target.closest && event.target.closest(".sales-detail-row .editable-cell");
      if (salesCell) {
        syncSalesDetailRow(salesCell.closest(".sales-detail-row"));
        updateSalesTotals();
      }
      var expenseCell = event.target.closest && event.target.closest(".expense-detail-row .editable-cell, .expense-detail-row .cell-combobox");
      if (expenseCell) {
        syncExpenseRow(expenseCell.closest(".expense-detail-row"), expenseCell);
        updateExpenseTotals();
      }
      var otherIncomeCell = event.target.closest && event.target.closest(".other-income-detail-row .editable-cell, .other-income-detail-row .cell-combobox");
      if (otherIncomeCell) {
        syncOtherIncomeRow(otherIncomeCell.closest(".other-income-detail-row"), otherIncomeCell);
        updateOtherIncomeTotals();
      }
      var checksInCell = event.target.closest && event.target.closest(".checks-in-detail-row .editable-cell, .checks-in-detail-row .cell-date");
      if (checksInCell) {
        syncChecksInRow(checksInCell.closest(".checks-in-detail-row"));
      }
    });

    document.addEventListener("blur", function (event) {
      var cell = event.target.closest && event.target.closest(".purchase-detail-row .editable-cell, .purchase-detail-row .cell-combobox");
      if (cell) syncPurchaseDetailRow(cell.closest(".purchase-detail-row"), cell);
      var drCell = event.target.closest && event.target.closest(".dr-detail-row .editable-cell, .dr-detail-row .cell-combobox");
      if (drCell) syncDRDetailRow(drCell.closest(".dr-detail-row"), drCell);
      var adjustmentCell = event.target.closest && event.target.closest(".purchase-adjustment-row .editable-cell");
      if (adjustmentCell) syncPurchaseAdjustmentRow(adjustmentCell.closest(".purchase-adjustment-row"), adjustmentCell);
      var salesCell = event.target.closest && event.target.closest(".sales-detail-row .editable-cell");
      if (salesCell) {
        syncSalesDetailRow(salesCell.closest(".sales-detail-row"));
        updateSalesTotals();
      }
      var expenseCell = event.target.closest && event.target.closest(".expense-detail-row .editable-cell, .expense-detail-row .cell-combobox");
      if (expenseCell) {
        syncExpenseRow(expenseCell.closest(".expense-detail-row"), expenseCell);
        updateExpenseTotals();
      }
      var otherIncomeCell = event.target.closest && event.target.closest(".other-income-detail-row .editable-cell, .other-income-detail-row .cell-combobox");
      if (otherIncomeCell) {
        syncOtherIncomeRow(otherIncomeCell.closest(".other-income-detail-row"), otherIncomeCell);
        updateOtherIncomeTotals();
      }
      var checksInCell = event.target.closest && event.target.closest(".checks-in-detail-row .editable-cell, .checks-in-detail-row .cell-date");
      if (checksInCell) syncChecksInRow(checksInCell.closest(".checks-in-detail-row"));
    }, true);

    hydratePurchaseDetails();
    hydratePurchaseSupplier();
    hydrateDRDetails();
    hydrateDRCustomer();
    hydrateARCreditCompany();
    hydrateAPDebitCompany();
    hydrateAPCreditCompany();
    hydrateARDebitCompany();
    hydrateRebatesCompany();
    hydrateExpenseRows();
    hydrateOtherIncomeRows();
    hydrateChecksInRows();
    hydrateSalesDetails();
    updatePurchaseTotals();
    updateSalesTotals();
    setPurchaseTab("adjustments");
    setSalesTab("markup");

    document.querySelectorAll("[data-purchase-tab]").forEach(function (button) {
      button.addEventListener("click", function () {
        setPurchaseTab(button.dataset.purchaseTab);
      });
    });

    document.querySelectorAll("[data-sales-tab]").forEach(function (button) {
      button.addEventListener("click", function () {
        setSalesTab(button.dataset.salesTab);
      });
    });

    document.querySelectorAll("[data-form-action]").forEach(function (button) {
      button.addEventListener("click", function () {
        var action = button.getAttribute("data-form-action");
        if (action === "new") window.location.href = routeBase + "/new";
        if (action === "open-list") window.location.href = routeBase + "/";
      });
    });
  })();
</script>
{{end}}
{{template "foot" .}}
